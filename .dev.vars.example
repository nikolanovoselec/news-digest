# Copy to .dev.vars for local development. NEVER commit .dev.vars.
#
# Required regardless of which sign-in provider you enable:
OAUTH_JWT_SECRET=local-dev-secret-32-chars-minimum-abcdef
APP_URL=http://localhost:4321

# Sign-in providers — set at least one pair. The landing page renders
# one button per provider that has both id+secret configured, listed
# alphabetically. A pair with only one field set is rejected by the
# deploy workflow.
GH_OAUTH_CLIENT_ID=your-github-oauth-app-client-id
GH_OAUTH_CLIENT_SECRET=your-github-oauth-app-client-secret
# GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret

# Optional — when both are unset the email step is silently skipped
# (digests still generate). Set both together or leave both blank.
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=News Digest <digest@localhost>

# Optional — dev/e2e bypass. When DEV_BYPASS_TOKEN is set, /api/dev/login
# and /api/dev/trigger-scrape accept a Bearer token to mint a synthetic
# session without going through OAuth. Leave unset on production
# deploys (those endpoints return 404 when the token is missing).
# DEV_BYPASS_TOKEN=local-only-bypass-token
# DEV_BYPASS_USER_ID overrides the user id minted by /api/dev/login.
# Defaults to the synthetic __e2e__ row from migrations/0006_e2e_user.sql
# so e2e tests never mutate the operator's account.
# DEV_BYPASS_USER_ID=__e2e__
