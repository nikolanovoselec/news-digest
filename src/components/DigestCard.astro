---
// Implements REQ-READ-001, REQ-READ-002
// Implements REQ-STAR-001
// Implements REQ-PIPE-002 (renders per-article tag list from validated tag allowlist)
//
// Single article card for the digest overview grid. Renders the title,
// 120-char one-liner summary, source-name badge, a star-toggle button,
// and an inline `#` disclosure that opens a non-interactive popover
// with the article's tag list (REQ-READ-001 AC 6).
//
// View Transitions: each card carries a unique `transition:name` derived
// from the article slug so Astro's ClientRouter performs a shared-element
// morph into the detail page's matching container. The detail page uses
// the same name on its title wrapper.
//
// Text is rendered as plain `{expression}` — Astro escapes by default,
// so REQ-READ-002 AC 2 (no innerHTML, no markdown parsing) is satisfied
// without extra work in this component.

interface Props {
  digestId: string;
  /** Article id, used for the star-toggle endpoint.
   *  Falls back to digestId when not supplied (callers that still pass
   *  the old shape keep working — the two ids happen to be the same in
   *  the global-feed schema). */
  articleId?: string;
  slug: string;
  title: string;
  oneLiner: string;
  sourceName: string | null;
  /** Outbound URL to the original article — used as the hostname
   * fallback when sourceName is null so the card never renders
   * without any source attribution. */
  sourceUrl?: string | null;
  /** Article tag list validated against the system allowlist. Empty array when no tags. */
  tags?: string[];
  /** Initial star state for the session user. Drives the button's
   *  glyph (filled vs outline) and aria-pressed attribute on first
   *  render. Defaults to false when the caller hasn't wired the
   *  per-user JOIN yet. */
  starred?: boolean;
  /**
   * Accepted for backward compatibility with callers that pass a
   * grid index (the old per-card stagger animation consumed it). The
   * animation is gone; the prop is retained as a no-op so callers
   * don't need an ordering churn.
   */
  index?: number;
}

const {
  digestId,
  articleId = digestId,
  slug,
  title,
  oneLiner,
  sourceName,
  sourceUrl = null,
  tags = [],
  starred = false,
  index = 0,
} = Astro.props;

const href = `/digest/${digestId}/${slug}`;
const transitionName = `card-${slug}`;
// No-op stagger calculation kept so existing call sites that pass
// `index={i}` don't need updating. Clamp preserved for when we
// revive any per-card staging (accessibility focus order, e.g.).
const stagger = Math.min(index, 9);
// data-tags is the filter contract with the tag-strip script on
// digest.astro: a comma-joined list so the script can intersect against
// the selected-tag set without re-parsing JSON per card.
const tagAttr = tags.join(',');

/** Resolve the badge text shown at the bottom-left of the card.
 *  Preference order: the fan-out source_name (minus the `feed:`
 *  namespace prefix) → the source-URL hostname minus `www.`. Only
 *  returns the empty string when every fallback is missing. Pure
 *  display logic — doesn't mutate the DB. */
function resolveDisplaySource(): string {
  if (sourceName !== null && sourceName !== '') {
    return sourceName.startsWith('feed:')
      ? sourceName.slice('feed:'.length)
      : sourceName;
  }
  if (typeof sourceUrl === 'string' && sourceUrl !== '') {
    try {
      const host = new URL(sourceUrl).host;
      return host.replace(/^www\./, '');
    } catch {
      return '';
    }
  }
  return '';
}
const displaySourceName = resolveDisplaySource();
---

<article
  class="digest-card"
  data-digest-card
  data-article-id={articleId}
  data-starred={starred ? 'true' : 'false'}
  data-stagger-index={stagger}
  data-tags={tagAttr}
  style={`--stagger-delay: ${stagger * 40}ms`}
>
  {/* Anchor wraps ONLY the read area (title + excerpt). The footer
      row sits as a sibling outside the anchor so its <button>s
      receive touch events natively — nesting <button> inside <a>
      flattens to the anchor on mobile Safari/Samsung Browser, which
      is why the star and # were unresponsive to taps. */}
  <a
    class="digest-card__link"
    href={href}
    transition:name={transitionName}
    aria-label={title}
  >
    <h2 class="digest-card__title">{title}</h2>
    <p class="digest-card__one-liner">{oneLiner}</p>
  </a>
  <footer class="digest-card__footer">
    <span class="digest-card__footer-left">
      {
        displaySourceName !== null && displaySourceName !== '' && (
          <span class="digest-card__source">{displaySourceName}</span>
        )
      }
    </span>
    <span class="digest-card__footer-right">
      {/* Implements REQ-STAR-001 — star toggle sits immediately
          before the # affordance so the two interactive controls
          read as a single bottom-right cluster. Same glyph weight
          + muted colour so neither dominates. */}
      <button
        type="button"
        class="digest-card__star"
        data-star-toggle
        data-article-id={articleId}
        aria-pressed={starred ? 'true' : 'false'}
        aria-label={starred ? `Unstar ${title}` : `Star ${title}`}
      >
        <svg
          class="digest-card__star-icon digest-card__star-icon--filled"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
        </svg>
        <svg
          class="digest-card__star-icon digest-card__star-icon--outline"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21 12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61z" />
        </svg>
      </button>
      {
        tags.length > 0 && (
          <div class="digest-card__tag-disclosure" data-tag-disclosure>
            <button
              type="button"
              class="digest-card__tag-trigger"
              data-tag-trigger
              aria-label={`Show ${tags.length} tag${tags.length === 1 ? '' : 's'} for ${title}`}
              aria-expanded="false"
            >
              #{tags.length}
            </button>
            <div class="digest-card__tag-popover" role="region">
              {tags.map((t) => (
                <span class="digest-card__tag-chip">#{t}</span>
              ))}
            </div>
          </div>
        )
      }
    </span>
  </footer>
</article>

<style>
  .digest-card {
    position: relative;
    /* The card itself is a flex container too so the inner anchor
       (.digest-card__link) can flex: 1 1 auto and stretch to the
       FULL height the grid gives us. Without this, the grid stretches
       the card but the anchor stays content-sized, the anchor's flex
       layout only sees its own content height, and 'margin-top: auto'
       on the footer pushes it to the wrong point. */
    display: flex;
    flex-direction: column;
    background-color: var(--surface);
    background-image: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.02),
      transparent 40%
    );
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    opacity: 1;
  }

  .digest-card__link {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.1rem 1.25rem 0.75rem;
    color: var(--text);
    text-decoration: none;
    min-width: 0;
    /* Fill the card's vertical space so the one-liner's bottom edge
       aligns near the footer regardless of content length. */
    flex: 1 1 auto;
  }

  /* Footer is a sibling of the anchor (kept OUTSIDE so its <button>s
     receive mobile touch events natively). It pins to the card's
     bottom via the card being flex-column with footer as the last
     child; the anchor's flex:1 consumes the remaining height.
     position:relative + z-index:1 guarantees the footer stacks above
     the sibling anchor on every engine — some mobile browsers paint
     later-DOM-order flex siblings underneath earlier ones when both
     are flex items and positions implicit; the explicit z-index
     removes that ambiguity. */
  .digest-card__footer {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0 1.25rem 1.1rem;
    position: relative;
    z-index: 1;
  }
  .digest-card__footer-left,
  .digest-card__footer-right {
    flex: 1 1 0;
    display: inline-flex;
    align-items: center;
    min-width: 0;
  }
  .digest-card__footer-left {
    justify-content: flex-start;
  }
  .digest-card__footer-right {
    justify-content: flex-end;
    /* Small separator between the star pill and the # pill so they
       read as two discrete controls rather than a joined bar. */
    gap: 8px;
  }
  .digest-card__footer-center {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  /* Star toggle — matches the # affordance's visual weight: muted
     text-sm, transparent background, no border. 14×14 glyph paired
     with 0 padding so the rendered size tracks the '#' character
     directly. A generous invisible hit area (2px padding) keeps
     touch-targetability without the button looking bigger than #. */
  /* Star toggle — matches the pre-pill compact size the user asked
     for (see the black '#' screenshot). DELIBERATELY no explicit
     height: padding: 2px 4px + a 14×14 SVG gives ~18px visual
     height, hugging the glyph without a filled pill rectangle
     dominating the card. Identical geometry to
     .digest-card__tag-trigger so the two read as a paired set. */
  .digest-card__star {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 2px 4px;
    line-height: 1;
    background: transparent;
    border: 0;
    border-radius: 3px;
    color: var(--text-muted);
    opacity: 0.7;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    /* Tell mobile browsers this is a single-tap target, not a
       scroll/pinch target — prevents the 300ms delay that can
       eat first-taps on some mobile engines. */
    touch-action: manipulation;
    transition:
      background-color 150ms var(--ease, ease),
      color 150ms var(--ease, ease),
      opacity 150ms var(--ease, ease);
  }
  .digest-card__star:hover {
    color: var(--text);
    opacity: 1;
  }
  .digest-card__star[aria-pressed='true'] {
    background: var(--text);
    color: var(--bg);
    opacity: 1;
  }
  .digest-card__star[aria-pressed='true']:hover {
    background: color-mix(in oklab, var(--text) 88%, var(--text-muted) 12%);
  }
  .digest-card__star-icon {
    display: inline-flex;
  }
  /* Default: unstarred → show outline, hide filled. aria-pressed='true'
     inverts. Both glyphs share the same 24×24 viewBox so the swap is a
     pure visibility flip with no layout shift. */
  .digest-card__star-icon--filled {
    display: none;
  }
  .digest-card__star[aria-pressed='true'] .digest-card__star-icon--filled {
    display: inline-flex;
  }
  .digest-card__star[aria-pressed='true'] .digest-card__star-icon--outline {
    display: none;
  }

  .digest-card:hover {
    border-color: var(--text-muted);
  }

  .digest-card__link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 0.5rem;
  }

  .digest-card__title {
    margin: 0;
    /* Editorial serif — same family as the article-detail headline
       and the dashboard "Today's digest" anchor, so the card reads
       as a mini-front-page teaser rather than a generic list row. */
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.01em;
    min-width: 0;
    text-wrap: balance;
  }

  /* Tag disclosure: plain <div> wrapper + <button> trigger. The
     popover is always in the DOM with visibility: hidden; CSS flips
     visibility + opacity on :hover (desktop) or .is-open (mobile,
     set by the client script). Simpler and more predictable than
     <details>, whose UA rule `display: none` on non-open children
     fought the :hover rule on specificity. */
  .digest-card__tag-disclosure {
    position: relative;
    flex-shrink: 0;
  }

  /* Demote the # to a lightweight muted glyph — no box, no border,
     just a clickable character. It's a secondary affordance; the
     article title owns the card's visual weight. Hitbox stays
     comfortably large via padding on the <summary>, not a min-size
     box. */
  /* Tag trigger reads as a small inverted-theme pill — same treatment
     as the selected tag-chip and the primary CTAs elsewhere in the
     app (background=var(--text), color=var(--bg)). Sits at 10%
     larger font than the footer's text-sm baseline so it has a bit
     more presence than the single-character '#' had before. */
  .digest-card__tag-trigger {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 2px 4px;
    background: var(--text);
    border: 0;
    border-radius: 3px;
    color: var(--bg);
    font-size: var(--text-sm);
    font-weight: 600;
    font-family: inherit;
    line-height: 1;
    user-select: none;
    cursor: pointer;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    transition:
      background-color 150ms ease,
      color 150ms ease,
      opacity 150ms ease;
  }
  .digest-card__tag-trigger:hover,
  .digest-card__tag-disclosure.is-open .digest-card__tag-trigger {
    /* Subtle darken on hover / while open — mixes the inverted
       background toward the text-muted tone. */
    background: color-mix(in oklab, var(--text) 88%, var(--text-muted) 12%);
  }

  .digest-card__one-liner {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-base);
    line-height: 1.45;
    /* Clamp to exactly 3 lines with an ellipsis. Summaries longer
       than 3 lines are truncated with "…"; summaries shorter fill
       what they occupy. Pairs with the details[0] feed on the
       dashboard/history surfaces. */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Source name gets a small-caps treatment — no pill, no background.
     It's metadata, not an interactive control, and de-pilling it lets
     the card's real pills (tag chips) own the "clickable" affordance
     without visual competition. */
  /* Source name — small-caps metadata that matches the article-
     detail page's metadata line. Sits at the bottom-left of the card
     via the footer row. */
  .digest-card__source {
    display: inline-block;
    padding: 0;
    background: transparent;
    color: var(--text-muted);
    border: 0;
    border-radius: 0;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  /* Popover — always in the DOM, hidden via visibility + opacity so
     CSS :hover can toggle it without fighting a UA display:none rule.
     Anchored to the bottom-right of the # trigger and opens UPWARD
     so it never clips below the grid. Uses the same inverted-theme
     palette as the # trigger: bg = var(--text), chip text =
     var(--bg), so the popover reads as a "pinned" version of the
     same pill rather than a floating card. */
  .digest-card__tag-popover {
    position: absolute;
    bottom: calc(100% + 6px);
    right: 0;
    z-index: 5;
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    padding: 6px 8px;
    background: var(--text);
    color: var(--bg);
    border: 1px solid var(--text);
    border-radius: 6px;
    max-width: min(260px, 80vw);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.25);
    visibility: hidden;
    opacity: 0;
    transform: translateY(4px);
    transition:
      opacity 150ms var(--ease, ease),
      transform 150ms var(--ease, ease),
      visibility 0s linear 150ms;
    pointer-events: none;
  }
  .digest-card__tag-disclosure.is-open .digest-card__tag-popover {
    visibility: visible;
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0s;
    pointer-events: auto;
  }
  /* Desktop (hover-capable) — popover opens on hover without any JS.
     Mobile keeps the click-to-open flow via the .is-open class, set
     by the script at the bottom of this file. */
  @media (hover: hover) and (pointer: fine) {
    .digest-card__tag-disclosure:hover .digest-card__tag-popover {
      visibility: visible;
      opacity: 1;
      transform: translateY(0);
      transition-delay: 0s;
      pointer-events: auto;
    }
  }

  /* Tag chips inside the # popover are plain text — no pill, no
     background, no border. The popover itself provides the inverted
     background; the chips just inherit its color. */
  .digest-card__tag-chip {
    display: inline-block;
    padding: 0;
    background: transparent;
    color: inherit;
    border: 0;
    border-radius: 0;
    font-size: var(--text-sm);
    line-height: 1.4;
  }

  /* Hide a card when the tag-strip filter is active and the card's
     tag list does not intersect the selection. The digest.astro script
     sets data-filter-hide on miss. */
  .digest-card[data-filter-hide='1'] {
    display: none;
  }
</style>

<script>
  // All card interactions (star toggle + tag-disclosure popover) live
  // in src/scripts/card-interactions.ts. That module binds direct
  // click handlers to every button on DOMContentLoaded and on
  // astro:page-load — no event delegation, no capture-phase tricks.
  import '~/scripts/card-interactions';
</script>
