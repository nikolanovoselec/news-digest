---
// Implements REQ-SET-004
//
// Dropdown populated from the hardcoded `MODELS` catalog. Options are
// grouped by `category` using native `<optgroup>` (Featured / Budget)
// so the order and labels travel with the server render.
//
// Per-option cost is computed from the model's per-million-token prices
// via `estimateCost`. The token budget (2000 in / 800 out) is an estimate
// for a single daily digest derived from the prompt size cap in
// REQUIREMENTS.md — it's a rough figure used to help users pick, not a
// hard budget enforced anywhere else.

import { MODELS, DEFAULT_MODEL_ID, estimateCost, type ModelOption } from '~/lib/models';

interface Props {
  /** Currently saved model id. Falls back to the project default. */
  selected?: string | null;
  /** Form field name — defaults to `model_id`. */
  name?: string;
  /** Form field id — defaults to `model_id` to pair with a <label for="model_id">. */
  id?: string;
}

const { selected, name = 'model_id', id = 'model_id' } = Astro.props;
const activeId = selected ?? DEFAULT_MODEL_ID;

// Token estimate for a single digest — used only for the dropdown
// preview. Real per-digest costs are logged against `digests.estimated_cost_usd`.
const TOKENS_IN = 2000;
const TOKENS_OUT = 800;

function formatCost(cents: number): string {
  // Show 4 decimals for sub-penny estimates so the user can see a real
  // delta between the cheapest and most expensive models. "free" is
  // shown for models whose prices have not been published (0 / 0).
  if (cents === 0) return 'free';
  return `$${cents.toFixed(4)} / digest`;
}

function optionLabel(model: ModelOption): string {
  const cost = formatCost(estimateCost(model.id, TOKENS_IN, TOKENS_OUT));
  return `${model.name} — ${model.description} (${cost})`;
}

const featured = MODELS.filter((m) => m.category === 'featured');
const budget = MODELS.filter((m) => m.category === 'budget');
---

<select id={id} name={name} class="model-select">
  <optgroup label="Featured">
    {
      featured.map((m) => (
        <option value={m.id} selected={m.id === activeId}>
          {optionLabel(m)}
        </option>
      ))
    }
  </optgroup>
  <optgroup label="Budget">
    {
      budget.map((m) => (
        <option value={m.id} selected={m.id === activeId}>
          {optionLabel(m)}
        </option>
      ))
    }
  </optgroup>
</select>

<style>
  .model-select {
    width: 100%;
    min-height: 44px;
    padding: 0.5rem 0.75rem;
    background-color: var(--bg);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 0.375rem;
    font-size: var(--text-base);
  }

  .model-select:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
</style>
