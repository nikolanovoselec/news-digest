---
// Implements REQ-PWA-001
//
// Cross-platform install prompt.
//
// - Android / desktop Chrome: captures the `beforeinstallprompt` event and
//   exposes an "Install app" button that resolves the deferred prompt.
// - iOS Safari: has no `beforeinstallprompt`; detect via user-agent sniff and
//   `!navigator.standalone`, then render a one-time instructional note
//   ("Tap the share icon, then Add to Home Screen").
//
// Hidden when the app is already running in standalone display mode
// (`window.matchMedia('(display-mode: standalone)').matches` or
// `navigator.standalone === true` on iOS).
//
// Requires the following Apple meta tags in `src/layouts/Base.astro`
// (added by the Design phase — Phase 9 — and duplicated here in this
// phase for independence):
//   - <meta name="apple-mobile-web-app-capable" content="yes">
//   - <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
//   - <meta name="apple-mobile-web-app-title" content="newsdigest">
//   - <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png">

interface Props {
  /** Optional className for the wrapper element (e.g. to hide on specific pages). */
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<div
  class:list={['install-prompt', className]}
  data-install-prompt
  hidden
  role="region"
  aria-label="Install app"
>
  <button
    type="button"
    data-install-button
    hidden
    class="install-prompt__button"
  >
    Install app
  </button>
  <p
    data-install-ios-note
    hidden
    class="install-prompt__ios-note"
  >
    Tap the share icon, then <strong>Add to Home Screen</strong>.
  </p>
</div>

{/* Static-served from /public so the site CSP `script-src 'self'`
    permits it. Astro 5 directRenderScript inlines pure-import script
    tags regardless of size, and the inline emit is then blocked by
    CSP. The .ts source under src/scripts/install-prompt.ts mirrors
    this file. */}
<script is:inline type="module" src="/scripts/install-prompt.js"></script>

<style>
  .install-prompt {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    background-color: var(--surface);
    color: var(--text);
  }

  .install-prompt[hidden] {
    display: none;
  }

  .install-prompt__button {
    min-height: 44px;
    min-width: 44px;
    padding: 0.5rem 1rem;
    background-color: var(--text);
    color: var(--bg);
    border: none;
    border-radius: 0.375rem;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
  }

  .install-prompt__button[hidden] {
    display: none;
  }

  .install-prompt__ios-note {
    margin: 0;
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.4;
  }

  .install-prompt__ios-note[hidden] {
    display: none;
  }
</style>
