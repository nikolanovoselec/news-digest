---
// Implements REQ-DES-002: single toggle button with sun/moon icons that
// swaps `data-theme` on <html> and persists to localStorage.theme.
// The actual click handler lives in src/scripts/bundled/theme-toggle.ts and is loaded
// as a client-side module via the <script> tag below; Astro hoists and bundles
// component-level scripts automatically.
//
// CF-059: sun/moon SVG icons moved to ThemeIcon.astro.
// CF-021: this file is the canonical sun/moon toggle for the whole app.
// HeaderThemeToggle.astro was merged in via a `variant` prop. The
// `header` variant produces the compact 32px control that sits next
// to the UserMenu avatar in the authenticated header; the `default`
// variant produces the same control used on anonymous pages (login,
// landing, logged-out errors). Both variants share the same click
// wiring below so the inline duplicate in UserMenu.astro could be
// removed.
import ThemeIcon from '~/components/ThemeIcon.astro';

interface Props {
  /**
   * Visual variant. `default` is the standalone control used on
   * anonymous pages; `header` is the compact authenticated-header
   * variant that pairs with the UserMenu avatar (no focus-ring
   * outline, no background transition).
   */
  variant?: 'default' | 'header';
}

const { variant = 'default' } = Astro.props;
const buttonClass =
  variant === 'header' ? 'theme-toggle theme-toggle--header focus-ring' : 'theme-toggle';
---

<button
  type="button"
  class={buttonClass}
  aria-label="Toggle color theme"
  data-theme-toggle
>
  <ThemeIcon variant="sun" class="theme-toggle__icon theme-toggle__icon--sun" />
  <ThemeIcon variant="moon" class="theme-toggle__icon theme-toggle__icon--moon" />
</button>

<style>
  /* Match the UserMenu avatar trigger geometry (44px tap target, 32px
     visual circle, transparent border that becomes visible on hover)
     so the two controls read as a paired set on the authenticated
     header. The same geometry applies to anonymous pages so the
     control reads consistently across the app.
     `outline: none` on every focus state kills the persistent
     circular ring some mobile engines paint when :focus-visible
     fires on tap. The icon itself is the affordance; the control
     doesn't need a focus ring on top of it. */
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
    padding: 4px;
    background: transparent;
    border: 1px solid transparent;
    border-radius: 9999px;
    color: var(--text);
    cursor: pointer;
    outline: none;
    -webkit-tap-highlight-color: transparent;
  }
  .theme-toggle:focus,
  .theme-toggle:focus-visible,
  .theme-toggle:active {
    outline: none;
    box-shadow: none;
  }
  /* Hover border ONLY on true-pointer devices. Samsung Browser and
     Android Chrome latch :hover state after a tap until another tap
     lands elsewhere, so a flat :hover rule would leave a 1px
     circular border around the button after every tap. `@media
     (hover: hover)` is how you tell CSS "this device can actually
     move a pointer off an element", which excludes all touch-primary
     surfaces. */
  @media (hover: hover) and (pointer: fine) {
    .theme-toggle:hover {
      border-color: var(--border);
    }
  }

  /* `:global(...)` selectors are required after CF-059 because the
     icon wrapper <span> is rendered by ThemeIcon.astro (a child
     component), not by this file. Astro applies its scope hash only
     to selectors and elements declared in the same component's
     <style> block; the child component's <span> carries the bare
     unscoped class names this parent passes via props. Without the
     :global wrapping, the scoped rules below would never match the
     child's DOM and both icons would render simultaneously (the bug
     this fix repairs). */
  :global(.theme-toggle__icon) {
    display: none;
    line-height: 0;
  }

  /* Show the sun in dark mode (click to go light), moon in light mode. */
  :global([data-theme='light'] .theme-toggle__icon--moon) {
    display: inline-flex;
  }
  :global([data-theme='dark'] .theme-toggle__icon--sun) {
    display: inline-flex;
  }

  /* 150ms cross-fade on color/background-color per REQ-DES-002. The
     `header` variant skips the background-color transition because
     it never paints a filled surface (the authenticated header sits
     on a different background than the rest of the page). */
  @media (prefers-reduced-motion: no-preference) {
    .theme-toggle {
      transition:
        background-color var(--duration-fast) var(--ease),
        color var(--duration-fast) var(--ease),
        border-color var(--duration-fast) var(--ease);
    }
    .theme-toggle--header {
      transition:
        color var(--duration-fast) var(--ease),
        border-color var(--duration-fast) var(--ease);
    }
  }
</style>

<script>
  // Implements REQ-DES-002 click handler wiring. Uses a document-
  // level delegated click handler gated by a flag on <html> so there
  // is NO race between when the button enters the DOM and when the
  // script binds - every tap anywhere on a [data-theme-toggle]
  // element fires `toggleTheme` immediately, even if this script
  // happened to execute before Astro's ViewTransition placed the
  // button. Fixes the "tap sometimes does nothing until I reload"
  // mobile bug the per-button initThemeToggle pattern had.
  //
  // CF-021: this is now the SOLE theme-click handler in the app.
  // The duplicate handler that used to live in UserMenu.astro was
  // removed when HeaderThemeToggle.astro was merged into this file
  // as a variant - both variants share this listener so there is no
  // longer a chance of double-firing.
  import { toggleTheme } from '~/scripts/bundled/theme-toggle';

  if (document.documentElement.dataset['themeToggleBound'] !== '1') {
    document.documentElement.dataset['themeToggleBound'] = '1';
    document.addEventListener(
      'click',
      (e) => {
        const t = e.target;
        if (!(t instanceof Element)) return;
        const btn = t.closest<HTMLButtonElement>('[data-theme-toggle]');
        if (btn === null) return;
        e.preventDefault();
        toggleTheme(document, localStorage, (q) => window.matchMedia(q));
      },
      true,
    );
  }
</script>
