---
// Implements REQ-DES-001 (system fonts, type scale, focus ring come in via global.css).
// Implements REQ-DES-002 (no-FOUC via defer-loaded /theme-init.js before stylesheet; header hosts ThemeToggle).
// Implements REQ-DES-003 (Astro View Transitions enabled → 250ms cross-fade default between routes).
// Implements REQ-PWA-001 (web app manifest link + Apple PWA meta tags for iOS home-screen install).
// Implements REQ-PWA-003 (viewport meta already uses viewport-fit=cover for safe-area insets).

import { ClientRouter } from 'astro:transitions';
import ThemeToggle from '~/components/ThemeToggle.astro';
import UserMenu from '~/components/UserMenu.astro';
import HeaderThemeToggle from '~/components/HeaderThemeToggle.astro';
import '~/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  /**
   * When true, the side/bottom navigation only exposes the Settings
   * entry. Used during first-run onboarding: the settings-gate
   * middleware already 303s every other route back to /settings, so
   * showing Digest / History tabs as clickable is a UX dead-end.
   */
  firstRun?: boolean;
  /**
   * If true, emit `<meta name="robots" content="noindex, follow">`.
   * Authenticated surfaces (dashboard, settings, starred, history,
   * article detail) pass this so they're kept out of public indices.
   */
  noindex?: boolean;
  /**
   * Canonical URL for this page. When omitted, derived from
   * `Astro.url.origin + Astro.url.pathname` — safe for most routes
   * since the site doesn't use query-string-driven canonical variants.
   */
  canonical?: string;
  /** Optional explicit open-graph image (1200×630). Defaults to /og.png. */
  ogImage?: string;
}

const {
  title = 'News Digest',
  description = 'A daily, AI-curated news digest. Pick your interests, we fetch and summarise the day — fresh every hour, delivered at your time.',
  firstRun = false,
  noindex = false,
  canonical,
  ogImage,
} = Astro.props;

// Full title format: "<page> — News Digest" unless the caller passed
// the root brand already. Home/landing uses the brand verbatim.
const fullTitle =
  title === 'News Digest' || title.startsWith('News Digest')
    ? title
    : `${title} — News Digest`;

const canonicalUrl =
  canonical ?? `${Astro.url.origin}${Astro.url.pathname}`;
// Default og:image is a 1200×630 branded SVG in public/og.svg. Twitter,
// LinkedIn, Slack, and Discord render SVG cards; Facebook's scraper
// rejects SVG og:images and will fall back to a text-only card, which
// is still better than the prior "no image at all" default. A caller
// can override with a raster PNG when one is generated per-page.
const ogImageUrl = ogImage ?? `${Astro.url.origin}/og.svg`;
const ogImageType = ogImageUrl.endsWith('.svg') ? 'image/svg+xml' : 'image/png';

// Server-side theme resolution (REQ-DES-002).
// Reading the `theme` cookie lets us set `data-theme` on <html> in the FIRST
// byte we emit, eliminating the flash where CSS applies the :root (light)
// tokens before the deferred theme-init.js script runs. The cookie is written
// by theme-toggle.ts alongside localStorage. Falls back to `light` when the
// cookie is absent — prefers-color-scheme is only visible client-side.
function readThemeCookie(cookieHeader: string | null): 'light' | 'dark' | null {
  if (cookieHeader === null || cookieHeader === '') return null;
  for (const pair of cookieHeader.split(';')) {
    const idx = pair.indexOf('=');
    if (idx < 0) continue;
    const name = pair.slice(0, idx).trim();
    const value = pair.slice(idx + 1).trim();
    if (name === 'theme' && (value === 'light' || value === 'dark')) return value;
  }
  return null;
}
const cookieTheme = readThemeCookie(Astro.request.headers.get('Cookie'));
const initialTheme = cookieTheme ?? 'light';
---

<!doctype html>
<html lang="en" data-theme={initialTheme}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>

    {/* Canonical + indexing hints. Authenticated pages pass noindex so
        search engines don't surface login walls or user-specific
        dashboards. */}
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, follow" />}

    {/* Open Graph (Facebook, LinkedIn, Slack, Discord, etc.) */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="News Digest" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content={ogImageType} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="News Digest — your daily tech digest, distilled by AI." />
    <meta property="og:locale" content="en_US" />

    {/* Twitter / X card — summary_large_image whenever we ship an og:image. */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="News Digest — your daily tech digest, distilled by AI." />

    {/* Performance hints — the site itself has no third-party deps on
        the critical path, but the dns-prefetch cost is ~0 and keeps the
        door open for future font/avatar hosts without a redeploy. */}
    <link rel="dns-prefetch" href="//secure.gravatar.com" />

    {/* pwa:apple-tags:start — REQ-PWA-001 AC 3. Keep these markers so this
        block stays idempotent across concurrent edits from other phases. */}
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#ffffff" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0b0b0d" />
    <meta name="color-scheme" content="light dark" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Digest" />
    {/* SVG apple-touch-icon — Safari 13+ supports it; older versions
        fall back to the favicon. We don't ship a raster PNG because we
        have no image pipeline to keep it in sync with the SVG master. */}
    <link rel="apple-touch-icon" href="/icons/app-icon.svg" />
    {/* pwa:apple-tags:end */}

    {/* Schema.org JSON-LD: WebSite + Organization. Gives Google a clean
        knowledge-panel card and disambiguates the site from the
        publisher entity.

        Defensive escape: replace </ with <\/ in the serialized JSON so
        any future caller-supplied string that contains a literal
        </script> sequence can't escape the script tag and inject
        arbitrary HTML. Current callers pass only server-controlled
        values; this is insurance for future refactors. */}
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@graph': [
        {
          '@type': 'WebSite',
          '@id': `${Astro.url.origin}/#website`,
          url: Astro.url.origin,
          name: 'News Digest',
          description,
          publisher: { '@id': `${Astro.url.origin}/#org` },
          inLanguage: 'en',
        },
        {
          '@type': 'Organization',
          '@id': `${Astro.url.origin}/#org`,
          name: 'Gray Matter GmbH',
          url: 'https://graymatter.ch',
          logo: `${Astro.url.origin}/favicon.svg`,
        },
      ],
    }).replace(/<\//g, '<\\/')} />

    {/* REQ-DES-002: /theme-init.js reconciles the server-rendered data-theme
        with prefers-color-scheme on a first visit where no cookie is set. */}
    <script is:inline defer src="/theme-init.js"></script>

    <ClientRouter />
  </head>
  <body
    data-first-run={firstRun ? 'true' : 'false'}
    data-user-tz={Astro.locals.user?.tz ?? ''}
  >
    <header class="site-header safe-top safe-x">
      <a href="/" class="site-header__brand focus-ring" aria-label="News Digest home">
        <svg
          class="site-header__mark"
          width="32"
          height="32"
          viewBox="0 0 24 24"
          aria-hidden="true"
          fill="currentColor"
        >
          {/* MDI newspaper-variant-outline — https://pictogrammers.com/library/mdi/icon/newspaper-variant-outline/ */}
          <path d="M20,11H4V8H20M20,15H13V13H20M20,19H13V17H20M11,19H4V13H11M20.33,4.67L18.67,3L17,4.67L15.33,3L13.67,4.67L12,3L10.33,4.67L8.67,3L7,4.67L5.33,3L3.67,4.67L2,3V19A2,2 0 0,0 4,21H20A2,2 0 0,0 22,19V3L20.33,4.67Z" />
        </svg>
        <span class="site-header__wordmark">
          <span class="site-header__word site-header__word--one">news</span><span class="site-header__word site-header__word--two">digest</span>
        </span>
      </a>
      <nav class="site-header__nav" aria-label="Primary">
        {/* Anonymous pages (landing, logged-out error pages) keep the
            standalone ThemeToggle because there's no UserMenu on those
            pages to provide the delegated click handler.
            Authenticated pages get a compact HeaderThemeToggle to the
            LEFT of the avatar — the sun/moon icon is a single-tap
            control; dark mode is no longer buried in the UserMenu
            dropdown. */}
        {!Astro.locals.user && <ThemeToggle />}
        {/* UserMenu is NOT hidden during firstRun — the user still needs
            a way to log out if they change their mind about onboarding,
            and the Settings link inside the menu points at the page
            they're already on (harmless). REQ-SET-006 gates navigation
            to other destinations; user identity controls are exempt. */}
        {Astro.locals.user && <HeaderThemeToggle />}
        {Astro.locals.user && (
          <UserMenu email={Astro.locals.user.email} login={Astro.locals.user.gh_login} />
        )}
      </nav>
    </header>
    <main class="site-main safe-x">
      <slot />
    </main>

    <footer class="site-footer safe-x" aria-label="Site footer">
      <p class="site-footer__copy">
        Built with <a class="site-footer__link" href="https://codeflare.ch/" target="_blank" rel="noopener noreferrer"><span class="site-footer__scramble" aria-label="Codeflare"><span class="site-footer__scramble-ghost" aria-hidden="true">Codeflare</span><span class="site-footer__scramble-live js-scramble-target" aria-hidden="true">Codeflare</span></span></a> © 2026 <a class="site-footer__link" href="https://graymatter.ch" target="_blank" rel="noopener noreferrer">Gray Matter GmbH</a>
      </p>
    </footer>

    {/* Scramble effect lives in /scramble.js so the site's CSP
        (`script-src 'self'`) allows it. Inline scripts are blocked;
        bundled modules work too but this keeps the payload out of
        Astro's build graph for a zero-failure-surface static asset. */}
    <script is:inline src="/scramble.js" defer></script>

    {/* Best-effort browser-tz auto-correct for every authenticated
        page, not just /settings. When the server-stored tz differs
        from the browser's Intl-resolved tz, POST the correction so
        the daily-email dispatcher picks it up on the next /5 cron.
        This is the fix for users who signed up, landed on /digest,
        never visited /settings, and received their digest at 08:00
        UTC instead of 08:00 local. CSP allows inline modules; we
        ship a bundled module instead of an inline script to stay
        under the 'script-src: self' policy. */}
    <script>
      async function syncBrowserTz(): Promise<void> {
        const body = document.body;
        const stored = body.dataset['userTz'] ?? '';
        if (stored === '') return;
        let browser = '';
        try {
          browser = Intl.DateTimeFormat().resolvedOptions().timeZone ?? '';
        } catch { return; }
        if (browser === '' || browser === stored) return;
        try {
          const res = await fetch('/api/auth/set-tz', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify({ tz: browser }),
          });
          if (res.ok) {
            body.dataset['userTz'] = browser;
          }
        } catch {
          // Network hiccup — next page load will retry.
        }
      }
      if (document.documentElement.dataset['tzAutoBound'] !== '1') {
        document.documentElement.dataset['tzAutoBound'] = '1';
        void syncBrowserTz();
        document.addEventListener('astro:page-load', () => { void syncBrowserTz(); });
      }
    </script>

    {/* Per-path scroll save/restore across navigations. Astro's
        ClientRouter default is scroll-to-top on every transition
        which breaks the natural "back from article detail returns
        you to where you were scrolling on /digest" behaviour. We
        save on before-swap and restore on page-load (deferred one
        frame so any filter-hydration DOM work has settled first).
        sessionStorage is keyed by pathname so forward navs to a
        page the user hasn't visited yet scroll to 0 cleanly. */}
    <script>
      // Track the path of the page whose scroll position we are
      // currently managing in a module-scoped variable, NOT in
      // `window.location.pathname`. Astro's ClientRouter calls
      // history.pushState BEFORE firing `astro:before-swap`, so by
      // the time saveScroll runs, `window.location.pathname` has
      // already flipped to the destination URL — we were saving
      // /digest's scroll under the detail page's key, and on return
      // reading `scroll:/digest` found nothing. currentPath is
      // updated only when restoreScroll completes so saveScroll
      // always writes under the page the user is leaving.
      let currentPath = window.location.pathname;
      const KEY = (): string => `scroll:${currentPath}`;
      function saveScroll(): void {
        try {
          sessionStorage.setItem(KEY(), String(window.scrollY));
        } catch { /* storage quota / disabled — nothing to do */ }
      }
      // Retry-based restore: the naive "single rAF after page-load"
      // race-loses against two mobile problems:
      //   (a) image-heavy pages whose layout height isn't established
      //       until lazy images have decoded — scrollTo(0, 1200) on a
      //       page that's only 600px tall clamps to 600 and the real
      //       target is lost forever;
      //   (b) pages that shrink AFTER the initial restore when the
      //       tag-strip filter's `applyFilter()` sets
      //       `display:none` on non-matching cards, collapsing the
      //       grid's height — the browser silently clamps scrollY and
      //       a simple "stop on first match" tick loop terminates
      //       before the collapse happens.
      // We tick every frame for 3 seconds AND observe document
      // height changes via ResizeObserver, re-asserting scrollTo on
      // every mutation. Stop on user wheel/touchmove so we never
      // jump under their finger.
      function restoreScroll(): void {
        // Advance currentPath to the page we're now on. Any future
        // saveScroll calls before the next navigation will correctly
        // key against this page, not the next destination.
        currentPath = window.location.pathname;
        try {
          const raw = sessionStorage.getItem(KEY());
          if (raw === null) return;
          const target = Number.parseInt(raw, 10);
          if (!Number.isFinite(target) || target < 0) return;
          if (target === 0) return;
          const started = performance.now();
          const DURATION_MS = 3000;
          let cancelled = false;
          let ro: ResizeObserver | null = null;
          const teardown = (): void => {
            cancelled = true;
            if (ro !== null) { ro.disconnect(); ro = null; }
          };
          window.addEventListener('wheel', teardown, { once: true, passive: true });
          window.addEventListener('touchmove', teardown, { once: true, passive: true });
          // ResizeObserver catches the dashboard's tag-filter layout
          // shrink as well as lazy-image layout growth — any time the
          // document height changes while we're in the restore window,
          // re-assert the target so the clamp can't strand us.
          if (typeof ResizeObserver !== 'undefined') {
            ro = new ResizeObserver(() => {
              if (cancelled) return;
              window.scrollTo(0, target);
            });
            ro.observe(document.documentElement);
          }
          const tick = (): void => {
            if (cancelled) return;
            window.scrollTo(0, target);
            if (performance.now() - started > DURATION_MS) {
              teardown();
              return;
            }
            requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
        } catch { /* ditto */ }
      }
      if (document.documentElement.dataset['scrollRestoreBound'] !== '1') {
        document.documentElement.dataset['scrollRestoreBound'] = '1';
        // Override Astro ClientRouter's scroll-to-top so our per-path
        // sessionStorage restore wins.
        if ('scrollRestoration' in window.history) {
          window.history.scrollRestoration = 'manual';
        }
        document.addEventListener('astro:before-swap', saveScroll);
        window.addEventListener('pagehide', saveScroll);
        document.addEventListener('astro:page-load', restoreScroll);
        // bfcache restore on iOS Safari: `astro:page-load` does NOT
        // fire when the browser back-navigates from an external link
        // and the page is served from bfcache. `pageshow` with
        // `persisted === true` is the signal for that path — without
        // it, Safari sees `scrollRestoration = 'manual'` and leaves
        // the scroll at 0. restoreScroll is idempotent and safe to
        // run again; it will read the saved scrollY and tick.
        window.addEventListener('pageshow', (e) => {
          if (e.persisted) restoreScroll();
        });
        restoreScroll();
      }
    </script>

    <style>
      /* Sticky header with a tasteful backdrop blur on scroll — no solid
         rule across the page. The horizontal line is implied by a tight
         wordmark on the left and the icon trio on the right. */
      .site-header {
        position: sticky;
        top: 0;
        z-index: 30;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 14px 20px;
        background-color: color-mix(in oklab, var(--bg) 88%, transparent);
        backdrop-filter: saturate(160%) blur(12px);
        -webkit-backdrop-filter: saturate(160%) blur(12px);
      }

      .site-header__brand {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        min-height: 44px;
        color: var(--text);
        text-decoration: none;
      }

      /* Logomark: the MDI newspaper-variant-outline icon. Same glyph
         used for favicon so the browser tab and the in-app brand stay
         consistent. Inherits var(--text) via currentColor. */
      .site-header__mark {
        display: inline-block;
        color: var(--text);
        flex-shrink: 0;
      }

      /* Wordmark doubles as the page H1 — 'Today's digest' was
         removed from /digest in favour of the brand carrying the
         visual weight of a page header. 2xl on desktop bumps to
         3xl so it reads as a header, not chrome. Mobile stays at
         2xl to keep the 44px sticky-header row comfortable. */
      .site-header__wordmark {
        display: inline-flex;
        align-items: baseline;
        font-size: var(--text-2xl);
        font-weight: 700;
        letter-spacing: -0.025em;
        line-height: 1;
      }
      @media (min-width: 768px) {
        .site-header__wordmark {
          /* No text-3xl token in the design system; inline the
             desktop bump so we don't fork the scale. 40px reads as
             a page header at desktop widths while staying below an
             H1 (48px+) so the brand still feels like navigation. */
          font-size: 40px;
        }
      }
      /* "news" in muted, "digest" in full text — kerned together without
         whitespace. Gives the brand character without adding chrome. */
      .site-header__word--one {
        color: var(--text-muted);
      }
      .site-header__word--two {
        color: var(--text);
      }

      .site-header__nav {
        display: inline-flex;
        align-items: center;
        gap: 4px;
      }

      .site-main {
        padding: 16px;
        flex: 1 1 auto;
        min-width: 0;
      }

      /* Quiet site-wide footer. Same padding as .site-main so it
         aligns with the reading column edges; muted text + a subtle
         top border so it reads as chrome, not content. */
      .site-footer {
        padding: 1.5rem 16px 2rem;
        color: var(--text-muted);
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        text-align: center;
        margin-top: 2rem;
      }
      .site-footer__copy {
        margin: 0;
      }
      /* Scramble target uses a ghost/live pair so the scrambling
         never perturbs the surrounding footer layout:
           - .ghost renders the target word ("Codeflare") in the
             footer's natural (proportional) font and is the ONLY
             element that occupies layout width.
           - .live sits absolute on top of .ghost with visibility,
             takes up zero layout space, and receives the scramble
             text via textContent from /scramble.js.
         The live layer uses a monospace stack so the moving chars
         each occupy a uniform horizontal slot and don't shift
         within the fixed ghost width. Color is explicitly inherited
         from the parent <a class="site-footer__link"> so the
         monospace "Codeflare" reads in the same muted tone as the
         rest of the footer copy. */
      .site-footer__scramble {
        position: relative;
        display: inline-block;
        vertical-align: baseline;
      }
      .site-footer__scramble-ghost {
        /* Invisible but lays out — this is what reserves "Codeflare"'s
           width in the footer's natural font so '·' and '©' never
           shift regardless of what the scrambler paints. */
        visibility: hidden;
      }
      .site-footer__scramble-live {
        position: absolute;
        inset: 0;
        display: inline-block;
        font-family:
          ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        /* Lock the color to the surrounding .site-footer__link (which
           is already var(--text-muted) — same tone as "Built with
           … © 2026 Gray Matter GmbH"). Prevents any browser default
           link-color bleeding into the live layer. */
        color: inherit;
        text-align: left;
        white-space: pre;
        overflow: hidden;
        pointer-events: none;
      }
      .site-footer__link {
        color: var(--text-muted);
        text-decoration: none;
        border-bottom: 1px solid transparent;
      }
      .site-footer__link:hover {
        color: var(--text);
        border-bottom-color: var(--text);
      }
    </style>

    <style is:global>
      /* Fill the viewport so the background colour (var(--bg)) covers the
         whole screen rather than collapsing to the content height. Without
         this, short pages like onboarding can leave white or black bands
         below the footer on mobile. */
      html,
      body {
        min-height: 100svh;
      }
      body {
        display: flex;
        flex-direction: column;
      }
    </style>
  </body>
</html>
