---
// Implements REQ-SET-001, REQ-SET-002, REQ-SET-003, REQ-SET-004, REQ-SET-005, REQ-SET-006, REQ-SET-007
//
// Unified onboarding + edit form. The `first_run` query param swaps the
// hero copy and the primary CTA label; the form fields are identical in
// both modes. A fully-configured user visiting `/settings?first_run=1`
// is redirected to `/settings` by the settings-gate middleware helper.
//
// All validation is repeated server-side in /api/settings — client-side
// form state is convenience only.

import type { APIContext } from 'astro';
import Base from '~/layouts/Base.astro';
import ModelSelect from '~/components/ModelSelect.astro';
import InstallPrompt from '~/components/InstallPrompt.astro';
import StatsWidget from '~/components/StatsWidget.astro';
import { loadSession } from '~/middleware/auth';
import { requireSettingsComplete } from '~/middleware/settings-gate';
import { DEFAULT_TZ } from '~/lib/tz';
import { DEFAULT_MODEL_ID } from '~/lib/models';
import { RESTORE_DEFAULTS_LABEL } from '~/lib/default-hashtags';


const env = Astro.locals.runtime.env;
if (typeof env.OAUTH_JWT_SECRET !== 'string' || env.OAUTH_JWT_SECRET === '') {
  return new Response('Application not configured', { status: 500 });
}

// Load the authenticated user into locals — the settings-gate helper
// reads from `Astro.locals.user`.
const session = await loadSession(
  Astro.request,
  env.DB,
  env.OAUTH_JWT_SECRET,
);
if (session === null) {
  return Astro.redirect('/api/auth/github/login', 303);
}
Astro.locals.user = session.user;

// Enforce the settings-incomplete / already-complete redirect rules.
// The helper only reads `request` and `locals`; cast to `APIContext`
// for the remainder of the surface it does not touch.
const gated = requireSettingsComplete({
  request: Astro.request,
  locals: Astro.locals,
} as unknown as APIContext);
if (gated !== null) {
  return gated;
}

const user = session.user;

const url = new URL(Astro.request.url);
const isFirstRun =
  url.searchParams.get('first_run') === '1' && user.digest_hour === null;

const digestHour = user.digest_hour ?? 8;
const digestMinute = user.digest_minute;
const timeValue = `${String(digestHour).padStart(2, '0')}:${String(digestMinute).padStart(2, '0')}`;
const tzValue = user.tz === '' ? DEFAULT_TZ : user.tz;
const currentModelId = user.model_id ?? DEFAULT_MODEL_ID;
const emailEnabled = user.email_enabled === 1;

const heroTitle = isFirstRun
  ? 'Welcome — pick a time, we handle the rest'
  : 'Settings';
const heroBody = isFirstRun
  ? 'Choose when your daily digest should arrive and which model powers the summaries. You can add interests once the digest is live.'
  : 'Tune your schedule, summary model, and email delivery.';
const primaryCta = isFirstRun ? 'Save and continue' : 'Save';
---

<Base title={isFirstRun ? 'Welcome to News Digest' : 'Settings'} firstRun={isFirstRun}>
  <section class="settings" data-settings data-first-run={isFirstRun ? '1' : '0'}>
    <header class="settings__hero">
      <h1 class="settings__title">{heroTitle}</h1>
      <p class="settings__subtitle">{heroBody}</p>
    </header>

    {!isFirstRun && <StatsWidget />}

    <form class="settings__form" data-settings-form>
      {/* Interests moved to the top of /digest — the tag strip there is
          the sole editor for the user's hashtags. Settings controls
          schedule, model, and delivery only. */}
      <fieldset class="settings__section">
        <legend class="settings__legend">Schedule</legend>
        <label class="settings__field">
          <span class="settings__field-label">Daily digest time</span>
          <input
            type="time"
            name="time"
            data-time-input
            value={timeValue}
            required
            class="settings__time-input"
          />
        </label>
        <div class="settings__tz" data-tz-block>
          <span class="settings__field-label">Timezone</span>
          <output class="settings__tz-current" data-tz-display>{tzValue}</output>
          <span class="settings__tz-hint">auto-detected from your browser</span>
        </div>
      </fieldset>

      <fieldset class="settings__section">
        <legend class="settings__legend">Interests</legend>
        <p class="settings__hint">
          Tags live at the top of the digest page — click to select/filter, click
          the × to delete. You can revert to the curated starter list at any time.
        </p>
        <div class="settings__actions-row">
          {/*
            Native <form> POST to /api/tags/restore — the endpoint
            writes DEFAULT_HASHTAGS server-side and 303-redirects to
            /digest, so the button works with zero JavaScript. The
            light progressive enhancement below only updates the
            inline "Restoring…" status during the POST round-trip.
          */}
          <form
            method="post"
            action="/api/tags/restore"
            class="settings__restore-form"
            data-restore-form
          >
            <button
              type="submit"
              class="settings__secondary-button"
              data-restore-tags
            >
              {RESTORE_DEFAULTS_LABEL}
            </button>
          </form>
          <p class="settings__status" data-restore-status aria-live="polite"></p>
        </div>
      </fieldset>

      <fieldset class="settings__section">
        <legend class="settings__legend">Inference and Notification</legend>
        <label class="settings__field">
          <span class="settings__field-label">Model</span>
          <ModelSelect selected={currentModelId} />
        </label>
        <label class="settings__toggle">
          <input
            type="checkbox"
            class="settings__email-checkbox"
            data-email-toggle
            checked={emailEnabled}
          />
          <span>Email me when my daily digest is ready</span>
        </label>
      </fieldset>

      <div class="settings__actions">
        <button type="submit" class="settings__submit" data-settings-submit>
          {primaryCta}
        </button>
        <p class="settings__status" data-settings-status aria-live="polite"></p>
      </div>
    </form>

    {
      !isFirstRun && (
        <section class="settings__secondary">
          <InstallPrompt />
          <aside class="settings__gravatar" aria-label="Profile picture tip">
            <span class="settings__gravatar-icon" aria-hidden="true">
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                {/* MDI account — https://pictogrammers.com/library/mdi/icon/account/ */}
                <path d="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z" />
              </svg>
            </span>
            <div class="settings__gravatar-body">
              <p class="settings__gravatar-title">Customise your profile picture</p>
              <p class="settings__gravatar-text">
                Your avatar comes from{' '}
                <a
                  class="settings__gravatar-link"
                  href="https://gravatar.com/"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Gravatar
                </a>
                , a free service that links a photo to your email address. Sign up there with the email on your account, upload a photo, and it appears here next time you load the app.
              </p>
            </div>
          </aside>
          <form
            class="settings__delete"
            data-delete-account
            aria-label="Delete account"
          >
            <h2 class="settings__danger-title">Delete account</h2>
            <p class="settings__danger-hint">
              Permanently deletes your account, digests, and all associated data.
            </p>
            <label class="settings__field">
              <span class="settings__field-label">Type DELETE to confirm</span>
              <input
                type="text"
                data-delete-confirm
                autocomplete="off"
                class="settings__delete-input"
              />
            </label>
            <button type="submit" class="settings__delete-button">
              Delete my account
            </button>
          </form>
        </section>
      )
    }
  </section>
</Base>

<script>
  // Implements REQ-SET-001, REQ-SET-002, REQ-SET-003, REQ-SET-004, REQ-SET-005, REQ-SET-007
  //
  // Client-side controller for /settings. Framework-free — collects
  // form state from DOM data attributes and POSTs JSON to /api/settings.

  interface SettingsResponse {
    ok?: boolean;
    discovering?: string[];
    error?: string;
    code?: string;
  }

  async function submitSettings(
    form: HTMLFormElement,
    status: HTMLElement,
    submitButton: HTMLButtonElement,
  ): Promise<void> {
    const timeInput = form.querySelector('[data-time-input]') as HTMLInputElement | null;
    const tzDisplay = form.querySelector('[data-tz-display]') as HTMLElement | null;
    const emailToggle = form.querySelector('[data-email-toggle]') as HTMLInputElement | null;
    const modelSelect = form.querySelector('select[name="model_id"]') as HTMLSelectElement | null;

    const timeValue = timeInput?.value ?? '';
    const [hourStr, minuteStr] = timeValue.split(':');
    const digestHour = Number.parseInt(hourStr ?? '', 10);
    const digestMinute = Number.parseInt(minuteStr ?? '', 10);
    // TZ is auto-detected (see detectAndPersistTz on page load). Fall
    // back to the displayed value if detection hasn't updated it yet.
    const tz =
      typeof Intl !== 'undefined' &&
      typeof Intl.DateTimeFormat === 'function'
        ? Intl.DateTimeFormat().resolvedOptions().timeZone
        : (tzDisplay?.textContent?.trim() ?? '');
    const modelId = modelSelect?.value ?? '';
    const emailEnabled = emailToggle?.checked === true;

    // Hashtags are edited on the /digest tag strip via POST /api/tags;
    // this endpoint no longer accepts a `hashtags` field.
    const payload = {
      digest_hour: digestHour,
      digest_minute: digestMinute,
      tz,
      model_id: modelId,
      email_enabled: emailEnabled,
    };

    submitButton.disabled = true;
    status.textContent = 'Saving…';
    let res: Response;
    try {
      res = await fetch('/api/settings', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
        credentials: 'same-origin',
      });
    } catch {
      status.textContent = 'Network error. Please try again.';
      submitButton.disabled = false;
      return;
    }

    let body: SettingsResponse = {};
    try {
      body = (await res.json()) as SettingsResponse;
    } catch {
      /* keep body as {} */
    }

    if (!res.ok || body.ok !== true) {
      status.textContent =
        body.error ?? 'Could not save your settings. Please try again.';
      submitButton.disabled = false;
      return;
    }

    const wasFirstRun =
      document
        .querySelector<HTMLElement>('[data-settings]')
        ?.dataset['firstRun'] === '1';

    if (wasFirstRun) {
      // Kick off the user's first digest automatically so they see a
      // live "generating…" card as soon as they land on /digest. If the
      // request fails (e.g., rate-limit, no tags yet), the server still
      // picks it up on the normal schedule — not worth blocking the
      // redirect on it.
      try {
        await fetch('/api/digest/refresh', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
        });
      } catch {
        /* best-effort */
      }
      window.location.assign('/digest');
      return;
    }

    status.textContent = 'Saved';
    submitButton.disabled = false;
  }

  async function deleteAccount(
    form: HTMLFormElement,
    status: HTMLElement,
  ): Promise<void> {
    const input = form.querySelector<HTMLInputElement>('[data-delete-confirm]');
    const confirm = input?.value.trim() ?? '';
    if (confirm !== 'DELETE') {
      status.textContent = 'Type DELETE exactly to confirm.';
      return;
    }
    status.textContent = 'Deleting…';
    const res = await fetch('/api/auth/account', {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ confirm: 'DELETE' }),
      credentials: 'same-origin',
    });
    if (res.ok) {
      const body = (await res.json()) as { redirect?: string };
      window.location.assign(body.redirect ?? '/');
      return;
    }
    status.textContent = 'Could not delete your account. Please try again.';
  }

  function init(): void {
    const form = document.querySelector<HTMLFormElement>('[data-settings-form]');
    if (form === null) return;
    if (form.dataset['bound'] === '1') return;
    form.dataset['bound'] = '1';

    const status = form.querySelector<HTMLElement>('[data-settings-status]');
    const submit = form.querySelector<HTMLButtonElement>('[data-settings-submit]');
    const tzDisplay = form.querySelector('[data-tz-display]') as HTMLElement | null;

    // Auto-detect the browser's timezone and sync it to the server when
    // it differs from the stored value. Updates the display without a
    // page reload. Best-effort — any network or validation failure is
    // swallowed so it doesn't block the form.
    if (tzDisplay !== null) {
      try {
        const browserTz = Intl.DateTimeFormat().resolvedOptions().timeZone;
        const storedTz = tzDisplay.textContent?.trim() ?? '';
        if (browserTz !== '' && browserTz !== storedTz) {
          tzDisplay.textContent = browserTz;
          fetch('/api/auth/set-tz', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ tz: browserTz }),
            credentials: 'same-origin',
          }).catch(() => {});
        }
      } catch {
        /* Intl unavailable — leave the stored tz in place. */
      }
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      if (status === null || submit === null) return;
      void submitSettings(form, status, submit);
    });

    // Restore initial tags: the <form> submits natively — the server
    // writes DEFAULT_HASHTAGS and 303-redirects to /digest. JS here is
    // a cosmetic layer that paints "Restoring…" while the browser
    // waits for the redirect. If the script never runs, the button
    // still works.
    const restoreForm = document.querySelector<HTMLFormElement>('[data-restore-form]');
    const restoreStatus = document.querySelector<HTMLElement>('[data-restore-status]');
    if (restoreForm !== null && restoreForm.dataset['bound'] !== '1') {
      restoreForm.dataset['bound'] = '1';
      restoreForm.addEventListener('submit', () => {
        const button = restoreForm.querySelector<HTMLButtonElement>('[data-restore-tags]');
        if (button !== null) button.disabled = true;
        if (restoreStatus !== null) restoreStatus.textContent = 'Restoring…';
        // Fall through to native POST — browser follows the 303.
      });
    }

    // Delete account form.
    const deleteForm = document.querySelector<HTMLFormElement>('[data-delete-account]');
    if (deleteForm !== null && deleteForm.dataset['bound'] !== '1') {
      deleteForm.dataset['bound'] = '1';
      deleteForm.addEventListener('submit', (e) => {
        e.preventDefault();
        const deleteStatus = document.createElement('p');
        deleteStatus.setAttribute('aria-live', 'polite');
        deleteForm.appendChild(deleteStatus);
        void deleteAccount(deleteForm, deleteStatus);
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init, { once: true });
  } else {
    init();
  }
  document.addEventListener('astro:page-load', init);
</script>

<style>
  .settings {
    max-width: 680px;
    margin: 0 auto;
    padding: 1.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .settings__hero {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .settings__title {
    margin: 0;
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--text);
  }

  .settings__subtitle {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-base);
    line-height: 1.5;
  }

  .settings__form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .settings__section {
    margin: 0;
    padding: 1rem 1.25rem;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    background-color: var(--surface);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .settings__legend {
    padding: 0;
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--text);
  }

  .settings__hint {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-sm);
  }

  .settings__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .settings__custom {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .settings__custom-label {
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .settings__custom-row {
    display: flex;
    gap: 0.5rem;
  }

  .settings__custom-input {
    flex: 1 1 auto;
    min-height: 44px;
    padding: 0.5rem 0.75rem;
    background-color: var(--bg);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 0.375rem;
  }

  .settings__custom-add {
    min-width: 44px;
    min-height: 44px;
    padding: 0.5rem 1rem;
    background-color: var(--bg);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 0.375rem;
    font-weight: 600;
    cursor: pointer;
  }

  .settings__field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .settings__field-label {
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .settings__time-input {
    min-height: 44px;
    padding: 0.5rem 0.75rem;
    background-color: var(--bg);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 0.375rem;
    width: max-content;
  }

  .settings__tz {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .settings__tz-current {
    font-weight: 600;
    color: var(--text);
  }

  .settings__tz-hint {
    color: var(--text-muted);
    font-size: var(--text-sm);
  }

  .settings__advanced-body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-top: 0.75rem;
  }

  .settings__toggle {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text);
  }

  .settings__toggle input {
    min-width: 20px;
    min-height: 20px;
  }

  /* Colour the email checkbox so the check glyph matches the primary
     button fill — black on light theme, white on dark — instead of the
     browser default blue. `accent-color` is the least-invasive way to
     recolour a native checkbox. */
  .settings__email-checkbox {
    accent-color: var(--text);
    width: 20px;
    height: 20px;
  }

  .settings__actions {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .settings__submit {
    min-height: 44px;
    padding: 0.75rem 1.25rem;
    background-color: var(--text);
    color: var(--bg);
    border: none;
    border-radius: 0.375rem;
    font-size: var(--text-base);
    font-weight: 600;
    cursor: pointer;
  }

  .settings__actions-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
  }

  .settings__secondary-button {
    min-height: 44px;
    padding: 0.5rem 1.25rem;
    /* Primary-button contrast: inverted of the current theme so it
       reads black-on-light / white-on-dark, matching the Save button. */
    background-color: var(--text);
    color: var(--bg);
    border: 1px solid var(--text);
    border-radius: 0.375rem;
    font-size: var(--text-sm);
    font-weight: 600;
    cursor: pointer;
  }
  .settings__secondary-button:hover {
    opacity: 0.9;
  }
  .settings__secondary-button:disabled {
    opacity: 0.6;
    cursor: wait;
  }

  .settings__submit:disabled {
    opacity: 0.6;
    cursor: wait;
  }

  .settings__status {
    margin: 0;
    min-height: 1.25rem;
    color: var(--text-muted);
    font-size: var(--text-sm);
  }

  .settings__secondary {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }

  .settings__gravatar {
    display: flex;
    gap: 0.875rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    background-color: var(--surface);
  }

  .settings__gravatar-icon {
    display: inline-flex;
    align-items: flex-start;
    color: var(--text-muted);
    flex-shrink: 0;
    padding-top: 0.1rem;
  }

  .settings__gravatar-body {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .settings__gravatar-title {
    margin: 0;
    font-weight: 600;
    color: var(--text);
    font-size: var(--text-base);
  }

  .settings__gravatar-text {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-sm);
    line-height: 1.5;
  }

  .settings__gravatar-link {
    color: var(--text);
    text-decoration: underline;
  }

  .settings__delete {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    background-color: var(--surface);
  }

  .settings__danger-title {
    margin: 0;
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--text);
  }

  .settings__danger-hint {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-sm);
  }

  .settings__delete-input {
    min-height: 44px;
    padding: 0.5rem 0.75rem;
    background-color: var(--bg);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 0.375rem;
  }

  .settings__delete-button {
    min-height: 44px;
    padding: 0.75rem 1.25rem;
    background-color: #b91c1c;
    color: #fafafa;
    border: 1px solid #b91c1c;
    border-radius: 0.375rem;
    font-weight: 600;
    cursor: pointer;
  }
  .settings__delete-button:hover {
    background-color: #991b1b;
    border-color: #991b1b;
  }
</style>
