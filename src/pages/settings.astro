  }

  .settings__logout {
    margin: 0;
  }

  .settings__logout-button {
    min-height: 44px;
    padding: 0.5rem 1rem;
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 0.375rem;
    font-size: var(--text-base);
    font-weight: 400;
