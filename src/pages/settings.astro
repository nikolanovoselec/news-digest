---
// Implements REQ-SET-001, REQ-SET-002, REQ-SET-003, REQ-SET-004, REQ-SET-005, REQ-SET-006, REQ-SET-007, REQ-DISC-004
//
// Unified onboarding + edit form. The `first_run` query param swaps the
// hero copy and the primary CTA label; the form fields are identical in
// both modes. A fully-configured user visiting `/settings?first_run=1`
// is redirected to `/settings` by the settings-gate middleware helper.
//
// All validation is repeated server-side in /api/settings — client-side
// form state is convenience only.

import type { APIContext } from 'astro';
import Base from '~/layouts/Base.astro';
import ModelSelect from '~/components/ModelSelect.astro';
import InstallPrompt from '~/components/InstallPrompt.astro';
import StatsWidget from '~/components/StatsWidget.astro';
import { loadSession } from '~/middleware/auth';
import { requireSettingsComplete } from '~/middleware/settings-gate';
import { DEFAULT_TZ } from '~/lib/tz';
import { DEFAULT_MODEL_ID } from '~/lib/models';
import {
  DEFAULT_HASHTAGS,
  DELETE_ALL_TAGS_LABEL,
  RESTORE_DEFAULTS_LABEL,
} from '~/lib/default-hashtags';
import { CURATED_SOURCES } from '~/lib/curated-sources';


const env = Astro.locals.runtime.env;
if (typeof env.OAUTH_JWT_SECRET !== 'string' || env.OAUTH_JWT_SECRET === '') {
  return new Response('Application not configured', { status: 500 });
}

// Load the authenticated user into locals — the settings-gate helper
// reads from `Astro.locals.user`.
const session = await loadSession(
  Astro.request,
  env.DB,
  env.OAUTH_JWT_SECRET,
);
if (session === null) {
  return Astro.redirect('/', 303);
}
Astro.locals.user = session.user;

// Enforce the settings-incomplete / already-complete redirect rules.
// The helper only reads `request` and `locals`; cast to `APIContext`
// for the remainder of the surface it does not touch.
const gated = requireSettingsComplete({
  request: Astro.request,
  locals: Astro.locals,
} as unknown as APIContext);
if (gated !== null) {
  return gated;
}

const user = session.user;

const url = new URL(Astro.request.url);
const isFirstRun =
  url.searchParams.get('first_run') === '1' && user.digest_hour === null;

const digestHour = user.digest_hour ?? 8;
const digestMinute = user.digest_minute;
const timeValue = `${String(digestHour).padStart(2, '0')}:${String(digestMinute).padStart(2, '0')}`;
const tzValue = user.tz === '' ? DEFAULT_TZ : user.tz;

// REQ-SET-007 AC 5 — manual tz picker. Render the full IANA inventory
// server-side so the picker is complete before client JS runs. The
// runtime exposes the list via Intl.supportedValuesOf('timeZone').
//
// CRITICAL — `Intl.supportedValuesOf('timeZone')` returns ONLY the
// canonical IANA zones; it does NOT include `'UTC'` or any of the
// `'Etc/*'` aliases (V8/Workers behavior). Our DEFAULT_TZ is `'UTC'`,
// so a fresh user with `users.tz = 'UTC'` finds NO `<option>` matching
// `selected={zone === 'UTC'}` — the browser silently falls back to the
// alphabetically-first option (`'Africa/Abidjan'`), and any subsequent
// form submit POSTs that wrong value back to /api/settings, poisoning
// the user record. Guard by prepending `tzValue` whenever it isn't in
// the canonical list, so the dropdown always has a real selected entry.
type IntlWithSupported = typeof Intl & {
  supportedValuesOf?: (key: string) => string[];
};
const intlWithSupported = Intl as IntlWithSupported;
const canonicalTzList: string[] =
  typeof intlWithSupported.supportedValuesOf === 'function'
    ? intlWithSupported.supportedValuesOf('timeZone')
    : [];
// Merge tzValue into the canonical list (when missing) and re-sort so the
// stored value lands in its alphabetical slot rather than pinned to the
// top. Without the sort, 'UTC' would sit above 'Africa/*' on every page
// load until the user picks a real zone.
const tzOptions: string[] = canonicalTzList.includes(tzValue)
  ? canonicalTzList
  : [tzValue, ...canonicalTzList].sort((a, b) => a.localeCompare(b));
const currentModelId = user.model_id ?? DEFAULT_MODEL_ID;
const emailEnabled = user.email_enabled === 1;

// REQ-SET-004 — ModelSelect is hidden while the global pipeline runs on
// a single default model. The stored `model_id` preference is still
// persisted by /api/settings (see the PUT handler there) so flipping
// `showModelSelect` back to `true` is a one-line re-enable without a
// schema change. `currentModelId` is preserved above for the same reason.
const showModelSelect = false;

// Parse the user's current hashtag list so we can compute which of
// the Restore / Delete buttons to surface. Corrupt JSON or a
// non-array payload is treated as an empty list so the form still
// renders. REQ-SET-002 AC 8.
let userHashtags: string[] = [];
if (typeof user.hashtags_json === 'string' && user.hashtags_json !== '') {
  try {
    const parsed = JSON.parse(user.hashtags_json) as unknown;
    if (Array.isArray(parsed)) {
      // Normalise on read so legacy rows that were stored before the
      // write-path normalisation landed (mixed case, leading `#`,
      // stray whitespace) still match DEFAULT_HASHTAGS set-membership
      // comparisons below. Without this, showDelete stayed false for
      // an account seeded with `['#ai', 'AI', ...]` because
      // userHashtagSet.has('ai') returned false on case mismatch.
      userHashtags = parsed
        .filter((v): v is string => typeof v === 'string')
        .map((t) => t.trim().toLowerCase().replace(/^#/, ''))
        .filter((t) => t !== '');
    }
  } catch {
    userHashtags = [];
  }
}
const userHashtagSet = new Set<string>(userHashtags);
// Restore is shown when at least one default tag is missing — the
// button would actually add something.
const showRestoreButton = DEFAULT_HASHTAGS.some((t) => !userHashtagSet.has(t));
// Delete is shown whenever the user has at least one tag — the
// button clears the whole list so the user can start over with a
// completely custom set. Hides only when the list is already empty,
// because clearing nothing is a no-op.
const showDeleteAllButton = userHashtags.length > 0;

// REQ-DISC-004 — identify user tags that have no working source so the
// "Discover missing sources" button can re-trigger discovery. A tag is
// stuck when:
//   - it has no entry in the curated registry (CURATED_SOURCES) AND
//   - either its `sources:{tag}` KV entry is missing, unparseable, or
//     resolves to a feeds array of length 0
//
// Tags that DO have a curated source are never stuck — even if discovery
// hasn't run for them yet, the curated feeds keep the dashboard fed.
//
// Pre-2026-04-25 behaviour: a missing KV entry was treated as "discovery
// still pending" and the tag stayed hidden, so a manually-added tag with
// no curated source AND no successful discovery never surfaced — the
// user had no way to trigger re-discovery for it.
//
// KV reads run in parallel; transient KV failures fall back to "not
// stuck" so a flaky read never lights up every tag at once.
const curatedTagSet = new Set<string>();
for (const src of CURATED_SOURCES) {
  for (const tag of src.tags) curatedTagSet.add(tag);
}
const emptyFeedTags: string[] = [];
if (userHashtags.length > 0) {
  const results = await Promise.all(
    userHashtags.map(async (tag) => {
      // Tags with curated sources always have feeds; never flag stuck.
      if (curatedTagSet.has(tag)) return null;
      try {
        const raw = await env.KV.get(`sources:${tag}`);
        // No KV entry: stuck (discovery never wrote anything for this
        // tag, and there's no curated fallback). The user needs to
        // trigger discovery to populate the cache.
        if (raw === null) return tag;
        let parsed: unknown;
        try {
          parsed = JSON.parse(raw);
        } catch {
          return tag; // unparseable — treat as stuck
        }
        if (parsed === null || typeof parsed !== 'object') return tag;
        const feeds = (parsed as { feeds?: unknown }).feeds;
        if (!Array.isArray(feeds) || feeds.length === 0) return tag;
        return null;
      } catch {
        return null; // transient KV blip — don't false-flag
      }
    }),
  );
  for (const tag of results) {
    if (typeof tag === 'string' && tag !== '') emptyFeedTags.push(tag);
  }
}

// Optional confirmation banner shown after a form-POST returns 303
// back to /settings?rediscover=ok&count=N. Purely cosmetic; the heavy
// lift happened in the POST handler.
const rediscoverConfirmedCount =
  url.searchParams.get('rediscover') === 'ok'
    ? Number.parseInt(url.searchParams.get('count') ?? '', 10)
    : null;
const rediscoverConfirmed =
  rediscoverConfirmedCount !== null && Number.isFinite(rediscoverConfirmedCount);

const heroTitle = isFirstRun
  ? 'Welcome — pick a time, we handle the rest'
  : 'Settings';
const heroBody = isFirstRun
  ? 'Choose when your daily digest should arrive and which model powers the summaries. You can add interests once the digest is live.'
  : 'Tune your schedule, summary model, and email delivery.';
const primaryCta = isFirstRun ? 'Save and continue' : 'Save';
---

<Base title={isFirstRun ? 'Welcome to News Digest' : 'Settings'} firstRun={isFirstRun}>
  <section class="settings" data-settings data-first-run={isFirstRun ? '1' : '0'}>
    <header class="settings__hero">
      <h1 class="settings__title">{heroTitle}</h1>
      <p class="settings__subtitle">{heroBody}</p>
    </header>

    {!isFirstRun && (
      <div class="settings__sponsor" aria-label="Project sponsor">
        <img
          src="/swiss-post.svg"
          alt="Swiss Post"
          class="settings__sponsor-logo"
          width="84"
          height="84"
        />
        <span class="settings__sponsor-caption">
          Powered by Security Architecture @ Swiss Post
        </span>
      </div>
    )}

    {!isFirstRun && <StatsWidget />}

    {/* Native form-POST fallback (REQ-AUTH-003 compatible). When the
        JS submit handler binds via init(), it `e.preventDefault()`s and
        sends the JSON PUT below. When the JS hasn't loaded yet (CSP
        block, mobile webview quirks, race against ClientRouter swap),
        the browser's native submit hits this same endpoint as a
        form-encoded POST and the server returns a 303 back here.
        Without this, no `method` attribute defaults to GET and the
        form silently navigates with values as query params — losing
        every save. */}
    <form
      class="settings__form"
      data-settings-form
      method="post"
      action="/api/settings"
    >
      {/* Interests moved to the top of /digest — the tag strip there is
          the sole editor for the user's hashtags. Settings controls
          schedule, model, and delivery only. */}
      <fieldset class="settings__section">
        <legend class="settings__legend">Notifications</legend>
        <label class="settings__field">
          <span class="settings__field-label">Daily digest time</span>
          <input
            type="time"
            name="time"
            data-time-input
            value={timeValue}
            required
            class="settings__time-input"
          />
        </label>
        <label class="settings__tz" data-tz-block>
          {/* Implements REQ-SET-007 AC 5 — manual tz picker. The
              <select> renders the full IANA inventory server-side and
              defaults to the stored tz so first-paint is correct. The
              wireTzPicker() init swaps the selection to the
              browser-detected zone when it differs, so the most likely
              answer is one click away. */}
          <span class="settings__field-label">Timezone</span>
          <select class="settings__tz-current" name="tz" data-tz-select>
            {tzOptions.map((zone) => (
              <option value={zone} selected={zone === tzValue}>{zone}</option>
            ))}
          </select>
        </label>
        {showModelSelect ? (
          <label class="settings__field">
            {/* Implements REQ-SET-004 — hidden while the global pipeline
                runs on a single default model. Kept here so re-enabling
                is a one-line flip of `showModelSelect`. */}
            <span class="settings__field-label">Model</span>
            <ModelSelect selected={currentModelId} />
          </label>
        ) : (
          /* Implements REQ-SET-004 — stored preference survives across
             UI toggles. Hidden input carries the current model_id so
             the PUT handler (which still validates and persists the
             field) receives the round-tripped value. */
          <input
            type="hidden"
            name="model_id"
            data-model-id-fallback
            value={currentModelId}
          />
        )}
        <label class="settings__toggle">
          <input
            type="checkbox"
            name="email_enabled"
            class="settings__email-checkbox"
            data-email-toggle
            checked={emailEnabled}
          />
          <span>Email me when my daily digest is ready</span>
        </label>
        <div class="settings__actions-row">
          <button
            type="submit"
            class="settings__secondary-button"
            data-settings-submit
          >
            {primaryCta}
          </button>
          <p class="settings__status" data-settings-status aria-live="polite"></p>
        </div>
      </fieldset>
    </form>

    {
      !isFirstRun && (
        <fieldset class="settings__section settings__section--standalone">
          <legend class="settings__legend">Interests</legend>
          <p class="settings__hint">
            Tags live at the top of the digest page — click to select/filter, click
            the × to delete. You can revert to the curated starter list at any time.
          </p>
          <div class="settings__actions-row">
            {/*
              Native <form> POST to /api/tags/restore. MUST sit outside
              the main <form class='settings__form'> above — nested
              <form>s are invalid HTML and the browser submits the
              outer one on click, which redirected users to
              /settings?time=08:30 instead of calling the endpoint.
              Shown only when at least one default tag is MISSING from
              the user's list; when they already have every default,
              Restore is a no-op, so we hide it.
            */}
            {showRestoreButton && (
              <form
                method="post"
                action="/api/tags/restore"
                class="settings__restore-form"
                data-restore-form
              >
                <button
                  type="submit"
                  class="settings__secondary-button"
                  data-restore-tags
                >
                  {RESTORE_DEFAULTS_LABEL}
                </button>
              </form>
            )}
            {/*
              Companion POST to /api/tags/delete-initial (endpoint kept
              for git-blame continuity; behaviour rewritten to clear
              the whole list). The button is a one-click "start from
              scratch" so a user can build a completely custom tag
              set without removing 20 default chips one-by-one.
              Visibility rules (REQ-SET-002 AC 8):
                - Restore + Delete both shown → user has at least one
                  tag AND is missing at least one default
                - Restore only → user has every default (nothing to
                  clear... wait, they still HAVE tags, so Delete too).
                  In practice this branch means empty list.
                - Delete only → user has every default (Restore hidden)
                - Neither → user's list is already empty
            */}
            {showDeleteAllButton && (
              <form
                method="post"
                action="/api/tags/delete-initial"
                class="settings__delete-all-form"
                data-delete-all-form
              >
                <button
                  type="submit"
                  class="settings__secondary-button"
                  data-delete-all-tags
                >
                  {DELETE_ALL_TAGS_LABEL}
                </button>
              </form>
            )}
            <p class="settings__status" data-restore-status aria-live="polite"></p>
          </div>
        </fieldset>
      )
    }

    {
      !isFirstRun && emptyFeedTags.length > 0 && (
        /* Implements REQ-DISC-004 — single bulk "Discover missing
           sources" button posts to /api/admin/discovery/retry-bulk which
           re-queues every empty-feed tag in one shot. The settings
           page no longer renders a button per stuck tag; clicking
           once is enough. Native form POST chosen over JS for the
           same Samsung-Browser/in-app-webview reliability reason as
           the rest of the page. The endpoint is additionally gated
           by Cloudflare Access so only the admin can execute it. */
        <fieldset class="settings__section settings__section--standalone">
          <legend class="settings__legend">Stuck tags</legend>
          <p class="settings__hint">
            {emptyFeedTags.length === 1 ? '1 tag has' : `${emptyFeedTags.length} tags have`} no working feeds right now. One click re-runs LLM discovery for all of them.
          </p>
          {rediscoverConfirmed && (
            <p class="settings__status" data-rediscover-status>
              {rediscoverConfirmedCount === 0
                ? 'Nothing to re-queue right now.'
                : rediscoverConfirmedCount === 1
                  ? 'Queued 1 tag for re-discovery. The next discovery tick (≤5 minutes) will refresh its sources.'
                  : `Queued ${rediscoverConfirmedCount} tags for re-discovery. The next few discovery ticks will refresh their sources.`}
            </p>
          )}
          <div class="settings__actions-row" data-rediscover-actions>
            <form
              method="post"
              action="/api/admin/discovery/retry-bulk"
              class="settings__rediscover-form"
              data-rediscover-bulk-form
            >
              <button
                type="submit"
                class="settings__secondary-button"
                data-rediscover-bulk
              >
                Discover missing sources
              </button>
            </form>
          </div>
        </fieldset>
      )
    }

    {
      !isFirstRun && (
        <section class="settings__secondary">
          <InstallPrompt />
          <fieldset class="settings__section">
            <legend class="settings__legend">Profile picture</legend>
            <p class="settings__hint">
              Your avatar comes from Gravatar, a free service that links a
              photo to your email address. Sign up there with the email on
              your account, upload a photo, and it appears here next time
              you load the app.
            </p>
            <div class="settings__actions-row">
              <a
                href="https://gravatar.com/"
                target="_blank"
                rel="noopener noreferrer"
                class="settings__secondary-button"
              >
                Open Gravatar
              </a>
            </div>
          </fieldset>
          <fieldset class="settings__section">
            <legend class="settings__legend">Force refresh</legend>
            <p class="settings__hint">
              Fire the global scrape pipeline immediately instead of
              waiting for the next 4-hour tick. Useful after a deploy
              to verify the coordinator + chunk consumer end-to-end.
              This endpoint is gated by Cloudflare Access — only
              operators with an Access session can reach it.
            </p>
            <div class="settings__actions-row">
              <form method="post" action="/api/admin/force-refresh">
                <button
                  type="submit"
                  class="settings__secondary-button"
                >
                  Force refresh now
                </button>
              </form>
            </div>
            {/* Live progress line for any in-flight scrape run. Hidden
                by default; the script at the bottom of this page polls
                /api/scrape-status every 5s and fills it with a
                "chunks done / articles ingested" line while status is
                running. Clears itself when the run completes. */}
            <p
              class="settings__status"
              data-scrape-progress
              aria-live="polite"
              hidden
            ></p>
          </fieldset>
          <fieldset class="settings__section">
            <legend class="settings__legend">Delete account</legend>
            <p class="settings__hint">
              Permanently deletes your account, digests, and all associated data.
            </p>
            {/*
              Native <form method="post" action="/api/auth/account"> —
              the server also accepts the JSON DELETE path for API
              callers, but the browser flow goes through POST so the
              JS interceptor can't swallow the submit on flaky mobile
              engines (Samsung Browser / in-app webviews). The HTML
              `required` + `pattern` attributes enforce the "DELETE"
              literal at the form-validation level before the browser
              dispatches; the server still re-validates.
            */}
            <form
              class="settings__delete"
              method="post"
              action="/api/auth/account"
              data-delete-account
              aria-label="Delete account"
            >
              <label class="settings__field">
                <span class="settings__field-label">Type DELETE to confirm</span>
                <input
                  type="text"
                  name="confirm"
                  data-delete-confirm
                  autocomplete="off"
                  required
                  pattern="DELETE"
                  class="settings__delete-input"
                />
              </label>
              <button type="submit" class="settings__delete-button">
                Delete my account
              </button>
            </form>
          </fieldset>
          <fieldset class="settings__section">
            <legend class="settings__legend">About</legend>
            <p class="settings__hint">
              News Digest is open source. Read the code, file an issue, fork it.
            </p>
            <div class="settings__actions-row">
              <a
                href="https://github.com/nikolanovoselec/ai-news-digest"
                target="_blank"
                rel="noopener noreferrer"
                class="settings__secondary-button"
              >
                View source on GitHub
              </a>
            </div>
          </fieldset>
        </section>
      )
    }
  </section>
</Base>

<script>
  // Implements REQ-SET-001, REQ-SET-002, REQ-SET-003, REQ-SET-004, REQ-SET-005, REQ-SET-007
  //
  // Client-side controller for /settings. Framework-free — collects
  // form state from DOM data attributes and POSTs JSON to /api/settings.

  interface SettingsResponse {
    ok?: boolean;
    discovering?: string[];
    error?: string;
    code?: string;
  }

  async function submitSettings(
    form: HTMLFormElement,
    status: HTMLElement,
    submitButton: HTMLButtonElement,
  ): Promise<void> {
    const timeInput = form.querySelector('[data-time-input]') as HTMLInputElement | null;
    const tzSelect = form.querySelector('[data-tz-select]') as HTMLSelectElement | null;
    const emailToggle = form.querySelector('[data-email-toggle]') as HTMLInputElement | null;
    // CRITICAL — model_id field is rendered as <select> when showModelSelect=true
    // and as a hidden <input> when false. Selecting `select[name="model_id"]`
    // returned null in production (showModelSelect=false), so modelId became ''
    // and PUT /api/settings 400'd with invalid_model_id BEFORE persisting tz.
    // Every save silently failed; users saw "tz reset to UTC" because the DB
    // value never changed. Use attribute-only selector to match either element.
    const modelSelect = form.querySelector(
      '[name="model_id"]',
    ) as HTMLSelectElement | HTMLInputElement | null;

    const timeValue = timeInput?.value ?? '';
    const [hourStr, minuteStr] = timeValue.split(':');
    const digestHour = Number.parseInt(hourStr ?? '', 10);
    const digestMinute = Number.parseInt(minuteStr ?? '', 10);
    // TZ comes from the manual <select> (REQ-SET-007 AC 5). The picker
    // is server-rendered with the stored value, then upgraded to the
    // browser-detected zone by wireTzPicker on load — so .value is
    // always the right answer, no Intl fallback needed here.
    const tz = tzSelect?.value ?? '';
    const modelId = modelSelect?.value ?? '';
    const emailEnabled = emailToggle?.checked === true;

    // Hashtags are edited on the /digest tag strip via POST /api/tags;
    // this endpoint no longer accepts a `hashtags` field.
    const payload = {
      digest_hour: digestHour,
      digest_minute: digestMinute,
      tz,
      model_id: modelId,
      email_enabled: emailEnabled,
    };

    submitButton.disabled = true;
    status.textContent = 'Saving…';
    let res: Response;
    try {
      res = await fetch('/api/settings', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
        credentials: 'same-origin',
      });
    } catch {
      status.textContent = 'Network error. Please try again.';
      submitButton.disabled = false;
      return;
    }

    let body: SettingsResponse = {};
    try {
      body = (await res.json()) as SettingsResponse;
    } catch {
      /* keep body as {} */
    }

    if (!res.ok || body.ok !== true) {
      status.textContent =
        body.error ?? 'Could not save your settings. Please try again.';
      submitButton.disabled = false;
      return;
    }

    const wasFirstRun =
      document
        .querySelector<HTMLElement>('[data-settings]')
        ?.dataset['firstRun'] === '1';

    if (wasFirstRun) {
      // Kick off the user's first digest automatically so they see a
      // live "generating…" card as soon as they land on /digest. If the
      // request fails (e.g., rate-limit, no tags yet), the server still
      // picks it up on the normal schedule — not worth blocking the
      // redirect on it.
      try {
        await fetch('/api/digest/refresh', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
        });
      } catch {
        /* best-effort */
      }
      window.location.assign('/digest');
      return;
    }

    // Refresh the body dataset so syncBrowserTz on subsequent View Transition
    // page loads sees the new stored tz and never re-stamps from a stale value.
    document.body.dataset['userTz'] = tz;
    status.textContent = 'Saved';
    submitButton.disabled = false;
  }

  // deleteAccount() lived here as a JS submit interceptor that
  // POSTed { confirm: 'DELETE' } via fetch. The form is now a native
  // HTML <form method="post" action="/api/auth/account"> so the
  // browser submits directly — no JS intercept, no race with mobile
  // engines that eat the submit. The server's POST handler returns a
  // 303 to /?account_deleted=1.

  /** Poll /api/scrape-status every 5s and write a "X/Y chunks done,
   *  N articles ingested" line into [data-scrape-progress]. Hides
   *  the element when no run is active, cheap to keep running —
   *  one SQL SELECT + one KV get per poll, no LLM, no article read. */
  async function pollScrapeProgress(): Promise<void> {
    const el = document.querySelector<HTMLElement>('[data-scrape-progress]');
    if (el === null) return;
    try {
      const res = await fetch('/api/scrape-status', {
        credentials: 'same-origin',
        headers: { Accept: 'application/json' },
      });
      if (!res.ok) {
        el.hidden = true;
        return;
      }
      const body = (await res.json()) as {
        running: boolean;
        chunks_remaining?: number | null;
        chunks_total?: number | null;
        articles_ingested?: number | null;
        started_at?: number;
      };
      if (!body.running) {
        el.hidden = true;
        el.textContent = '';
        return;
      }
      // Bucketed progress — 0 / 25 / 50 / 75 / 100 %. Snap DOWN to
      // the nearest quarter (floor), so a run that's finished 3 of
      // 4 chunks reads as 75%, not 100%. Total unknown → show a
      // plain 'Scrape in progress' line until the coordinator's
      // chunk_count write lands.
      const parts: string[] = ['Scrape in progress'];
      if (
        typeof body.chunks_total === 'number' && body.chunks_total > 0 &&
        typeof body.chunks_remaining === 'number'
      ) {
        const done = Math.max(0, body.chunks_total - body.chunks_remaining);
        const ratio = done / body.chunks_total;
        const pct = Math.min(100, Math.floor(ratio * 4) * 25);
        parts.push(`${pct}%`);
      }
      const ing = body.articles_ingested;
      if (typeof ing === 'number' && ing > 0) {
        parts.push(`${ing} articles ingested`);
      }
      if (typeof body.started_at === 'number') {
        const elapsed = Math.max(0, Math.floor(Date.now() / 1000) - body.started_at);
        const m = Math.floor(elapsed / 60);
        const s = elapsed % 60;
        parts.push(`${m}m ${s}s elapsed`);
      }
      el.textContent = parts.join(' — ');
      el.hidden = false;
    } catch {
      /* keep the current text; the next tick retries */
    }
  }

  let scrapeProgressHandle: number | null = null;
  function wireScrapeProgress(): void {
    if (scrapeProgressHandle !== null) return;
    void pollScrapeProgress();
    scrapeProgressHandle = window.setInterval(pollScrapeProgress, 5_000);
  }
  /** Clear the scrape-progress poll interval on Astro View-Transition
   *  navigations. Without this the setInterval keeps firing after
   *  the user leaves /settings — the DOM-query null-guard stops
   *  UI writes but the HTTP request still fires every 5s. */
  function teardownScrapeProgress(): void {
    if (scrapeProgressHandle !== null) {
      window.clearInterval(scrapeProgressHandle);
      scrapeProgressHandle = null;
    }
  }
  document.addEventListener('astro:before-swap', teardownScrapeProgress);

  function init(): void {
    // Restore + delete forms live OUTSIDE the main settings form (they
    // were hoisted to fix a nested-<form> bug). Wire them first so they
    // bind even when the main form early-returns as already-bound.
    wireRestoreForm();
    wireDeleteForm();
    wireScrapeProgress();

    const form = document.querySelector<HTMLFormElement>('[data-settings-form]');
    if (form === null) return;
    if (form.dataset['bound'] === '1') return;
    form.dataset['bound'] = '1';

    const status = form.querySelector<HTMLElement>('[data-settings-status]');
    const submit = form.querySelector<HTMLButtonElement>('[data-settings-submit]');
    const tzSelect = form.querySelector('[data-tz-select]') as HTMLSelectElement | null;

    // Surface the native-POST round-trip outcome inline next to the
    // Save button (instead of a top-of-page banner). The /api/settings
    // POST handler 303-redirects to /settings?saved=ok or
    // /settings?error=<code>; copy the message into the same
    // [data-settings-status] node the JS PUT path writes to, then
    // strip the query so a refresh doesn't re-show stale text.
    if (status !== null) {
      try {
        const params = new URLSearchParams(window.location.search);
        const saved = params.get('saved');
        const errorCode = params.get('error');
        if (saved === 'ok') {
          status.textContent = 'Saved';
        } else if (errorCode !== null && errorCode !== '') {
          const map: Record<string, string> = {
            invalid_time: 'Pick a valid digest time.',
            invalid_tz: 'Pick a valid IANA timezone.',
            invalid_model_id: 'Pick a valid model.',
            forbidden_origin: 'Origin check failed; reload and try again.',
            bad_request: 'Could not parse the form; reload and try again.',
            internal_error: 'Save failed on the server; please try again.',
            app_not_configured: 'Server is misconfigured; contact the admin.',
          };
          status.textContent = map[errorCode] ?? 'Could not save your settings.';
        }
        if (saved !== null || errorCode !== null) {
          params.delete('saved');
          params.delete('error');
          const next = params.toString();
          const newUrl = window.location.pathname + (next === '' ? '' : '?' + next);
          window.history.replaceState({}, '', newUrl);
        }
      } catch {
        /* leave status text blank if URL parsing fails */
      }
    }

    // REQ-SET-007 AC 5 + AC 6 — browser-detected pre-select. Server
    // rendered the dropdown with the stored tz selected (or 'UTC' as
    // the UI fallback when stored is the empty seed sentinel). We only
    // swap to the browser-resolved zone while the stored value is the
    // seeded sentinel (empty), matching Base.astro's syncBrowserTz gate.
    // Any non-empty stored value is authoritative — including 'UTC',
    // which a user can pick deliberately.
    //
    // Read the stored tz from `document.body.dataset.userTz`, NOT from
    // `tzSelect.value`. The select's value defaults to the alphabetically
    // -first option when no `<option selected>` matched the stored value.
    const storedTz = document.body.dataset['userTz'] ?? '';
    if (tzSelect !== null && storedTz === '') {
      try {
        const browserTz = Intl.DateTimeFormat().resolvedOptions().timeZone;
        if (
          browserTz !== '' &&
          browserTz !== tzSelect.value &&
          tzSelect.querySelector(`option[value="${CSS.escape(browserTz)}"]`) !== null
        ) {
          tzSelect.value = browserTz;
        }
      } catch {
        /* Intl unavailable — leave the stored tz in place. */
      }
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      if (status === null || submit === null) return;
      void submitSettings(form, status, submit);
    });

  }

  /** Wire Restore-initial-tags handler. Separate from init() so that
   * the main settings form's early-return ("already bound") doesn't
   * skip this handler after a View-Transition DOM swap. */
  function wireRestoreForm(): void {
    const restoreForm = document.querySelector<HTMLFormElement>('[data-restore-form]');
    const restoreStatus = document.querySelector<HTMLElement>('[data-restore-status]');
    if (restoreForm === null) return;
    if (restoreForm.dataset['bound'] === '1') return;
    restoreForm.dataset['bound'] = '1';
    restoreForm.addEventListener('submit', () => {
      const button = restoreForm.querySelector<HTMLButtonElement>('[data-restore-tags]');
      if (button !== null) button.disabled = true;
      if (restoreStatus !== null) restoreStatus.textContent = 'Restoring…';
      // Fall through to native POST — browser follows the 303.
    });
  }

  /** Wire the Delete-account button's progress indicator. The form
   *  itself is a native POST so no submit intercept is needed — this
   *  handler only flashes "Deleting…" on click so the user gets
   *  immediate feedback while the browser navigates. */
  function wireDeleteForm(): void {
    const deleteForm = document.querySelector<HTMLFormElement>('[data-delete-account]');
    if (deleteForm === null) return;
    if (deleteForm.dataset['bound'] === '1') return;
    deleteForm.dataset['bound'] = '1';
    deleteForm.addEventListener('submit', () => {
      const button = deleteForm.querySelector<HTMLButtonElement>(
        'button[type="submit"]',
      );
      if (button !== null) {
        button.disabled = true;
        button.textContent = 'Deleting…';
      }
      // Fall through to native POST — browser follows the 303.
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init, { once: true });
  } else {
    init();
  }
  document.addEventListener('astro:page-load', init);
</script>

