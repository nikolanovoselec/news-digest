---
// Implements REQ-AUTH-001
//
// Landing page. Shows a single "Sign in with GitHub" button for anonymous
// visitors (AC 1). Already-authenticated users are redirected to /digest
// so the root path is a stable entry point from bookmarks, shortcuts,
// and PWA launches regardless of session state.

import Base from '~/layouts/Base.astro';
import { loadSession } from '~/middleware/auth';

const env = Astro.locals.runtime.env;
if (typeof env.OAUTH_JWT_SECRET === 'string' && env.OAUTH_JWT_SECRET !== '') {
  const session = await loadSession(Astro.request, env.DB, env.OAUTH_JWT_SECRET);
  if (session !== null) {
    return Astro.redirect('/digest', 303);
  }
}

// Surface a friendly message when the OAuth callback bounced the user
// back here (e.g. `no_verified_email` per REQ-AUTH-001 AC 4).
const errorCode = Astro.url.searchParams.get('error');
const errorMessage =
  errorCode === 'no_verified_email'
    ? 'GitHub did not return a verified primary email. Please verify an email address on GitHub and try again.'
    : errorCode !== null && errorCode !== ''
      ? 'Sign-in did not complete. Please try again.'
      : null;
---

<Base title="News Digest — personalised daily tech news">
  <main class="landing safe-x" role="main">
    <section class="landing__hero">
      <h1 class="landing__title">Your daily tech digest,<br />distilled by AI.</h1>
      <p class="landing__tagline">
        Pick the hashtags you care about. Every morning, a concise, readable summary
        of the day's news — no feeds to scroll, no noise.
      </p>

      {errorMessage !== null && (
        <p class="landing__error" role="alert">{errorMessage}</p>
      )}

      {/* POST instead of a GET anchor so mobile browser prefetch cannot
          regenerate the OAuth state cookie between the click and GitHub's
          callback. Samsung Browser was observed issuing 4 prefetch GETs
          in ~500ms, each overwriting the state cookie — the cookie value
          that finally stuck did not match the state GitHub returned. */}
      <form method="post" action="/api/auth/github/login" class="landing__form">
        <button type="submit" class="landing__cta focus-ring">
          <svg
            class="landing__cta-icon"
            viewBox="0 0 24 24"
            aria-hidden="true"
            width="20"
            height="20"
          >
            <path
              fill="currentColor"
              d="M12 .5C5.73.5.75 5.48.75 11.75c0 4.96 3.22 9.16 7.68 10.65.56.1.76-.24.76-.54 0-.27-.01-1.16-.02-2.1-3.13.68-3.79-1.33-3.79-1.33-.51-1.3-1.25-1.65-1.25-1.65-1.02-.7.08-.69.08-.69 1.13.08 1.72 1.16 1.72 1.16 1 1.72 2.63 1.23 3.27.94.1-.73.39-1.23.71-1.51-2.5-.28-5.13-1.25-5.13-5.58 0-1.23.44-2.24 1.16-3.03-.12-.28-.5-1.43.11-2.99 0 0 .95-.3 3.1 1.16a10.8 10.8 0 0 1 5.64 0c2.14-1.46 3.09-1.16 3.09-1.16.62 1.56.23 2.71.11 2.99.72.79 1.16 1.8 1.16 3.03 0 4.34-2.63 5.3-5.14 5.58.4.35.76 1.03.76 2.08 0 1.5-.01 2.71-.01 3.08 0 .3.2.65.77.54 4.46-1.5 7.67-5.7 7.67-10.65C23.25 5.48 18.27.5 12 .5Z"
            />
          </svg>
          Sign in with GitHub
        </button>
      </form>
      <p class="landing__privacy">
        We only use your GitHub email to send digests. No password, no tracking.
      </p>
    </section>
  </main>
</Base>

<style>
  .landing {
    display: grid;
    place-items: center;
    min-height: calc(100svh - 4rem);
    padding: 2rem 1.25rem;
  }
  .landing__hero {
    max-width: 36rem;
    text-align: center;
  }
  .landing__title {
    font-size: clamp(1.875rem, 5vw, 3rem);
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 1rem;
    color: var(--text);
  }
  .landing__tagline {
    font-size: 1.125rem;
    line-height: 1.55;
    color: var(--text-muted);
    margin: 0 0 2.5rem;
  }
  .landing__error {
    background: var(--surface-raised);
    border: 1px solid var(--border);
    border-left: 3px solid var(--danger, #d33);
    color: var(--text);
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    margin: 0 0 1.5rem;
    font-size: 0.95rem;
    text-align: left;
  }
  .landing__form {
    margin: 0;
    padding: 0;
  }
  .landing__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.875rem 1.5rem;
    background: var(--text);
    color: var(--bg);
    border: none;
    border-radius: 9999px;
    font-family: inherit;
    font-weight: 500;
    font-size: 1rem;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.15s ease, opacity 0.15s ease;
  }
  .landing__cta:hover {
    transform: translateY(-1px);
    opacity: 0.92;
  }
  .landing__cta:active {
    transform: translateY(0);
  }
  .landing__cta-icon {
    flex-shrink: 0;
  }
  .landing__privacy {
    font-size: 0.8125rem;
    color: var(--text-muted);
    margin: 1.25rem 0 0;
  }
</style>
