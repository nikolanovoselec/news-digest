---
// Implements REQ-AUTH-001
//
// Landing page. Renders one button per provider that the deployment has
// configured (env credentials present), listed alphabetically. Already-
// authenticated users are redirected to /digest so the root path is a
// stable entry point from bookmarks, shortcuts, and PWA launches
// regardless of session state.

import Base from '~/layouts/Base.astro';
import { loadSession } from '~/middleware/auth';
import { configuredProviders } from '~/lib/oauth-providers';

const env = Astro.locals.runtime.env;
if (typeof env.OAUTH_JWT_SECRET === 'string' && env.OAUTH_JWT_SECRET !== '') {
  const session = await loadSession(Astro.request, env.DB, env.OAUTH_JWT_SECRET);
  if (session !== null) {
    return Astro.redirect('/digest', 303);
  }
}

const providers = configuredProviders(env);

// Surface a friendly message when the OAuth callback bounced the user
// back here (e.g. `no_verified_email` per REQ-AUTH-001 AC 4). The
// callback appends ?provider=<name> when known so the message can name
// the provider precisely instead of guessing "GitHub" for every error.
const errorCode = Astro.url.searchParams.get('error');
const errorProvider = Astro.url.searchParams.get('provider');
const providerLabel =
  errorProvider === 'github'
    ? 'GitHub'
    : errorProvider === 'google'
      ? 'Google'
      : 'the sign-in provider';
const errorMessage =
  errorCode === 'no_verified_email'
    ? `${providerLabel} did not return a verified primary email. Please verify an email address on ${providerLabel} and try again.`
    : errorCode === 'invalid_state'
      ? 'Sign-in did not complete (CSRF state mismatch). Please try again.'
      : errorCode !== null && errorCode !== ''
        ? 'Sign-in did not complete. Please try again.'
        : null;
---

<Base title="News Digest — personalised daily tech news">
  <main class="landing safe-x" role="main">
    <section class="landing__hero">
      <h1 class="landing__title">Your daily tech digest,<br />distilled by AI.</h1>
      <p class="landing__tagline">
        Pick the hashtags you care about. Every morning, a concise, readable summary
        of the day's news — no feeds to scroll, no noise.
      </p>

      {errorMessage !== null && (
        <p class="landing__error" role="alert">{errorMessage}</p>
      )}

      {providers.length === 0 && (
        /* No provider configured: surface a clear message instead of
           dead buttons (REQ-AUTH-001 AC 1). */
        <p class="landing__error" role="alert" data-no-providers>
          Sign-in is not configured for this deployment. The operator
          needs to add at least one OAuth provider's credentials.
        </p>
      )}

      {providers.length > 0 && (
        /* POST instead of a GET anchor so mobile browser prefetch cannot
           regenerate the OAuth state cookie between the click and the
           provider's callback. Samsung Browser was observed issuing 4
           prefetch GETs in ~500ms, each overwriting the state cookie. */
        <div class="landing__providers" data-providers>
          {providers.map((p) => (
            <form
              method="post"
              action={`/api/auth/${p.name}/login`}
              class="landing__form"
              data-provider={p.name}
            >
              <button type="submit" class="landing__cta focus-ring">
                {p.name === 'github' && (
                  <svg
                    class="landing__cta-icon"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                    width="20"
                    height="20"
                  >
                    <path
                      fill="currentColor"
                      d="M12 .5C5.73.5.75 5.48.75 11.75c0 4.96 3.22 9.16 7.68 10.65.56.1.76-.24.76-.54 0-.27-.01-1.16-.02-2.1-3.13.68-3.79-1.33-3.79-1.33-.51-1.3-1.25-1.65-1.25-1.65-1.02-.7.08-.69.08-.69 1.13.08 1.72 1.16 1.72 1.16 1 1.72 2.63 1.23 3.27.94.1-.73.39-1.23.71-1.51-2.5-.28-5.13-1.25-5.13-5.58 0-1.23.44-2.24 1.16-3.03-.12-.28-.5-1.43.11-2.99 0 0 .95-.3 3.1 1.16a10.8 10.8 0 0 1 5.64 0c2.14-1.46 3.09-1.16 3.09-1.16.62 1.56.23 2.71.11 2.99.72.79 1.16 1.8 1.16 3.03 0 4.34-2.63 5.3-5.14 5.58.4.35.76 1.03.76 2.08 0 1.5-.01 2.71-.01 3.08 0 .3.2.65.77.54 4.46-1.5 7.67-5.7 7.67-10.65C23.25 5.48 18.27.5 12 .5Z"
                    />
                  </svg>
                )}
                {p.name === 'google' && (
                  /* Google "G" mark — official multi-color logo. Each
                     path uses one of the four brand colours as fill so
                     the icon stays branded regardless of theme. */
                  <svg
                    class="landing__cta-icon"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                    width="20"
                    height="20"
                  >
                    <path
                      fill="#4285F4"
                      d="M22.5 12.27c0-.79-.07-1.55-.2-2.27H12v4.31h5.92a5.06 5.06 0 0 1-2.2 3.32v2.76h3.56c2.08-1.92 3.27-4.74 3.27-8.12Z"
                    />
                    <path
                      fill="#34A853"
                      d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.55-2.76c-.98.66-2.24 1.05-3.73 1.05-2.87 0-5.3-1.94-6.17-4.55H2.16v2.85A11 11 0 0 0 12 23Z"
                    />
                    <path
                      fill="#FBBC05"
                      d="M5.83 14.08a6.6 6.6 0 0 1 0-4.16V7.07H2.16a11 11 0 0 0 0 9.86l3.67-2.85Z"
                    />
                    <path
                      fill="#EA4335"
                      d="M12 5.38c1.62 0 3.07.56 4.21 1.65l3.15-3.15C17.46 2.09 14.97 1 12 1A11 11 0 0 0 2.16 7.07l3.67 2.85C6.7 7.32 9.13 5.38 12 5.38Z"
                    />
                  </svg>
                )}
                Sign in with {p.displayName}
              </button>
            </form>
          ))}
        </div>
      )}
    </section>
  </main>
</Base>

<style>
  .landing {
    display: grid;
    place-items: center;
    /* Leave room for the sticky header (~60px) + global footer (~80px
       including top-margin + padding) so the footer lands inside the
       viewport on short content. Without this, landing fills 100svh-4rem
       which combined with header + footer pushes the footer below
       the fold and forces the user to scroll. */
    min-height: calc(100svh - 12rem);
    padding: 2rem 1.25rem;
  }
  .landing__hero {
    max-width: 36rem;
    text-align: center;
  }
  .landing__title {
    font-size: clamp(1.875rem, 5vw, 3rem);
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 1rem;
    color: var(--text);
  }
  .landing__tagline {
    font-size: 1.125rem;
    line-height: 1.55;
    color: var(--text-muted);
    margin: 0 0 2.5rem;
  }
  .landing__error {
    background: var(--surface-raised);
    border: 1px solid var(--border);
    border-left: 3px solid var(--danger, #d33);
    color: var(--text);
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    margin: 0 0 1.5rem;
    font-size: 0.95rem;
    text-align: left;
  }
  .landing__providers {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }
  .landing__form {
    margin: 0;
    padding: 0;
  }
  .landing__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.875rem 1.5rem;
    background: var(--text);
    color: var(--bg);
    border: none;
    border-radius: 9999px;
    font-family: inherit;
    font-weight: 500;
    font-size: 1rem;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.15s ease, opacity 0.15s ease;
  }
  .landing__cta:hover {
    transform: translateY(-1px);
    opacity: 0.92;
  }
  .landing__cta:active {
    transform: translateY(0);
  }
  .landing__cta-icon {
    flex-shrink: 0;
  }
</style>
