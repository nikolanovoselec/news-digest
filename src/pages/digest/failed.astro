---
// Implements REQ-READ-006
//
// Failure page for digest generation. Shown when the most recent digest
// has `status='failed'` (digest.astro server-side redirects here) OR
// when the client-side poll loop observes a 'failed' status.
//
// Layout: calm headline + short explanation + primary "Try again"
// action + secondary "Go to settings" link. The raw `error_code` is
// shown in a muted monospace footer so advanced users can quote it in
// support requests — per REQ-READ-006 AC 2, NO prose from the
// underlying error ever reaches the DOM; only the sanitized code.

import Base from '~/layouts/Base.astro';
import { loadSession } from '~/middleware/auth';

// Load the authenticated user onto locals so the header (UserMenu)
// renders. Mirror the auth pattern from digest.astro:
// fail-closed with 500 when the OAUTH_JWT_SECRET is missing, route
// unauth visitors through the OAuth flow.
const env = Astro.locals.runtime.env;
if (typeof env.OAUTH_JWT_SECRET !== 'string' || env.OAUTH_JWT_SECRET === '') {
  return new Response('Application not configured', { status: 500 });
}
const session = await loadSession(Astro.request, env.DB, env.OAUTH_JWT_SECRET);
if (session === null) {
  return Astro.redirect('/api/auth/github/login', 303);
}
Astro.locals.user = session.user;

const url = new URL(Astro.request.url);
const rawCode = url.searchParams.get('code');

// Allowlist the sanitized error codes we are willing to show. Anything
// outside this list falls back to the generic `llm_failed` label — we
// never echo an arbitrary query parameter into the DOM (CON-SEC-001).
const ALLOWED_CODES = new Set<string>([
  'llm_invalid_json',
  'llm_failed',
  'all_sources_failed',
  'generation_stalled',
  'user_cancelled',
  'rate_limited',
]);
const errorCode =
  rawCode !== null && ALLOWED_CODES.has(rawCode) ? rawCode : 'llm_failed';

// Rate-limit metadata forwarded from /api/digest/refresh's 303 redirect.
const rateLimitReason = url.searchParams.get('reason');
const retryAfterRaw = url.searchParams.get('retry_after');
const retryAfterSeconds =
  retryAfterRaw !== null && /^\d+$/.test(retryAfterRaw)
    ? Number.parseInt(retryAfterRaw, 10)
    : null;
---

<Base title="Digest failed">
  <section class="failure-page">
    <h1 class="failure-page__title">We couldn't build your digest</h1>
    <p class="failure-page__message">
      Something went wrong while generating today's digest. You can try again,
      or adjust your sources and schedule in settings.
    </p>
    <div class="failure-page__actions">
      {/*
        Native <form> POST to /api/digest/refresh. The endpoint detects
        the form content-type and responds with a 303 redirect that the
        browser follows automatically — so Try-again works even when
        JavaScript is disabled, broken, or shadowed by a stale bundle.
        The client-side JS below is a pure progressive enhancement that
        updates the inline status region before the browser navigates.
      */}
      <form
        class="failure-page__retry-form"
        method="post"
        action="/api/digest/refresh"
        data-retry-form
      >
        <button
          type="submit"
          class="failure-page__retry-button"
          data-retry-button
        >
          Try again
        </button>
      </form>
    </div>
    <p
      class="failure-page__status"
      data-retry-status
      role="status"
      aria-live="polite"
    >
      {
        errorCode === 'rate_limited' && (
          <span>
            {rateLimitReason === 'daily_cap'
              ? `Daily refresh limit reached${retryAfterSeconds !== null ? ` — try again in ${Math.ceil(retryAfterSeconds / 60)} min` : ''}.`
              : `Please wait${retryAfterSeconds !== null ? ` ${retryAfterSeconds} s` : ' a moment'} before retrying.`}
          </span>
        )
      }
    </p>
    <footer class="failure-page__code">
      <code>{errorCode}</code>
    </footer>
  </section>
</Base>

<script>
  // Light progressive enhancement on top of the native <form> POST:
  //   * paint a 'Retrying…' status line synchronously when the form
  //     submits, so the user gets feedback during the ~1s POST round-
  //     trip before the browser follows the 303 redirect,
  //   * disable the submit button to prevent double-clicks.
  //
  // If this script never runs (bundle blocked, CSP hiccup, stale SW
  // etc.) the native form submission still works — the server
  // responds with a 303 that the browser follows without any JS.
  function init(): void {
    const form = document.querySelector<HTMLFormElement>('[data-retry-form]');
    if (form === null) return;
    if (form.dataset['bound'] === '1') return;
    form.dataset['bound'] = '1';
    form.addEventListener('submit', () => {
      const button = form.querySelector<HTMLButtonElement>('[data-retry-button]');
      const status = document.querySelector<HTMLElement>('[data-retry-status]');
      if (button !== null) button.disabled = true;
      if (status !== null) status.textContent = 'Retrying…';
      // Fall through — don't call preventDefault(). The native POST
      // navigates to the 303 Location the endpoint returned.
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init, { once: true });
  } else {
    init();
  }
  document.addEventListener('astro:page-load', init);
</script>

<style>
  .failure-page {
    max-width: 560px;
    margin: 0 auto;
    padding: 3rem 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    text-align: center;
  }

  .failure-page__title {
    margin: 0;
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--text);
  }

  .failure-page__message {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-base);
    line-height: 1.5;
  }

  .failure-page__actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .failure-page__retry {
    margin: 0;
  }

  .failure-page__retry-button {
    min-height: 44px;
    padding: 0.75rem 1.5rem;
    background-color: var(--text);
    color: var(--bg);
    border: none;
    border-radius: 0.375rem;
    font-weight: 600;
    cursor: pointer;
  }

  .failure-page__retry-button:disabled {
    opacity: 0.6;
    cursor: wait;
  }

  .failure-page__status {
    margin: 0.5rem 0 0;
    color: var(--text-muted);
    font-size: var(--text-sm);
    min-height: 1.25rem;
  }

  .failure-page__code {
    margin-top: 1.5rem;
    color: var(--text-muted);
    font-size: var(--text-sm);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }
</style>
