---
// Implements REQ-READ-002, REQ-READ-003
//
// Article detail view. Renders the article's title, the three `details`
// bullets as an unordered list, and a prominent "Read at source" link.
// All text is rendered with Astro's default `{expression}` escaping —
// the component NEVER sets raw HTML, never runs a markdown parser,
// and never loads a sanitizer (REQ-READ-002 AC 2).
//
// Read-tracking (REQ-READ-003) runs inline in this page loader rather
// than through a separate API endpoint: a single atomic UPDATE
// user-scoped via a subquery flips `articles.read_at` from NULL to
// now() on the first view. Repeat views do nothing because the WHERE
// clause requires `read_at IS NULL`.

import type { APIContext } from 'astro';
import Base from '~/layouts/Base.astro';
import { loadSession } from '~/middleware/auth';
import { requireSettingsComplete } from '~/middleware/settings-gate';

interface DigestRow {
  id: string;
  user_id: string;
  local_date: string;
  generated_at: number;
  status: 'in_progress' | 'ready' | 'failed';
  error_code: string | null;
}

interface ArticleRow {
  id: string;
  digest_id: string;
  slug: string;
  source_url: string;
  title: string;
  one_liner: string;
  details_json: string;
  source_name: string | null;
  published_at: number | null;
  rank: number;
  read_at: number | null;
}

const env = Astro.locals.runtime.env;
if (typeof env.OAUTH_JWT_SECRET !== 'string' || env.OAUTH_JWT_SECRET === '') {
  return new Response('Application not configured', { status: 500 });
}

const session = await loadSession(Astro.request, env.DB, env.OAUTH_JWT_SECRET);
if (session === null) {
  return Astro.redirect('/api/auth/github/login', 303);
}
Astro.locals.user = session.user;

const gated = requireSettingsComplete({
  request: Astro.request,
  locals: Astro.locals,
} as unknown as APIContext);
if (gated !== null) {
  return gated;
}

const user = session.user;
const digestId = Astro.params['id'];
const slug = Astro.params['slug'];
if (typeof digestId !== 'string' || digestId === '') {
  return new Response('Not found', { status: 404 });
}
if (typeof slug !== 'string' || slug === '') {
  return new Response('Not found', { status: 404 });
}

// Enforce ownership: the digest must belong to the session user.
const digestRow = await env.DB.prepare(
  'SELECT id, user_id, local_date, generated_at, status, error_code FROM digests WHERE id = ?1 AND user_id = ?2',
)
  .bind(digestId, user.id)
  .first<DigestRow>();

if (digestRow === null) {
  return new Response('Not found', { status: 404 });
}

const articleRow = await env.DB.prepare(
  'SELECT id, digest_id, slug, source_url, title, one_liner, details_json, source_name, published_at, rank, read_at FROM articles WHERE digest_id = ?1 AND slug = ?2',
)
  .bind(digestId, slug)
  .first<ArticleRow>();

if (articleRow === null) {
  return new Response('Not found', { status: 404 });
}

// REQ-READ-003 AC 1+2+4 — atomic user-scoped UPDATE. The subquery
// prevents cross-user marking; `read_at IS NULL` makes the statement
// idempotent for re-visits.
if (articleRow.read_at === null) {
  const nowSec = Math.floor(Date.now() / 1000);
  try {
    await env.DB.prepare(
      'UPDATE articles SET read_at = ?1 WHERE id = ?2 AND digest_id IN (SELECT id FROM digests WHERE user_id = ?3) AND read_at IS NULL',
    )
      .bind(nowSec, articleRow.id, user.id)
      .run();
  } catch {
    // Read-tracking is best-effort; a failure here must not block the
    // detail view from rendering.
  }
}

// Parse the stored `details_json` array. The write path sanitizes and
// guarantees an array-of-3, but be defensive against malformed rows so
// a corrupt entry doesn't crash the render.
let details: string[] = [];
try {
  const parsed = JSON.parse(articleRow.details_json) as unknown;
  if (Array.isArray(parsed)) {
    details = parsed.filter((v): v is string => typeof v === 'string');
  }
} catch {
  details = [];
}

const transitionName = `card-${articleRow.slug}`;

// Reading-time estimate from the sum of detail-paragraph word counts.
// 220 wpm is the standard desk-reader rate; clamp to ≥1 minute so a
// very short article doesn't read "0 MIN".
function countWords(s: string): number {
  const t = s.trim();
  if (t === '') return 0;
  return t.split(/\s+/u).length;
}
const totalWords = details.reduce((acc, p) => acc + countWords(p), 0);
const readMinutes = Math.max(1, Math.ceil(totalWords / 220));

// Publish-date formatting. When the article has its own `published_at`
// fall back to the digest's generated_at. Render in the US editorial
// short style (APR 23, NOV 8). Pure display, no timezone affordances
// needed because the field is informational, not interactive.
const MONTHS = [
  'JAN', 'FEB', 'MAR', 'APR', 'MAY', 'JUN',
  'JUL', 'AUG', 'SEP', 'OCT', 'NOV', 'DEC'
];
function formatDate(unixSec: number): string {
  const d = new Date(unixSec * 1000);
  return `${MONTHS[d.getUTCMonth()]} ${d.getUTCDate()}`;
}
const publishedSec = articleRow.published_at ?? digestRow.generated_at;
const publishedLabel = formatDate(publishedSec);

// Display source: prefer the fan-out's source_name (minus the
// `feed:` namespace prefix), fall back to the outbound URL's host so
// a null source_name never leaves the metadata line empty. Inlined
// instead of a local function so tsc's null-narrowing on articleRow
// from the 404 guard above stays in scope.
const rawSource = articleRow.source_name ?? '';
let displaySource: string;
if (rawSource !== '') {
  displaySource = rawSource.startsWith('feed:')
    ? rawSource.slice('feed:'.length)
    : rawSource;
} else {
  try {
    displaySource = new URL(articleRow.source_url).host.replace(/^www\./, '');
  } catch {
    displaySource = '';
  }
}
---

<Base title={articleRow.title}>
  <article class="article-detail" data-article-detail>
    <nav class="article-detail__back" aria-label="Back navigation">
      <a href="/digest" class="article-detail__back-link" aria-label="Back to digest">
        <svg
          class="article-detail__back-icon"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          {/* MDI arrow-left — https://pictogrammers.com/library/mdi/icon/arrow-left/ */}
          <path d="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z" />
        </svg>
      </a>
    </nav>

    <header class="article-detail__header" transition:name={transitionName}>
      <h1 class="article-detail__title">{articleRow.title}</h1>
      <p class="article-detail__meta" aria-label="Article metadata">
        {
          displaySource !== '' && (
            <>
              <span class="article-detail__meta-item">{displaySource}</span>
              <span class="article-detail__meta-sep" aria-hidden="true">·</span>
            </>
          )
        }
        <span class="article-detail__meta-item">{publishedLabel}</span>
        <span class="article-detail__meta-sep" aria-hidden="true">·</span>
        <span class="article-detail__meta-item">{readMinutes} MIN READ</span>
      </p>
    </header>

    <div class="article-detail__body">
      {
        details.map((paragraph, i) => (
          <p
            class={`article-detail__paragraph${i === 0 ? ' article-detail__paragraph--lead' : ''}`}
          >
            {paragraph}
          </p>
        ))
      }
    </div>

    <a
      class="article-detail__source-link"
      href={articleRow.source_url}
      target="_blank"
      rel="noopener noreferrer"
    >
      Read at source &rarr;
    </a>
  </article>
</Base>

<style>
  /* Editorial reading surface: serif headline, small-caps metadata
     line, optical-sized body measure, drop-cap lead paragraph. The
     cumulative effect is "magazine" rather than "dashboard". */
  .article-detail {
    max-width: 680px;
    margin: 0 auto;
    padding: 1.5rem 0 3rem;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  /* Back arrow — icon-only, centred inside a tap-sized square. The
     MDI arrow-left glyph sits at the top-left of the reading column,
     giving a clear "leave this article" affordance without competing
     with the headline below. */
  .article-detail__back {
    display: flex;
  }
  .article-detail__back-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    min-width: 0;
    min-height: 0;
    margin-left: -8px;
    color: var(--text-muted);
    text-decoration: none;
    border-radius: 6px;
    transition: color 150ms var(--ease, ease), background 150ms var(--ease, ease);
  }
  .article-detail__back-link:hover {
    color: var(--text);
    background: var(--surface);
  }
  .article-detail__back-icon {
    display: block;
  }

  .article-detail__header {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .article-detail__title {
    margin: 0;
    font-family: var(--font-serif);
    /* 32 px anchor but we let it breathe vs the prior 700 weight by
       dropping to 600 and loosening tracking — hairline heavier glyphs
       read as "display" without shouting. */
    font-size: var(--text-2xl);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--text);
    text-wrap: balance;
  }

  .article-detail__meta {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .article-detail__meta-sep {
    opacity: 0.6;
  }

  .article-detail__body {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .article-detail__paragraph {
    margin: 0;
    max-width: 62ch;
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: 1.65;
    color: var(--text);
    /* Proper reading prose controls: allow hyphenation, ask the
       browser for a `pretty` wrap that avoids orphan lines. */
    hyphens: auto;
    -webkit-hyphens: auto;
    text-wrap: pretty;
  }

  /* Lead paragraph gets a drop cap. Plain float, no negative margins,
     no initial-letter trickery — browser implementations of both
     initial-letter and aggressive negative-margin alignment vary too
     much (Samsung WebKit sent the glyph flying above the metadata
     line). Here the letter occupies ~3 body lines naturally via
     line-height: 0.88 and drops cleanly. Cap-height sits a hair below
     the first running line; 1 px isn't worth fighting the rendering
     engine for. */
  .article-detail__paragraph--lead::first-letter {
    float: left;
    font-family: var(--font-serif);
    font-size: 3.2em;
    font-weight: 700;
    line-height: 0.82;
    /* No top padding — the lead cap's top edge aligns with the first
       running-text line's cap-height. A tiny negative margin-top pulls
       the visually-ascendant serif top in line with Inter's cap-height
       on the first body row. Tuned for Charter/Georgia; visible offset
       is ≤1 px across the stack. */
    margin: -0.02em 0.1em 0 0;
    color: var(--text);
  }

  /* Primary source link — stays solid-inverted like the other primary
     actions (Save, Refresh) so the CTA still feels "the button". */
  .article-detail__source-link {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    min-height: 44px;
    padding: 0.75rem 1.25rem;
    background-color: var(--text);
    color: var(--bg);
    border: 1px solid var(--text);
    border-radius: 0.375rem;
    font-weight: 600;
    text-decoration: none;
    margin-top: 0.5rem;
  }
  .article-detail__source-link:hover {
    opacity: 0.9;
  }
  .article-detail__source-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
</style>
