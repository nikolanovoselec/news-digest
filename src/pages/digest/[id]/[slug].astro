---
// Implements REQ-READ-002, REQ-READ-003
//
// Article detail view. Renders the article's title, each details
// paragraph as a <p>, and a prominent "Read at source" affordance.
// The label is ALWAYS "Read at source" (no "(+N)" suffix); the
// click behaviour branches: when the article was clustered from
// multiple sources (entries in `article_sources`) the button opens
// the <AltSourcesModal /> picker so the reader chooses which
// outlet to open; a single-source article is a direct link to
// primary_source_url.
//
// All text is rendered with Astro's default `{expression}` escaping —
// the component NEVER sets raw HTML, never runs a markdown parser,
// and never loads a sanitizer (REQ-READ-002 AC 2).
//
// Read-tracking (REQ-READ-003) runs inline in this page loader rather
// than through a separate API endpoint: a single atomic INSERT into
// `article_reads` is user-scoped and idempotent via PRIMARY KEY
// conflict (ON CONFLICT DO NOTHING).

import type { APIContext } from 'astro';
import Base from '~/layouts/Base.astro';
import AltSourcesModal from '~/components/AltSourcesModal.astro';
import { loadSession } from '~/middleware/auth';
import { requireSettingsComplete } from '~/middleware/settings-gate';
import { slugify } from '~/lib/slug';
import { splitIntoParagraphs } from '~/lib/paragraph-split';

interface ArticleRow {
  id: string;
  title: string;
  details_json: string;
  primary_source_name: string;
  primary_source_url: string;
  published_at: number;
  ingested_at: number;
}

interface AltSourceRow {
  source_name: string;
  source_url: string;
  published_at: number | null;
}

interface ReadRow {
  read_at: number;
}

interface StarRow {
  starred_at: number;
}

const env = Astro.locals.runtime.env;
if (typeof env.OAUTH_JWT_SECRET !== 'string' || env.OAUTH_JWT_SECRET === '') {
  return new Response('Application not configured', { status: 500 });
}

const session = await loadSession(Astro.request, env.DB, env.OAUTH_JWT_SECRET);
if (session === null) {
  return Astro.redirect('/api/auth/github/login', 303);
}
Astro.locals.user = session.user;

const gated = requireSettingsComplete({
  request: Astro.request,
  locals: Astro.locals,
} as unknown as APIContext);
if (gated !== null) {
  return gated;
}

const user = session.user;
const articleId = Astro.params['id'];
const slug = Astro.params['slug'];
if (typeof articleId !== 'string' || articleId === '') {
  return new Response('Not found', { status: 404 });
}
if (typeof slug !== 'string' || slug === '') {
  return new Response('Not found', { status: 404 });
}

// REQ-READ-002 — article lookup in the global pool. The row is NOT
// user-scoped (any authenticated user can view any article); per-user
// state (read, starred) is joined separately.
const articleRow = await env.DB.prepare(
  'SELECT id, title, details_json, primary_source_name, primary_source_url, published_at, ingested_at FROM articles WHERE id = ?1',
)
  .bind(articleId)
  .first<ArticleRow>();

if (articleRow === null) {
  return new Response('Not found', { status: 404 });
}

// Canonicalise slug against the title — if the URL slug doesn't match
// the title-derived slug, redirect to the canonical URL so that stale
// history links continue to work.
const canonicalSlug = slugify(articleRow.title);
if (slug !== canonicalSlug) {
  return Astro.redirect(`/digest/${articleId}/${canonicalSlug}`, 301);
}

// Load alternative sources, ordered by published_at ASC so the modal
// presents them chronologically. A null published_at sorts first.
const altSourcesResult = await env.DB.prepare(
  'SELECT source_name, source_url, published_at FROM article_sources WHERE article_id = ?1 ORDER BY published_at ASC',
)
  .bind(articleRow.id)
  .all<AltSourceRow>();
const altSourceRows: AltSourceRow[] = altSourcesResult.results ?? [];

// Filter out the primary row from alt-sources — the modal renders it
// once in the "primary" slot at the top of the list.
const altSources = altSourceRows.filter(
  (row) => row.source_url !== articleRow.primary_source_url,
);

// Per-user state — read + starred bools. Star button wire-up lives in
// the star-feature agent's follow-up commit; here we only expose the
// values so the page has them.
const readRow = await env.DB.prepare(
  'SELECT read_at FROM article_reads WHERE user_id = ?1 AND article_id = ?2',
)
  .bind(user.id, articleRow.id)
  .first<ReadRow>();
const alreadyRead = readRow !== null;

const starRow = await env.DB.prepare(
  'SELECT starred_at FROM article_stars WHERE user_id = ?1 AND article_id = ?2',
)
  .bind(user.id, articleRow.id)
  .first<StarRow>();
const isStarred = starRow !== null;

// REQ-READ-003 — idempotent read mark via INSERT OR IGNORE. Best-effort;
// a failure must not block the render.
if (!alreadyRead) {
  const nowSec = Math.floor(Date.now() / 1000);
  try {
    await env.DB.prepare(
      'INSERT OR IGNORE INTO article_reads (user_id, article_id, read_at) VALUES (?1, ?2, ?3)',
    )
      .bind(user.id, articleRow.id, nowSec)
      .run();
  } catch {
    // Read-tracking is best-effort; a failure here must not block the
    // detail view from rendering.
  }
}

// Parse the stored `details_json` array. The write path sanitizes and
// guarantees an array-of-1-to-3, but be defensive against malformed
// rows so a corrupt entry doesn't crash the render. Some legacy rows
// store paragraph breaks as a literal "\n" escape sequence rather than
// a real newline — splitIntoParagraphs normalises both forms.
let details: string[] = [];
try {
  const parsed = JSON.parse(articleRow.details_json) as unknown;
  if (Array.isArray(parsed)) {
    details = parsed
      .filter((v): v is string => typeof v === 'string')
      .flatMap((s) => splitIntoParagraphs(s));
  }
} catch {
  details = [];
}

const transitionName = `card-${canonicalSlug}`;

// Reading-time estimate from the sum of detail-paragraph word counts.
// 220 wpm is the standard desk-reader rate; clamp to ≥1 minute so a
// very short article doesn't read "0 MIN".
function countWords(s: string): number {
  const t = s.trim();
  if (t === '') return 0;
  return t.split(/\s+/u).length;
}
const totalWords = details.reduce((acc, p) => acc + countWords(p), 0);
const readMinutes = Math.max(1, Math.ceil(totalWords / 220));

// Publish-date formatting. Render in the US editorial short style
// (APR 23, NOV 8). Pure display, no timezone affordances needed
// because the field is informational, not interactive.
const MONTHS = [
  'JAN', 'FEB', 'MAR', 'APR', 'MAY', 'JUN',
  'JUL', 'AUG', 'SEP', 'OCT', 'NOV', 'DEC'
];
function formatDate(unixSec: number): string {
  const d = new Date(unixSec * 1000);
  return `${MONTHS[d.getUTCMonth()]} ${d.getUTCDate()}`;
}
const publishedSec = articleRow.published_at;
const publishedLabel = formatDate(publishedSec);

// Display source: prefer the primary_source_name (minus the `feed:`
// namespace prefix), fall back to the outbound URL's host so a null
// source_name never leaves the metadata line empty.
const rawSource = articleRow.primary_source_name;
let displaySource: string;
if (rawSource !== '') {
  displaySource = rawSource.startsWith('feed:')
    ? rawSource.slice('feed:'.length)
    : rawSource;
} else {
  try {
    displaySource = new URL(articleRow.primary_source_url).host.replace(/^www\./, '');
  } catch {
    displaySource = '';
  }
}

// Label is always plain "Read at source" — whether there's one
// source or many. Click behaviour diverges: single-source → direct
// navigation to primary_source_url; multi-source → open the
// <AltSourcesModal /> picker so the reader chooses which outlet to
// read. The '+N' count hint was removed per user request (it leaked
// implementation detail into what should just be a read affordance).
const readAtLabel = 'Read at source';

// Star/read state exposed to the template so the follow-up star-feature
// agent can wire the button without another data pass. Referenced
// below via data-* attributes.
const articleDataset = {
  read: alreadyRead ? '1' : '0',
  starred: isStarred ? '1' : '0',
};
---

<Base title={articleRow.title}>
  <article
    class="article-detail"
    data-article-detail
    data-article-id={articleRow.id}
    data-read={articleDataset.read}
    data-starred={articleDataset.starred}
  >
    <nav class="article-detail__back" aria-label="Back navigation">
      {/* Plain <a> keeps this working without JS (direct-link users
          land on the dashboard). The inline script below upgrades
          the href to a history.back() call when the user arrived
          via in-app navigation (search results, dashboard, /starred)
          — so "Back" actually returns to where they came from. */}
      <a href="/digest" class="article-detail__back-link" aria-label="Go back" data-article-back>
        <svg
          class="article-detail__back-icon"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          {/* MDI arrow-left — https://pictogrammers.com/library/mdi/icon/arrow-left/ */}
          <path d="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z" />
        </svg>
      </a>
    </nav>

    <header class="article-detail__header" transition:name={transitionName}>
      <h1 class="article-detail__title">{articleRow.title}</h1>
      <p class="article-detail__meta" aria-label="Article metadata">
        {
          displaySource !== '' && (
            <>
              <span class="article-detail__meta-item">{displaySource}</span>
              <span class="article-detail__meta-sep" aria-hidden="true">·</span>
            </>
          )
        }
        <span class="article-detail__meta-item">{publishedLabel}</span>
        <span class="article-detail__meta-sep" aria-hidden="true">·</span>
        <span class="article-detail__meta-item">{readMinutes} MIN READ</span>
        <span class="article-detail__meta-sep" aria-hidden="true">·</span>
        {/* Implements REQ-STAR-001 — star toggle at the end of the
            metadata line. Same optimistic toggle as the card button;
            aria-pressed starts at the server-rendered state. */}
        <button
          type="button"
          class="article-detail__star"
          data-star-toggle
          data-article-id={articleRow.id}
          aria-pressed={isStarred ? 'true' : 'false'}
          aria-label={isStarred ? 'Unstar this article' : 'Star this article'}
        >
          <svg
            class="article-detail__star-icon article-detail__star-icon--filled"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
          </svg>
          <svg
            class="article-detail__star-icon article-detail__star-icon--outline"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21 12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61z" />
          </svg>
        </button>
      </p>
    </header>

    <div class="article-detail__body">
      {
        details.map((paragraph, i) => (
          <p
            class={`article-detail__paragraph${i === 0 ? ' article-detail__paragraph--lead' : ''}`}
          >
            {paragraph}
          </p>
        ))
      }
    </div>

    {
      altSources.length === 0 ? (
        <a
          class="article-detail__source-link"
          href={articleRow.primary_source_url}
          target="_blank"
          rel="noopener noreferrer"
        >
          <span>{readAtLabel}</span>
          <svg
            class="article-detail__source-link-icon"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            {/* MDI arrow-right — https://pictogrammers.com/library/mdi/icon/arrow-right/ */}
            <path d="M4,11V13H16L10.5,18.5L11.92,19.92L19.84,12L11.92,4.08L10.5,5.5L16,11H4Z" />
          </svg>
        </a>
      ) : (
        <button
          type="button"
          class="article-detail__source-link"
          data-alt-sources-trigger
        >
          <span>{readAtLabel}</span>
          <svg
            class="article-detail__source-link-icon"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            {/* MDI arrow-right — https://pictogrammers.com/library/mdi/icon/arrow-right/ */}
            <path d="M4,11V13H16L10.5,18.5L11.92,19.92L19.84,12L11.92,4.08L10.5,5.5L16,11H4Z" />
          </svg>
        </button>
      )
    }
  </article>
  {
    altSources.length >= 1 && (
      <AltSourcesModal
        primarySourceName={displaySource !== '' ? displaySource : articleRow.primary_source_name}
        primarySourceUrl={articleRow.primary_source_url}
        primaryPublishedAt={publishedSec}
        altSources={altSources}
      />
    )
  }
</Base>

<style>
  /* Editorial reading surface: serif headline, small-caps metadata
     line, optical-sized body measure, drop-cap lead paragraph. The
     cumulative effect is "magazine" rather than "dashboard". */
  .article-detail {
    max-width: 680px;
    margin: 0 auto;
    padding: 1.5rem 0 3rem;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  /* Back arrow — icon-only, centred inside a tap-sized square. The
     MDI arrow-left glyph sits at the top-left of the reading column,
     giving a clear "leave this article" affordance without competing
     with the headline below. */
  .article-detail__back {
    display: flex;
  }
  .article-detail__back-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    min-width: 0;
    min-height: 0;
    margin-left: -8px;
    color: var(--text-muted);
    text-decoration: none;
    border-radius: 6px;
    transition: color 150ms var(--ease, ease), background 150ms var(--ease, ease);
  }
  .article-detail__back-link:hover {
    color: var(--text);
    background: var(--surface);
  }
  .article-detail__back-icon {
    display: block;
  }

  .article-detail__header {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .article-detail__title {
    margin: 0;
    font-family: var(--font-serif);
    /* 32 px anchor but we let it breathe vs the prior 700 weight by
       dropping to 600 and loosening tracking — hairline heavier glyphs
       read as "display" without shouting. */
    font-size: var(--text-2xl);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--text);
    text-wrap: balance;
  }

  .article-detail__meta {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .article-detail__meta-sep {
    opacity: 0.6;
  }

  .article-detail__body {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .article-detail__paragraph {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: 1.65;
    color: var(--text);
    /* Proper reading prose controls: allow hyphenation, ask the
       browser for a `pretty` wrap that avoids orphan lines. */
    hyphens: auto;
    -webkit-hyphens: auto;
    text-wrap: pretty;
  }

  /* Lead paragraph drop cap — plain float, no initial-letter.
     Samsung Browser implements `initial-letter` but with a
     size/position offset that floats the cap visibly above line 1
     on mobile (reported via screenshot). Chromium, Safari, and
     Firefox each have their own quirks with the property too.
     Skip the spec path entirely and hand-tune a float so every
     browser lands the cap in the same place.

     Geometry target:
       - cap-top aligns with line 1's cap-top (not the line-box top)
       - baseline sits on line 2's baseline
       - spans 2 body lines total

     Math (body line-height 1.65, cap-height ≈ 0.7 × font-size):
       - line-1 cap-top sits ~0.49em below the paragraph top
         ((1.65 - 1)/2 half-leading + 0.15em ascender padding)
       - distance line-1 cap-top → line-2 baseline = 1.65 + 0.7
         = 2.35em of cap-height span
       - drop-cap font-size = 2.35 / 0.7 ≈ 3.4em
       - at line-height 1, drop-cap's ascender padding above cap is
         0.15 × 3.4 ≈ 0.51em
       - so float top = paragraph top + (body_cap_top − drop_cap_pad)
                      = 0 + (0.49 − 0.51) = ~-0.02em → margin-top: 0
       - in practice browsers round the font-metric layout by ±1-2px;
         margin-top 0 is the cleanest starting point and looked
         correct on desktop Chrome + Firefox. If this regresses on
         a specific browser, nudge margin-top in 0.02em steps. */
  .article-detail__paragraph--lead::first-letter {
    float: left;
    font-family: var(--font-serif);
    font-weight: 700;
    color: var(--text);
    font-size: 3.4em;
    line-height: 1;
    margin: 0 0.1em 0 0;
    padding: 0;
  }

  /* Primary source link — stays solid-inverted like the other primary
     actions (Save, Refresh) so the CTA still feels "the button". The
     same class is applied to both the <a> (single-source) and <button>
     (multi-source) variants so the affordance reads identically. */
  .article-detail__source-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    align-self: flex-start;
    min-height: 44px;
    padding: 0.75rem 1.25rem;
    background-color: var(--text);
    color: var(--bg);
    border: 1px solid var(--text);
    border-radius: 0.375rem;
    font-weight: 600;
    font-family: inherit;
    font-size: inherit;
    text-decoration: none;
    margin-top: 0.5rem;
    cursor: pointer;
  }
  .article-detail__source-link:hover {
    opacity: 0.9;
  }
  .article-detail__source-link-icon {
    display: block;
  }
  .article-detail__source-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* Star toggle sits inline at the end of the metadata line. Small,
     unobtrusive, muted by default; swaps filled vs outline via
     aria-pressed so the user sees their action stick. */
  .article-detail__star {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 0;
    min-height: 0;
    width: 28px;
    height: 28px;
    padding: 0;
    background: transparent;
    border: 0;
    border-radius: 4px;
    color: var(--text-muted);
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    transition: color 150ms var(--ease, ease), background 150ms var(--ease, ease);
  }
  .article-detail__star:hover {
    color: var(--text);
    background: var(--surface);
  }
  .article-detail__star[aria-pressed='true'] {
    color: var(--text);
  }
  .article-detail__star-icon {
    display: inline-flex;
  }
  .article-detail__star-icon--filled {
    display: none;
  }
  .article-detail__star[aria-pressed='true'] .article-detail__star-icon--filled {
    display: inline-flex;
  }
  .article-detail__star[aria-pressed='true'] .article-detail__star-icon--outline {
    display: none;
  }
</style>

<script>
  // Implements REQ-STAR-001 — inline handler for the metadata-line star
  // button. Attaches once per page via the
  // [data-star-detail-bound] sentinel; survives view transitions by
  // re-running on astro:page-load. The DigestCard script is NOT in
  // this page's graph (no cards render here), so we repeat the
  // minimal toggle handler instead of relying on that component.
  async function handleStarClick(button: HTMLButtonElement): Promise<void> {
    const articleId = button.dataset['articleId'];
    if (articleId === undefined || articleId === '') return;
    const wasPressed = button.getAttribute('aria-pressed') === 'true';
    const nextPressed = !wasPressed;
    button.setAttribute('aria-pressed', nextPressed ? 'true' : 'false');
    try {
      const res = await fetch(
        `/api/articles/${encodeURIComponent(articleId)}/star`,
        {
          method: nextPressed ? 'POST' : 'DELETE',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
        },
      );
      if (!res.ok) {
        button.setAttribute('aria-pressed', wasPressed ? 'true' : 'false');
      }
    } catch {
      button.setAttribute('aria-pressed', wasPressed ? 'true' : 'false');
    }
  }

  function init(): void {
    if (document.documentElement.dataset['starDetailBound'] === '1') return;
    document.documentElement.dataset['starDetailBound'] = '1';
    document.addEventListener('click', (e) => {
      const target = e.target;
      if (!(target instanceof Element)) return;
      const button = target.closest<HTMLButtonElement>('[data-star-toggle]');
      if (button === null) return;
      e.preventDefault();
      e.stopPropagation();
      void handleStarClick(button);
    }, true);
  }

  function teardown(): void {
    // The document-level `data-star-detail-bound` flag persists across
    // view transitions intentionally. The listener is added on
    // `document` so it survives DOM swaps; init() only runs once.
  }

  init();
  document.addEventListener('astro:page-load', init);
  document.addEventListener('astro:before-swap', teardown);

  // Back button — return to the exact previous page (search results,
  // dashboard, /starred, etc.) when the user arrived via in-app
  // navigation. Falls through to the plain href="/digest" when the
  // user direct-linked here (history.length === 1 or navigation type
  // is "reload") so the anchor stays a valid link without JS.
  function handleBackClick(this: HTMLAnchorElement, e: MouseEvent): void {
    // Don't override middle-click, cmd/ctrl-click, etc.
    if (e.button !== 0 || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) {
      return;
    }
    // Only hijack when there IS a back entry that's on our own origin.
    // document.referrer is the cheapest signal — the reliable hint
    // that the user came from another page on this site.
    const sameOrigin =
      document.referrer !== '' &&
      new URL(document.referrer).origin === window.location.origin;
    if (!sameOrigin) {
      return; // let the href="/digest" fallback do its job
    }
    e.preventDefault();
    window.history.back();
  }

  function bindBack(): void {
    const link = document.querySelector<HTMLAnchorElement>('[data-article-back]');
    if (link === null) return;
    if (link.dataset['backBound'] === '1') return;
    link.dataset['backBound'] = '1';
    link.addEventListener('click', handleBackClick);
  }
  bindBack();
  document.addEventListener('astro:page-load', bindBack);
</script>
