---
// Implements REQ-READ-001, REQ-READ-004, REQ-READ-005, REQ-READ-006
//
// Today's digest view. Three possible render states keyed off the
// `/api/digest/today` response:
//
//   1. `digest === null` or `digest.local_date !== today` and
//      `next_scheduled_at !== null` → pending-today banner variant.
//   2. `live === true` (digest.status === 'in_progress') → indeterminate
//      progress bar + 10 skeleton cards + footer elapsed clock; starts
//      the 5-second poll loop on mount.
//   3. `digest.status === 'ready'` → full card grid + cost footer.
//   4. `digest.status === 'failed'` → 303-redirect to /digest/failed.
//
// The page also handles the offline case (REQ-READ-006 AC 4) by
// rendering a `data-offline-banner` slot that the small inline script
// toggles based on `navigator.onLine`.

import type { APIContext } from 'astro';
import Base from '~/layouts/Base.astro';
import DigestCard from '~/components/DigestCard.astro';
import LoadingSkeleton from '~/components/LoadingSkeleton.astro';
import CostFooter from '~/components/CostFooter.astro';
import PendingBanner from '~/components/PendingBanner.astro';
import { loadSession } from '~/middleware/auth';
import { requireSettingsComplete } from '~/middleware/settings-gate';
import { localDateInTz } from '~/lib/tz';
import { GET as getToday } from '~/pages/api/digest/today';

interface DigestRow {
  id: string;
  user_id: string;
  local_date: string;
  generated_at: number;
  execution_ms: number | null;
  tokens_in: number | null;
  tokens_out: number | null;
  estimated_cost_usd: number | null;
  model_id: string;
  status: 'in_progress' | 'ready' | 'failed';
  error_code: string | null;
  trigger: string;
}

interface ArticleRow {
  id: string;
  digest_id: string;
  slug: string;
  source_url: string;
  title: string;
  one_liner: string;
  details_json: string;
  source_name: string | null;
  published_at: number | null;
  rank: number;
  read_at: number | null;
  /** REQ-GEN-005 AC 6 — validated subset of the user's hashtag list. */
  tags?: string[];
}

interface TodayResponse {
  digest: DigestRow | null;
  articles: ArticleRow[];
  live: boolean;
  next_scheduled_at: number | null;
}

const env = Astro.locals.runtime.env;
if (typeof env.OAUTH_JWT_SECRET !== 'string' || env.OAUTH_JWT_SECRET === '') {
  return new Response('Application not configured', { status: 500 });
}

const session = await loadSession(Astro.request, env.DB, env.OAUTH_JWT_SECRET);
if (session === null) {
  return Astro.redirect('/api/auth/github/login', 303);
}
Astro.locals.user = session.user;

const gated = requireSettingsComplete({
  request: Astro.request,
  locals: Astro.locals,
} as unknown as APIContext);
if (gated !== null) {
  return gated;
}

const user = session.user;

// Fetch today's digest + articles by invoking the /api/digest/today
// GET handler in-process. Calling the handler directly (rather than
// making a fetch to our own origin) avoids a subrequest roundtrip and
// keeps the auth scoping identical to browser navigation because the
// handler reads its own session from context.request.
let today: TodayResponse = {
  digest: null,
  articles: [],
  live: false,
  next_scheduled_at: null,
};
try {
  const res = await getToday({
    request: Astro.request,
    locals: Astro.locals,
    url: new URL(Astro.request.url),
  } as unknown as APIContext);
  if (res.ok) {
    today = (await res.json()) as TodayResponse;
  }
} catch {
  // Treat handler failures as "no digest yet" — the page still renders
  // with the pending banner so the user sees something useful.
}

// Determine "today" in the user's tz so we can compare against
// digest.local_date. REQ-READ-005 AC 2 — if the most recent digest's
// local_date is NOT today, the banner wins over any stale card grid.
const nowSec = Math.floor(Date.now() / 1000);
const todayLocal = localDateInTz(nowSec, user.tz);

// If TODAY's digest failed (REQ-READ-004 AC 5 + REQ-READ-006 AC 2),
// redirect to the dedicated failure page. A failed digest from a prior
// day is treated as "no digest for today" — the pending banner for the
// next scheduled run takes over.
if (
  today.digest !== null &&
  today.digest.status === 'failed' &&
  today.digest.local_date === todayLocal
) {
  const code = today.digest.error_code ?? 'llm_failed';
  return Astro.redirect(`/digest/failed?code=${encodeURIComponent(code)}`, 303);
}

const digest = today.digest;
const articles = today.articles;

// Parse the user's current hashtags for the inline tag strip at the top
// of the page. Empty array when not yet set — the strip renders an
// obvious "+ add" prompt and POSTs to /api/tags on submit.
let userTags: string[] = [];
if (user.hashtags_json !== null && user.hashtags_json !== '') {
  try {
    const parsed = JSON.parse(user.hashtags_json) as unknown;
    if (Array.isArray(parsed)) {
      userTags = parsed.filter((v): v is string => typeof v === 'string');
    }
  } catch {
    userTags = [];
  }
}

const isLive = digest !== null && digest.status === 'in_progress';
const isReadyToday =
  digest !== null &&
  digest.status === 'ready' &&
  digest.local_date === todayLocal;

// Banner is shown when there is no digest at all or the most recent
// one is from a prior day (REQ-READ-005 AC 2 / AC 4).
const showBanner = !isLive && !isReadyToday && today.next_scheduled_at !== null;
const firstEver = digest === null;

// Empty-result page per REQ-READ-006 AC 1: a ready digest with fewer
// than 3 articles redirects to the no-stories page.
if (isReadyToday && articles.length < 3) {
  return Astro.redirect('/digest/no-stories', 303);
}
---

<Base title="Today's digest">
  <section class="digest-page" data-digest-page>
    <div
      class="digest-page__offline"
      data-offline-banner
      role="status"
      hidden
    >
      You're offline — showing the last digest you viewed.
    </div>

    {/*
      Inline tag strip (REQ-SET-002). The sole editor for the user's
      hashtags — there is no tag configuration in /settings anymore.
      Empty state renders just the "+ add" pill which expands into an
      input on click.
    */}
    <div class="tag-strip" data-tag-strip>
      {userTags.map((tag) => {
        const display = '#' + tag;
        return (
          <button
            type="button"
            class="tag-chip"
            data-tag-chip
            data-tag={tag}
            aria-pressed="false"
            aria-label={`${tag} — click to filter, click again to deselect`}
          >
            <span class="tag-chip__label">{display}</span>
            <span
              class="tag-chip__remove"
              data-tag-remove
              role="button"
              tabindex="-1"
              aria-label={`Remove ${tag} from your hashtags`}
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" />
              </svg>
            </span>
          </button>
        );
      })}
      <button type="button" class="tag-add" data-tag-add aria-label="Add a hashtag">
        <span class="tag-add__plus" aria-hidden="true">+</span>
        <span class="tag-add__label">add</span>
      </button>
      <input
        type="text"
        class="tag-add-input"
        data-tag-add-input
        placeholder="type a tag"
        autocomplete="off"
        maxlength="33"
        hidden
      />
    </div>
    <p
      class="tag-strip__nomatch"
      data-tag-nomatch
      role="status"
      aria-live="polite"
      hidden
    >
      No stories match the selected tag(s). Click a selected tag to deselect.
    </p>

    <header class="digest-page__header">
      <h1 class="digest-page__title">Today's digest</h1>
      {/*
        A plain <button>, NOT a <form action="/api/digest/refresh">. If
        JS is slow to hydrate and the user clicks early, we used to see
        a full-page POST navigate to /api/digest/refresh — which the
        service worker's /api/* NetworkFirst rule then turned into a
        generic 404 on cache miss. The button-only variant means a click
        without JS is simply a no-op; the JS click handler fires fetch()
        and handles all response codes.
      */}
      <button
        type="button"
        class="digest-page__refresh-button"
        data-refresh-button
        disabled={isLive}
      >
        Refresh now
      </button>
    </header>

    {
      isLive && digest !== null && (
        <div class="digest-page__progress" data-progress aria-label="Generating digest">
          <div class="digest-page__progress-bar" role="progressbar" aria-valuetext="generating"></div>
        </div>
      )
    }

    {
      showBanner && today.next_scheduled_at !== null && (
        <PendingBanner
          nextScheduledAt={today.next_scheduled_at}
          tz={user.tz}
          firstEver={firstEver}
        />
      )
    }

    {
      isLive && digest !== null && (
        <div
          class="digest-page__grid"
          data-digest-grid
          data-digest-poll
          data-digest-id={digest.id}
          data-state="live"
        >
          {Array.from({ length: 10 }).map(() => <LoadingSkeleton />)}
        </div>
      )
    }

    {
      isReadyToday && digest !== null && (
        <div class="digest-page__grid" data-digest-grid data-state="ready">
          {articles.map((a, i) => (
            <DigestCard
              digestId={digest.id}
              slug={a.slug}
              title={a.title}
              oneLiner={a.one_liner}
              sourceName={a.source_name}
              tags={a.tags ?? []}
              index={i}
            />
          ))}
        </div>
      )
    }

    {
      isLive && digest !== null && (
        <div class="digest-page__live-footer" data-live-footer>
          <span data-elapsed-clock data-started-at={String(digest.generated_at)}>
            Generating… 0s elapsed
          </span>
        </div>
      )
    }

    {
      isReadyToday && digest !== null && (
        <CostFooter
          generatedAt={digest.generated_at}
          tz={user.tz}
          executionMs={digest.execution_ms}
          tokensIn={digest.tokens_in}
          tokensOut={digest.tokens_out}
          estimatedCostUsd={digest.estimated_cost_usd}
          modelId={digest.model_id}
        />
      )
    }
  </section>
</Base>

<script>
  // Implements REQ-READ-001 AC 4, REQ-READ-004, REQ-READ-006 AC 4
  //
  // Three responsibilities:
  //   1. Wire the Refresh form to POST /api/digest/refresh (JSON), then
  //      morph the button into a progress bar on 202 and reload to pick
  //      up the in-progress digest.
  //   2. Start the 5-second poll loop via digest-poll.ts when the page
  //      renders the live state (reload on ready, redirect on failed).
  //   3. Toggle the offline banner based on navigator.onLine.

  import { bindDigestPoll } from '~/scripts/digest-poll';

  interface RefreshResponse {
    digest_id?: string;
    status?: string;
    error?: string;
    code?: string;
    retry_after_seconds?: number;
  }

  async function handleRefresh(button: HTMLButtonElement): Promise<void> {
    button.disabled = true;
    let res: Response;
    try {
      res = await fetch('/api/digest/refresh', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
      });
    } catch {
      button.disabled = false;
      return;
    }

    if (res.status === 429) {
      // REQ-READ-006 AC 3 — rate-limited response sends the user to the
      // dedicated countdown page.
      let body: RefreshResponse = {};
      try {
        body = (await res.json()) as RefreshResponse;
      } catch {
        /* ignore */
      }
      const seconds =
        typeof body.retry_after_seconds === 'number' ? body.retry_after_seconds : 300;
      window.location.assign(`/rate-limited?seconds=${encodeURIComponent(seconds)}`);
      return;
    }

    if (res.status === 202 || res.status === 409) {
      // Reload — the server-rendered page picks up the in-progress
      // digest and starts the poll loop on the next render.
      window.location.reload();
      return;
    }

    // Other failures — re-enable the button so the user can retry.
    button.disabled = false;
  }

  function wireRefresh(): void {
    const button = document.querySelector<HTMLButtonElement>('[data-refresh-button]');
    if (button === null) return;
    if (button.dataset['bound'] === '1') return;
    button.dataset['bound'] = '1';
    button.addEventListener('click', () => {
      void handleRefresh(button);
    });
  }

  function wireOfflineBanner(): void {
    const banner = document.querySelector<HTMLElement>('[data-offline-banner]');
    const refreshButton = document.querySelector<HTMLButtonElement>(
      '[data-refresh-button]',
    );
    if (banner === null) return;
    const update = (): void => {
      const offline = !window.navigator.onLine;
      banner.hidden = !offline;
      if (refreshButton !== null) {
        if (offline) {
          refreshButton.disabled = true;
          refreshButton.title = 'You are offline';
        } else if (refreshButton.title === 'You are offline') {
          refreshButton.disabled = false;
          refreshButton.removeAttribute('title');
        }
      }
    };
    update();
    window.addEventListener('online', update);
    window.addEventListener('offline', update);
  }

  let pollCancel: (() => void) | null = null;

  function wireElapsedClock(): void {
    const el = document.querySelector<HTMLElement>('[data-elapsed-clock]');
    if (el === null) return;
    const startRaw = el.dataset['startedAt'];
    if (startRaw === undefined || startRaw === '') return;
    const startSec = Number.parseInt(startRaw, 10);
    if (Number.isNaN(startSec)) return;
    const update = (): void => {
      const diff = Math.max(0, Math.floor(Date.now() / 1000) - startSec);
      el.textContent = `Generating… ${diff}s elapsed`;
    };
    update();
    const handle = window.setInterval(update, 1000);
    el.dataset['elapsedHandle'] = String(handle);
  }

  function teardown(): void {
    if (pollCancel !== null) {
      pollCancel();
      pollCancel = null;
    }
    const el = document.querySelector<HTMLElement>('[data-elapsed-clock]');
    if (el !== null) {
      const raw = el.dataset['elapsedHandle'];
      if (raw !== undefined && raw !== '') {
        const handle = Number.parseInt(raw, 10);
        if (!Number.isNaN(handle)) window.clearInterval(handle);
      }
      el.dataset['elapsedHandle'] = '';
    }
  }

  function init(): void {
    wireRefresh();
    wireOfflineBanner();
    wireElapsedClock();
    const grid = document.querySelector<HTMLElement>('[data-digest-poll]');
    if (grid !== null) {
      pollCancel = bindDigestPoll();
    }

    wireTagStrip();
  }

  // --- Tag strip (top of page) --------------------------------------
  // Replace the entire hashtag list via POST /api/tags. On add/remove
  // the strip optimistically updates the DOM and fires the request in
  // the background. If the server rejects, the DOM reverts.

  function tagStripTags(strip: HTMLElement): string[] {
    return Array.from(
      strip.querySelectorAll<HTMLElement>('[data-tag-chip]'),
    ).map((el) => el.dataset['tag'] ?? '').filter((t) => t !== '');
  }

  function normaliseTag(raw: string): string {
    const s = raw.toLowerCase().trim().replace(/^#/, '');
    return s.replace(/[^a-z0-9-]/g, '');
  }

  async function saveTags(strip: HTMLElement, tags: string[]): Promise<boolean> {
    try {
      const res = await fetch('/api/tags', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify({ tags }),
      });
      return res.ok;
    } catch {
      return false;
    }
  }

  function renderTagChip(strip: HTMLElement, tag: string): HTMLElement {
    // Match the SSR chip markup in digest.astro so selected styling and
    // the remove affordance behave identically for dynamically-added chips.
    const chip = document.createElement('button');
    chip.type = 'button';
    chip.className = 'tag-chip';
    chip.dataset['tagChip'] = '';
    chip.dataset['tag'] = tag;
    chip.setAttribute('aria-pressed', 'false');
    chip.setAttribute('aria-label', `${tag} — click to filter, click again to deselect`);
    const label = document.createElement('span');
    label.className = 'tag-chip__label';
    label.textContent = '#' + tag;
    chip.appendChild(label);
    const remove = document.createElement('span');
    remove.className = 'tag-chip__remove';
    remove.dataset['tagRemove'] = '';
    remove.setAttribute('role', 'button');
    remove.setAttribute('tabindex', '-1');
    remove.setAttribute('aria-label', `Remove ${tag} from your hashtags`);
    remove.innerHTML =
      '<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">' +
      '<path d="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"/>' +
      '</svg>';
    chip.appendChild(remove);
    // Insert before the [data-tag-add] button so the "+ add" stays last.
    const addButton = strip.querySelector<HTMLButtonElement>('[data-tag-add]');
    if (addButton !== null) strip.insertBefore(chip, addButton);
    else strip.appendChild(chip);
    return chip;
  }

  /**
   * Show a tiny live-region message next to the tag strip. Auto-clears
   * after 3s. Used for over-cap and save-failure feedback so failed
   * optimistic adds don't disappear silently.
   */
  function showTagError(strip: HTMLElement, message: string): void {
    let region = strip.querySelector<HTMLElement>('[data-tag-error]');
    if (region === null) {
      region = document.createElement('span');
      region.className = 'tag-strip__error';
      region.setAttribute('role', 'status');
      region.setAttribute('aria-live', 'polite');
      region.dataset['tagError'] = '';
      strip.appendChild(region);
    }
    region.textContent = message;
    const clearId = window.setTimeout(() => {
      if (region !== null && region.textContent === message) {
        region.textContent = '';
      }
    }, 3000);
    region.dataset['clearTimeout'] = String(clearId);
  }

  function wireTagStrip(): void {
    const strip = document.querySelector<HTMLElement>('[data-tag-strip]');
    if (strip === null || strip.dataset['bound'] === '1') return;
    strip.dataset['bound'] = '1';

    const addButton = strip.querySelector<HTMLButtonElement>('[data-tag-add]');
    const input = strip.querySelector<HTMLInputElement>('[data-tag-add-input]');
    if (addButton === null || input === null) return;

    const reveal = (): void => {
      addButton.hidden = true;
      input.hidden = false;
      input.focus();
    };
    const hide = (): void => {
      input.value = '';
      input.hidden = true;
      addButton.hidden = false;
    };
    const MAX_TAGS = 20; // matches server MAX_HASHTAGS in api/settings.ts
    const commit = async (): Promise<void> => {
      const tag = normaliseTag(input.value);
      if (tag.length < 2 || tag.length > 32) {
        hide();
        return;
      }
      const existing = tagStripTags(strip);
      if (existing.includes(tag)) {
        hide();
        return;
      }
      if (existing.length >= MAX_TAGS) {
        showTagError(strip, `Max ${MAX_TAGS} tags. Remove one first.`);
        hide();
        return;
      }
      const chip = renderTagChip(strip, tag);
      hide();
      const ok = await saveTags(strip, [...existing, tag]);
      if (!ok) {
        chip.remove();
        showTagError(strip, 'Could not save. Please try again.');
      }
    };

    addButton.addEventListener('click', reveal);
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        void commit();
      } else if (e.key === 'Escape') {
        e.preventDefault();
        hide();
      }
    });
    input.addEventListener('blur', () => {
      // Small delay so a click on a tag-remove inside the strip doesn't
      // race with the blur-close and leave the input stranded.
      setTimeout(() => {
        if (!input.hidden && document.activeElement !== input) hide();
      }, 150);
    });

    // REQ-SET-002 AC 2 + REQ-READ-001 AC 7:
    //   Click on the chip body         → toggle filter selection
    //   Click on the red × inside chip → delete the tag
    //   Selected chips filter the grid to articles whose tag list
    //   intersects the selection set; no selection = no filter.
    const applyFilter = (): void => {
      const selected = new Set<string>();
      strip
        .querySelectorAll<HTMLElement>('[data-tag-chip].is-selected')
        .forEach((el) => {
          const t = el.dataset['tag'];
          if (t !== undefined && t !== '') selected.add(t);
        });
      const cards = document.querySelectorAll<HTMLElement>('[data-digest-card]');
      let visible = 0;
      cards.forEach((card) => {
        if (selected.size === 0) {
          delete card.dataset['filterHide'];
          visible++;
          return;
        }
        const raw = card.dataset['tags'] ?? '';
        const cardTags = raw === '' ? [] : raw.split(',');
        const match = cardTags.some((t) => selected.has(t));
        if (match) {
          delete card.dataset['filterHide'];
          visible++;
        } else {
          card.dataset['filterHide'] = '1';
        }
      });
      const noMatch = document.querySelector<HTMLElement>('[data-tag-nomatch]');
      if (noMatch !== null) {
        noMatch.hidden = !(selected.size > 0 && visible === 0);
      }
    };

    strip.addEventListener('click', (e) => {
      const target = e.target as HTMLElement | null;
      if (target === null) return;
      // Red × → delete the tag, regardless of selection state.
      const removeHit = target.closest<HTMLElement>('[data-tag-remove]');
      if (removeHit !== null) {
        e.preventDefault();
        e.stopPropagation();
        const chip = removeHit.closest<HTMLElement>('[data-tag-chip]');
        if (chip === null) return;
        const tag = chip.dataset['tag'] ?? '';
        if (tag === '') return;
        if (tagStripTags(strip).length <= 1) {
          showTagError(strip, 'At least one tag is required.');
          return;
        }
        chip.remove();
        applyFilter();
        const remaining = tagStripTags(strip);
        void (async () => {
          const ok = await saveTags(strip, remaining);
          if (!ok) {
            renderTagChip(strip, tag);
            applyFilter();
            showTagError(strip, 'Could not save. Please try again.');
          }
        })();
        return;
      }
      // Chip body → toggle selection / filter.
      const chip = target.closest<HTMLElement>('[data-tag-chip]');
      if (chip === null) return;
      e.preventDefault();
      const tag = chip.dataset['tag'] ?? '';
      if (tag === '') return;
      const nowSelected = chip.classList.toggle('is-selected');
      chip.setAttribute('aria-pressed', nowSelected ? 'true' : 'false');
      applyFilter();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init, { once: true });
  } else {
    init();
  }
  document.addEventListener('astro:page-load', init);
  document.addEventListener('astro:before-swap', teardown);
</script>

<style>
  .digest-page {
    max-width: 1120px;
    margin: 0 auto;
    padding: 1rem 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .digest-page__offline {
    padding: 0.6rem 1rem;
    background-color: var(--surface);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    font-size: var(--text-sm);
  }

  .digest-page__offline[hidden] {
    display: none;
  }

  .digest-page__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .digest-page__title {
    margin: 0;
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--text);
  }

  .digest-page__refresh-button {
    min-height: 44px;
    padding: 0.5rem 1rem;
    background-color: var(--text);
    color: var(--bg);
    border: none;
    border-radius: 0.375rem;
    font-weight: 600;
    cursor: pointer;
  }

  .digest-page__refresh-button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .digest-page__progress {
    position: relative;
    height: 4px;
    background-color: var(--border);
