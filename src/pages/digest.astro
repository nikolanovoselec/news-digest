    padding: 0.25rem 0.75rem;
    background: var(--bg);
    color: var(--text-muted);
    border: 1px dashed var(--border);
    border-radius: 9999px;
    cursor: pointer;
    font-family: inherit;
    font-size: var(--text-sm);
    font-weight: 500;
    flex-shrink: 0;
