---
// Implements REQ-READ-001
// Implements REQ-READ-005
//
// Today's digest view — global article pool filtered by the user's
// active hashtags. The every-4-hours scrape_run populates the pool; this
// page renders the 50 newest articles whose tags intersect the user's
// tag set, plus a countdown header ("Last updated at HH:MM" in the
// page comment, shown on-screen as "Next update in Xm" or "Xh Ym"
// aligned to the right end of the title row — wraps below on narrow
// viewports).
//
// The page is server-rendered in-process via loadTodayPayload — no
// subrequest roundtrip. The tag-strip filter is preserved unchanged.
// Empty state: "No news for you today, try adding additional tags."

import type { APIContext } from 'astro';
import Base from '~/layouts/Base.astro';
import DigestCard from '~/components/DigestCard.astro';
import TagStrip from '~/components/TagStrip.astro';
import { loadSession } from '~/middleware/auth';
import { requireSettingsComplete } from '~/middleware/settings-gate';
import { loadTodayPayload } from '~/pages/api/digest/today';
import { localDateInTz, DEFAULT_TZ, isValidTz } from '~/lib/tz';
import { parseHashtags } from '~/lib/hashtags';

const env = Astro.locals.runtime.env;
if (typeof env.OAUTH_JWT_SECRET !== 'string' || env.OAUTH_JWT_SECRET === '') {
  return new Response('Application not configured', { status: 500 });
}

const session = await loadSession(Astro.request, env.DB, env.OAUTH_JWT_SECRET);
if (session === null) {
  return Astro.redirect('/', 303);
}
// CF-010 — silent-refresh: attach the re-issued session cookie when
// loadSession says it's near expiry so plain page navigation extends
// the session per REQ-AUTH-002 AC 4.
for (const c of session.cookiesToSet) Astro.response.headers.append('Set-Cookie', c);
Astro.locals.user = session.user;

const gated = requireSettingsComplete({
  request: Astro.request,
  locals: Astro.locals,
} as unknown as APIContext);
if (gated !== null) {
  // The gate may emit a redirect; preserve the silent-refresh cookie.
  for (const c of session.cookiesToSet) gated.headers.append('Set-Cookie', c);
  return gated;
}

const user = session.user;

// Parse the user's active hashtags for the tag strip + the global-pool
// query.
const userTags = parseHashtags(user.hashtags_json);

// Fetch the dashboard payload in-process. loadTodayPayload returns
// articles + last_scrape_run + next_scrape_at in the same shape the
// /api/digest/today GET handler returns.
const today = await loadTodayPayload(env.DB, user.id, userTags);
const articles = today.articles;

// The countdown is computed client-side from next_scrape_at so the
// ticker stays accurate across the tab's lifetime. A "Last updated at
// HH:MM" label was retired alongside the minutes-only countdown — if
// it's ever reintroduced, import localHourMinuteInTz from ~/lib/tz
// and derive the HH:MM string from today.last_scrape_run.started_at.

// Set of user-active tags for filtering displayed article tags.
// Articles in the global pool can carry tags the current user does
// not have selected (the LLM tags broadly; cards inherit the full
// tag list from the article pool). Surfacing those would expose
// stale taxonomy (e.g. a recently-dropped default tag still cached
// from the LLM allowlist) on cards the user opens. Filter at render.
const userTagSet = new Set<string>(userTags);

// Per-tag article count for the tag-strip — drives the `[count]`
// affordance and the count-desc sort order. Tags with zero articles
// today render a blank count slot (tag strip CSS collapses the slot).
const tagCounts = new Map<string, number>();
for (const tag of userTags) tagCounts.set(tag, 0);
for (const a of articles) {
  for (const t of a.tags) {
    if (!tagCounts.has(t)) continue;
    tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
  }
}
const sortedUserTags = [...userTags].sort((a, b) => {
  const diff = (tagCounts.get(b) ?? 0) - (tagCounts.get(a) ?? 0);
  if (diff !== 0) return diff;
  return a.localeCompare(b);
});

// The dashboard grid caps at 29 real cards; slot 30 is a tile that
// deep-links to /history?date=<today-local>. Compute the user's local
// calendar date so the href resolves to today in their timezone.
// Fall back to DEFAULT_TZ when the persisted value is empty OR an
// invalid IANA zone (e.g. a renamed zone in a stale DB row) —
// localDateInTz wraps Intl.DateTimeFormat which throws on unknown
// zones and would 500 the whole dashboard.
const rawUserTz = user.tz === '' ? DEFAULT_TZ : user.tz;
const userTz = isValidTz(rawUserTz) ? rawUserTz : DEFAULT_TZ;
const todayLocalDate = localDateInTz(Math.floor(Date.now() / 1000), userTz);

// SSR the tag filter from `?tags=` so the initial HTML already
// reflects the user's active filter. Without this, the server
// renders every card visible, Astro's ClientRouter swaps that body
// in on back-nav, the View-Transitions snapshot captures the
// unfiltered layout, Astro's scrollTo(historyState.scrollY) lands
// on the wrong content, and the animation morphs between
// incompatible geometries (outgoing filtered → incoming unfiltered).
// Emitting the filter state server-side eliminates the entire race.
// Client-side `applyFilter()` still drives chip-toggle interactions.
const rawSelectedTags = Astro.url.searchParams.get('tags');
const selectedTagSet = new Set<string>(
  typeof rawSelectedTags === 'string' && rawSelectedTags !== ''
    ? rawSelectedTags
        .split(',')
        .map((t) => t.trim().toLowerCase())
        .filter((t) => t !== '')
    : [],
);
function isCardHidden(articleTags: readonly string[]): boolean {
  if (selectedTagSet.size === 0) return false;
  return !articleTags.some((t) => selectedTagSet.has(t));
}
---

<Base title="Your feed">
  <section class="digest-page" data-digest-page>
    {/* a11y: the visible "Today's digest" headline was removed in
        favour of the brand wordmark carrying the page-header role,
        but screen readers still need a single h1 per page so skip-
        to-heading navigation has somewhere to land. Visually hidden
        but exposed to the a11y tree. */}
    <h1 class="digest-page__a11y-title">Today's digest</h1>
    <div
      class="digest-page__offline"
      data-offline-banner
      role="status"
      hidden
    >
      You're offline — showing the last digest you viewed.
    </div>

    {/*
      Tag strip — shared component with Search & History (TagStrip.astro).
      Sole editor for the user's hashtags; no tag configuration in
      /settings anymore. Empty state renders just the "+ add" pill
      which expands into an input on click. Filter behaviour (click
      to toggle `is-selected`, + add, remove) is wired in the page
      script below against the data-* attributes the component ships.
    */}
    <TagStrip
      tags={sortedUserTags}
      counts={tagCounts}
      initialSelected={selectedTagSet}
      countNoun="articles today"
    />
    <p
      class="tag-strip__nomatch"
      data-tag-nomatch
      role="status"
      aria-live="polite"
      hidden
    >
      No stories match the selected tag(s). Click a selected tag to deselect.
    </p>

    {/* The "Today's digest" <h1> was dropped — the brand wordmark
        at the top-left now plays the page-header role, so a second
        <h1> below it felt redundant. Countdown is preserved as a
        lightweight line above the grid. */}
    <header class="digest-page__header">
      <p
        class="digest-page__meta"
        data-countdown
        data-next-at={String(today.next_scrape_at)}
      >
        <span
          class="digest-page__meta-label"
          data-countdown-header
        >Next update in </span><span class="digest-page__meta-countdown" data-countdown-text>…</span>
      </p>
    </header>

    {
      articles.length === 0 ? (
        <p class="digest-page__empty" data-empty>
          No news for you today, try adding additional tags.
        </p>
      ) : (
        <div class="digest-page__grid" data-digest-grid data-state="ready">
          {articles.map((a, i) => (
            <DigestCard
              digestId={a.id}
              articleId={a.id}
              slug={a.slug}
              title={a.title}
              oneLiner={a.details[0] ?? ''}
              sourceName={a.primary_source_name}
              sourceUrl={a.primary_source_url}
              tags={a.tags.filter((t) => userTagSet.has(t))}
              starred={a.starred}
              index={i}
              filterHide={isCardHidden(a.tags)}
            />
          ))}
          {/* REQ-READ-001 AC 5 — slot 30 deep-links to Search &
              History scoped to today. Tag filtering that reaches
              beyond the visible 29 happens on /history, not here. */}
          <a
            class="digest-page__more-card"
            data-digest-more-tile
            href={`/history?date=${todayLocalDate}`}
            aria-label="See all of today's articles in Search & History"
          >
            <svg
              class="digest-page__more-icon"
              viewBox="0 0 24 24"
              aria-hidden="true"
              fill="currentColor"
            >
              {/* MDI gradient-vertical — https://pictogrammers.com/library/mdi/icon/gradient-vertical/ */}
              <path d="M11,9H13V11H11V9M9,11H11V13H9V11M13,11H15V13H13V11M15,9H17V11H15V9M7,9H9V11H7V9M19,3H5A2,2 0 0,0 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5A2,2 0 0,0 19,3M9,18H7V16H9V18M13,18H11V16H13V18M17,18H15V16H17V18M19,11H17V13H19V15H17V13H15V15H13V13H11V15H9V13H7V15H5V13H7V11H5V5H19V11Z" />
            </svg>
          </a>
        </div>
      )
    }

  </section>
</Base>

<script>
  // Implements REQ-READ-001
  // Implements REQ-READ-007
  //
  // Three responsibilities:
  //   1. Tick the "Next update in Xm" (or "Xh Ym") countdown every 10s from
  //      the server-rendered next_scrape_at; refetch /api/digest/today
  //      when the countdown hits zero and re-render the header+grid.
  //   2. Toggle the offline banner based on navigator.onLine.
  //   3. Wire the tag-strip filter (add / remove / toggle-select);
  //      reorder selected chip to slot 0 via the shared FLIP cascade
  //      (REQ-READ-007) so the motion confirms the tap and the chip
  //      never "disappears" mid-flight.

  import { flipChipToFront, flipChipToPosition, isFlipLocked } from '~/lib/tag-railing-flip';

  let countdownHandle: number | null = null;

  function formatCountdown(seconds: number): string {
    if (seconds <= 0) return '0m';
    // Round up so the display ticks down to 0m at the actual boundary
    // rather than sitting on 0m for 59 seconds.
    const totalMinutes = Math.ceil(seconds / 60);
    if (totalMinutes < 60) return `${totalMinutes}m`;
    const h = Math.floor(totalMinutes / 60);
    const m = totalMinutes % 60;
    return `${h}h ${m}m`;
  }

  async function refetchAndReplace(): Promise<void> {
    try {
      const res = await fetch('/api/digest/today', {
        credentials: 'same-origin',
        headers: { Accept: 'application/json' },
      });
      if (!res.ok) return;
      const body = (await res.json()) as {
        last_scrape_run: { started_at: number } | null;
        next_scrape_at: number;
        articles: unknown[];
      };
      const el = document.querySelector<HTMLElement>('[data-countdown]');
      if (el !== null) {
        el.dataset['nextAt'] = String(body.next_scrape_at);
      }
      // If the article set changed, a full reload is the simplest way
      // to pick up the new server render — the page is lightweight and
      // this only fires once per hour.
      if (Array.isArray(body.articles)) {
        window.location.reload();
      }
    } catch {
      /* ignore — the next tick retries */
    }
  }

  function tickCountdown(): void {
    const el = document.querySelector<HTMLElement>('[data-countdown]');
    const textEl = document.querySelector<HTMLElement>('[data-countdown-text]');
    const headerEl = document.querySelector<HTMLElement>('[data-countdown-header]');
    if (el === null || textEl === null) return;
    // If we've been told a scrape is running (via data-running on the
    // countdown wrapper set by the status poll), skip the countdown
    // math entirely — the label ALREADY reads "Update in progress…".
    if (el.dataset['running'] === '1') return;
    const raw = el.dataset['nextAt'];
    if (raw === undefined || raw === '') return;
    const nextAt = Number.parseInt(raw, 10);
    if (Number.isNaN(nextAt)) return;
    const nowSec = Math.floor(Date.now() / 1000);
    const remaining = nextAt - nowSec;
    if (remaining <= 0) {
      textEl.textContent = '0m';
      // Fire a refetch exactly once; avoid a tight loop by bumping the
      // next-at forward by 60s so we don't refetch on every tick until
      // the real update lands.
      el.dataset['nextAt'] = String(nowSec + 60);
      void refetchAndReplace();
      return;
    }
    textEl.textContent = formatCountdown(remaining);
    if (headerEl !== null) headerEl.textContent = 'Next update in ';
  }

  async function pollScrapeStatus(): Promise<void> {
    try {
      const res = await fetch('/api/scrape-status', {
        credentials: 'same-origin',
        headers: { Accept: 'application/json' },
      });
      if (!res.ok) return;
      const body = (await res.json()) as {
        running: boolean;
        chunks_remaining?: number | null;
        chunks_total?: number | null;
      };
      const el = document.querySelector<HTMLElement>('[data-countdown]');
      const textEl = document.querySelector<HTMLElement>('[data-countdown-text]');
      const headerEl = document.querySelector<HTMLElement>('[data-countdown-header]');
      if (el === null || textEl === null || headerEl === null) return;
      if (body.running) {
        el.dataset['running'] = '1';
        // Split across the header + countdown spans so the
        // "in progress…" half inherits the bolded
        // .digest-page__meta-countdown style already used for the
        // countdown number, matching the "Next update in <2h 14m>"
        // treatment where the back half is visually emphasised.
        headerEl.textContent = 'Update ';
        textEl.textContent = 'in progress…';
      } else if (el.dataset['running'] === '1') {
        // Run just finished — pull in fresh articles + next_scrape_at.
        delete el.dataset['running'];
        void refetchAndReplace();
        tickCountdown();
      }
    } catch {
      /* poll silently; the next tick retries */
    }
  }

  function wireCountdown(): void {
    if (countdownHandle !== null) return;
    const el = document.querySelector<HTMLElement>('[data-countdown]');
    if (el === null) return;
    tickCountdown();
    void pollScrapeStatus();
    // Minute-only display → tick every 10s is enough; no need for 1Hz.
    // Also poll /api/scrape-status every 10s so the "Update in
    // progress" label appears/clears in near-real-time without
    // shipping a separate interval.
    countdownHandle = window.setInterval(() => {
      tickCountdown();
      void pollScrapeStatus();
    }, 10_000);
  }

  function wireOfflineBanner(): void {
    const banner = document.querySelector<HTMLElement>('[data-offline-banner]');
    if (banner === null) return;
    const update = (): void => {
      banner.hidden = window.navigator.onLine;
    };
    update();
    window.addEventListener('online', update);
    window.addEventListener('offline', update);
  }

  function teardown(): void {
    if (countdownHandle !== null) {
      window.clearInterval(countdownHandle);
      countdownHandle = null;
    }
  }

  function init(): void {
    // The astro:page-load listener below is bound to `document` and
    // survives ClientRouter navigations — meaning it ALSO fires when
    // the user lands on /history (which shares <TagStrip /> with
    // this page). Without a page-marker guard, init() would
    // re-attach a click handler to [data-tag-strip] on /history,
    // stomping on /history's own handler and silently cancelling
    // every chip toggle. data-digest-page is only present on this
    // route, so the check keeps /digest's bindings scoped to it.
    if (document.querySelector('[data-digest-page]') === null) return;
    wireCountdown();
    wireOfflineBanner();
    wireTagStrip();
  }

  // --- Tag strip (top of page) --------------------------------------
  // Replace the entire hashtag list via POST /api/tags. On add/remove
  // the strip optimistically updates the DOM and fires the request in
  // the background. If the server rejects, the DOM reverts.

  function tagStripTags(strip: HTMLElement): string[] {
    return Array.from(
      strip.querySelectorAll<HTMLElement>('[data-tag-chip]'),
    ).map((el) => el.dataset['tag'] ?? '').filter((t) => t !== '');
  }

  function normaliseTag(raw: string): string {
    const s = raw.toLowerCase().trim().replace(/^#/, '');
    return s.replace(/[^a-z0-9-]/g, '');
  }

  async function saveTags(tags: string[]): Promise<boolean> {
    try {
      const res = await fetch('/api/tags', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify({ tags }),
      });
      return res.ok;
    } catch {
      return false;
    }
  }

  function renderTagChip(strip: HTMLElement, tag: string): HTMLElement {
    const chip = document.createElement('button');
    chip.type = 'button';
    chip.className = 'tag-chip';
    chip.dataset['tagChip'] = '';
    chip.dataset['tag'] = tag;
    chip.dataset['count'] = '0';
    chip.setAttribute('aria-pressed', 'false');
    chip.setAttribute(
      'aria-label',
      `${tag} — 0 articles today. Click to filter, click again to deselect.`,
    );
    const label = document.createElement('span');
    label.className = 'tag-chip__label';
    const hash = document.createElement('span');
    hash.className = 'tag-chip__hash';
    hash.setAttribute('aria-hidden', 'true');
    hash.textContent = '#';
    label.appendChild(hash);
    label.appendChild(document.createTextNode(tag));
    chip.appendChild(label);

    const slot = document.createElement('span');
    slot.className = 'tag-chip__slot';
    slot.setAttribute('aria-hidden', 'true');
    const count = document.createElement('span');
    count.className = 'tag-chip__count';
    count.textContent = '';
    slot.appendChild(count);
    const remove = document.createElement('span');
    remove.className = 'tag-chip__remove';
    remove.dataset['tagRemove'] = '';
    remove.setAttribute('role', 'button');
    remove.setAttribute('tabindex', '-1');
    remove.setAttribute('aria-label', `Remove ${tag} from your hashtags`);
    // CF-032 — build SVG via DOM API instead of innerHTML. Inputs are
    // constants today, but the DOM-construction pattern is what we
    // want every contributor to reach for.
    const SVG_NS = 'http://www.w3.org/2000/svg';
    const svg = document.createElementNS(SVG_NS, 'svg');
    svg.setAttribute('width', '12');
    svg.setAttribute('height', '12');
    svg.setAttribute('viewBox', '0 0 24 24');
    svg.setAttribute('fill', 'currentColor');
    svg.setAttribute('aria-hidden', 'true');
    const path = document.createElementNS(SVG_NS, 'path');
    path.setAttribute(
      'd',
      'M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z',
    );
    svg.appendChild(path);
    remove.appendChild(svg);
    slot.appendChild(remove);
    chip.appendChild(slot);

    // The +add button was hoisted OUT of [data-tag-strip] and now
    // lives as a sibling under [data-tag-strip-wrap] so the strip's
    // mask-fade can't paint over it. That means the strip contains
    // ONLY chips — append the new chip to the end; the +add button
    // sits absolute-positioned on top of the right edge via CSS.
    // The old `strip.querySelector('[data-tag-add]')` always returned
    // null post-hoist and fell through to the same appendChild
    // anyway, but kept a misleading branch that would silently
    // mis-order anything non-chip added to the strip later.
    strip.appendChild(chip);
    return chip;
  }

  function showTagError(strip: HTMLElement, message: string): void {
    let region = strip.querySelector<HTMLElement>('[data-tag-error]');
    if (region === null) {
      region = document.createElement('span');
      region.className = 'tag-strip__error';
      region.setAttribute('role', 'status');
      region.setAttribute('aria-live', 'polite');
      region.dataset['tagError'] = '';
      strip.appendChild(region);
    }
    region.textContent = message;
    const clearId = window.setTimeout(() => {
      if (region !== null && region.textContent === message) {
        region.textContent = '';
      }
    }, 3000);
    region.dataset['clearTimeout'] = String(clearId);
  }

  function wireTagStrip(): void {
    const strip = document.querySelector<HTMLElement>('[data-tag-strip]');
    if (strip === null || strip.dataset['bound'] === '1') return;
    strip.dataset['bound'] = '1';

    // The +add button and its companion input were hoisted OUT of the
    // scrolling `[data-tag-strip]` and are now SIBLINGS of it under
    // `[data-tag-strip-wrap]` (so the mask-fade on the strip doesn't
    // paint them). Query the wrapper so we can still find them —
    // without this lookup, the null-guard below early-returns and the
    // whole strip click handler (tag-select + tag-remove) never binds.
    const wrap = strip.closest<HTMLElement>('[data-tag-strip-wrap]') ?? document;
    const addButton = wrap.querySelector<HTMLButtonElement>('[data-tag-add]');
    const input = wrap.querySelector<HTMLInputElement>('[data-tag-add-input]');
    if (addButton === null || input === null) return;

    const reveal = (): void => {
      addButton.hidden = true;
      input.hidden = false;
      input.focus();
    };
    const hide = (): void => {
      input.value = '';
      input.hidden = true;
      addButton.hidden = false;
    };
    // Keep in sync with MAX_HASHTAGS on the server (src/pages/api/settings.ts).
    // Bumped to 25 so the 20-default seed leaves real headroom for customs.
    const MAX_TAGS = 25;
    const commit = async (): Promise<void> => {
      const tag = normaliseTag(input.value);
      if (tag.length < 2 || tag.length > 32) {
        hide();
        return;
      }
      const existing = tagStripTags(strip);
      if (existing.includes(tag)) {
        hide();
        return;
      }
      if (existing.length >= MAX_TAGS) {
        showTagError(strip, `Max ${MAX_TAGS} tags. Remove one first.`);
        hide();
        return;
      }
      const chip = renderTagChip(strip, tag);
      hide();
      const ok = await saveTags([...existing, tag]);
      if (!ok) {
        chip.remove();
        showTagError(strip, 'Could not save. Please try again.');
      }
    };

    addButton.addEventListener('click', reveal);
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        void commit();
      } else if (e.key === 'Escape') {
        e.preventDefault();
        hide();
      }
    });
    input.addEventListener('blur', () => {
      setTimeout(() => {
        if (!input.hidden && document.activeElement !== input) hide();
      }, 150);
    });

    /** Sync selected tags into the URL via replaceState so browser
     *  Back from an article detail page (or a tab reload) restores
     *  the exact filter the user left. replaceState avoids clogging
     *  the history stack — each chip click overwrites the same entry
     *  rather than pushing a new one. */
    const syncUrlTags = (selected: string[]): void => {
      const url = new URL(window.location.href);
      if (selected.length > 0) {
        url.searchParams.set('tags', selected.join(','));
      } else {
        url.searchParams.delete('tags');
      }
      const next = url.pathname + (url.search === '' ? '' : url.search);
      if (next !== window.location.pathname + window.location.search) {
        window.history.replaceState({}, '', next);
      }
    };

    const applyFilter = (): void => {
      const selectedList: string[] = [];
      strip
        .querySelectorAll<HTMLElement>('[data-tag-chip].is-selected')
        .forEach((el) => {
          const t = el.dataset['tag'];
          if (t !== undefined && t !== '') selectedList.push(t);
        });
      const selected = new Set(selectedList);
      syncUrlTags(selectedList);
      const cards = document.querySelectorAll<HTMLElement>('[data-digest-card]');
      let visible = 0;
      cards.forEach((card) => {
        if (selected.size === 0) {
          delete card.dataset['filterHide'];
          visible++;
          return;
        }
        const raw = card.dataset['tags'] ?? '';
        const cardTags = raw === '' ? [] : raw.split(',');
        const match = cardTags.some((t) => selected.has(t));
        if (match) {
          delete card.dataset['filterHide'];
          visible++;
        } else {
          card.dataset['filterHide'] = '1';
        }
      });
      const noMatch = document.querySelector<HTMLElement>('[data-tag-nomatch]');
      if (noMatch !== null) {
        noMatch.hidden = !(selected.size > 0 && visible === 0);
      }
    };

    /** Hydrate the chip selection from the URL on load. Called
     *  before the first applyFilter() so the initial render reflects
     *  whatever tag filter the user had active when they left. */
    const hydrateFromUrl = (): void => {
      const raw = new URL(window.location.href).searchParams.get('tags');
      if (raw === null || raw === '') return;
      const tokens = new Set(
        raw.split(',').map((t) => t.trim()).filter((t) => t !== ''),
      );
      strip.querySelectorAll<HTMLElement>('[data-tag-chip]').forEach((chip) => {
        const tag = chip.dataset['tag'];
        if (tag !== undefined && tokens.has(tag)) {
          chip.classList.add('is-selected');
          chip.setAttribute('aria-pressed', 'true');
        }
      });
    };
    /** Pin selected chips to the front of the strip. On mobile the
     *  strip is horizontally scrollable and the browser resets the
     *  scroll to 0 on every navigation — if the user's selected
     *  chip lived at position 15, they'd have to scroll to find it
     *  again. Moving selected chips to scroll-position 0 means the
     *  filter is always visible without any re-scrolling. DOM
     *  reorder preserves each chip's state + event listeners. */
    const pinSelectedToFront = (): void => {
      const selected = Array.from(
        strip.querySelectorAll<HTMLElement>('[data-tag-chip].is-selected'),
      );
      // Insert in reverse at index 0 so the first selected chip ends
      // up leftmost — each insertBefore at firstChild pushes earlier
      // entries one slot to the right, so reversed iteration yields
      // the intended order-of-appearance. Uses insertBefore rather
      // than prepend because Astro's emitted Workers + DOM type
      // overlap pollutes ParentNode.prepend's overload resolution.
      for (let i = selected.length - 1; i >= 0; i -= 1) {
        strip.insertBefore(selected[i]!, strip.firstChild);
      }
    };

    hydrateFromUrl();
    pinSelectedToFront();
    applyFilter();

    strip.addEventListener('click', (e) => {
      const target = e.target as HTMLElement | null;
      if (target === null) return;
      // REQ-READ-007 AC 5 — drop taps received while a cascade is
      // mid-flight. Without this guard a rapid double-tap can flip a
      // chip's selected state twice while the FLIP transforms are
      // still settling, leaving data and DOM order desynced.
      if (isFlipLocked(strip)) {
        e.preventDefault();
        e.stopPropagation();
        return;
      }
      const removeHit = target.closest<HTMLElement>('[data-tag-remove]');
      if (removeHit !== null) {
        e.preventDefault();
        e.stopPropagation();
        const chip = removeHit.closest<HTMLElement>('[data-tag-chip]');
        if (chip === null) return;
        const tag = chip.dataset['tag'] ?? '';
        if (tag === '') return;
        if (tagStripTags(strip).length <= 1) {
          showTagError(strip, 'At least one tag is required.');
          return;
        }
        chip.remove();
        applyFilter();
        const remaining = tagStripTags(strip);
        void (async () => {
          const ok = await saveTags(remaining);
          if (!ok) {
            renderTagChip(strip, tag);
            applyFilter();
            showTagError(strip, 'Could not save. Please try again.');
          }
        })();
        return;
      }
      const chip = target.closest<HTMLElement>('[data-tag-chip]');
      if (chip === null) return;
      e.preventDefault();
      const tag = chip.dataset['tag'] ?? '';
      if (tag === '') return;
      const nowSelected = chip.classList.toggle('is-selected');
      chip.setAttribute('aria-pressed', nowSelected ? 'true' : 'false');
      if (nowSelected) {
        // REQ-READ-007 — cascade the chip to slot 0 with the FLIP
        // helper. The helper handles tap-pulse, in-flight lockout,
        // and scroll-position preservation (no auto-scroll on tap).
        // applyFilter runs immediately so the grid updates without
        // waiting on the animation; the visual cascade is chrome.
        void flipChipToFront(strip, chip);
      } else {
        // REQ-READ-007 AC 3 — unselect cascade. Slide the chip back
        // to its natural sort position (count-desc, alpha tiebreak)
        // among the non-selected chips. Walk other chips and find
        // the first one that should sort AFTER this chip; insertBefore
        // semantics: passing that node lands the chip immediately
        // before it. null beforeNode means append to end (lowest-
        // priority chip).
        const chipCount = Number.parseInt(chip.dataset['count'] ?? '0', 10);
        const chipTag = chip.dataset['tag'] ?? '';
        let beforeNode: HTMLElement | null = null;
        const allChips = strip.querySelectorAll<HTMLElement>('[data-tag-chip]');
        for (const other of allChips) {
          if (other === chip) continue;
          if (other.classList.contains('is-selected')) continue;
          const otherCount = Number.parseInt(other.dataset['count'] ?? '0', 10);
          const otherTag = other.dataset['tag'] ?? '';
          if (chipCount > otherCount) { beforeNode = other; break; }
          if (chipCount === otherCount && chipTag.localeCompare(otherTag) < 0) {
            beforeNode = other;
            break;
          }
        }
        void flipChipToPosition(strip, chip, beforeNode);
      }
      applyFilter();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init, { once: true });
  } else {
    init();
  }
  document.addEventListener('astro:page-load', init);
  document.addEventListener('astro:before-swap', teardown);
</script>

