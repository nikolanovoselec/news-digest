    position: absolute;
    right: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    -webkit-tap-highlight-color: transparent;
    transition:
      color 150ms var(--ease, ease),
      border-color 150ms var(--ease, ease),
      background 150ms var(--ease, ease);
  }
  .tag-add:hover {
    color: var(--text);
    border-color: var(--text);
    background: var(--surface);
  }
  .tag-add__plus {
    font-size: var(--text-lg);
    line-height: 1;
    font-weight: 400;
  }

  .tag-add-input {
    display: inline-flex;
    min-height: 32px;
    padding: 0.25rem 0.75rem;
    background: var(--bg);
    color: var(--text);
    border: 1px solid var(--text);
    border-radius: 9999px;
    font-size: var(--text-sm);
    font-weight: 500;
    outline: none;
    min-width: 140px;
  }

  .tag-strip__error {
    color: var(--text-muted);
    font-size: var(--text-sm);
    margin-left: 0.5rem;
    transition: opacity 0.2s ease;
  }
</style>
