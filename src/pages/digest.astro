    border-color: var(--text);
  }
  .tag-chip.is-selected .tag-chip__count {
    opacity: 0;
  }
  .tag-chip.is-selected .tag-chip__remove {
    opacity: 1;
    pointer-events: auto;
  }

  .tag-strip__nomatch {
    margin: 0 1rem 0.5rem;
    color: var(--text-muted);
    font-size: var(--text-sm);
  }
  .tag-strip__nomatch[hidden] {
    display: none;
  }

  .tag-add {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
