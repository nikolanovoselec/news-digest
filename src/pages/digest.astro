      min-height: 220px;
    }
    .digest-page__more-icon {
      width: 64px;
      height: 64px;
    }
  }
</style>

{/* Tag-strip styles are `is:global` because renderTagChip() builds
    chips via the DOM API (not Astro SSR), which means newly-added
    chips don't inherit the `data-astro-cid-*` attribute that scoped
    styles match on. Without is:global, fresh chips rendered post-add
    fell back to default button sizing and looked visibly bigger than
    the SSR'd ones until the next page reload. */}
<style is:global>
  /* Wrapper: establishes the positioning context for the floating
     + add button and the horizontal mask on the inner scroll area. */
  .tag-strip-wrap {
    position: relative;
  }
  .tag-strip {
    display: flex;
    flex-wrap: nowrap;
    gap: 0.5rem;
    align-items: center;
    padding: 0.25rem 1rem;
    /* Reserve space on the right for the absolutely-positioned + add
       button (~5rem incl. gap) so the last chip can scroll into view
       without sitting under the button permanently. */
    padding-right: 6rem;
    overflow-x: auto;
    overflow-y: visible;
    scroll-snap-type: x proximity;
    scrollbar-width: none;
    /* Mask the right edge: chips visibly fade to transparent as they
       approach the button, so they NEVER appear to overlap it. The
       button itself is a sibling outside this mask, so it renders
       crisp on top. This is the fix for the "tags scroll under +add"
       complaint — rendered masking is unaffected by z-index or
       sticky-position quirks. */
    mask-image: linear-gradient(
      to right,
      black 0,
      black calc(100% - 5rem),
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to right,
      black 0,
      black calc(100% - 5rem),
      transparent 100%
    );
  }
  /* Desktop layout — strip wraps, + add sits at end of flow instead
     of floating absolutely. Gate on viewport width, NOT input
     capability (hover: hover): Samsung Browser and other hybrid
     devices sometimes report hover:none on a wide desktop viewport,
     which left the absolute + add button anchored at `top: 50%` of
     a tall wrapped strip, landing it visibly in the middle of the
     card grid. Width-based gating is deterministic across browsers. */
  @media (min-width: 768px) {
    .tag-strip-wrap {
      position: static;
    }
    .tag-strip {
      flex-wrap: wrap;
      overflow: visible;
      padding-right: 1rem;
      mask-image: none;
      -webkit-mask-image: none;
    }
    .tag-add {
      position: static;
    }
  }
  .tag-strip::-webkit-scrollbar {
    display: none;
  }

  .tag-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    min-height: 32px;
    padding: 0.25rem 0.75rem;
    background: var(--surface);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 9999px;
    font-size: var(--text-sm);
    font-weight: 500;
    font-family: inherit;
    line-height: 1;
    letter-spacing: -0.005em;
    cursor: pointer;
    flex-shrink: 0;
    scroll-snap-align: start;
    -webkit-tap-highlight-color: transparent;
    transition:
      background 150ms var(--ease, ease),
      color 150ms var(--ease, ease),
      border-color 150ms var(--ease, ease),
      padding-right 150ms var(--ease, ease),
      gap 150ms var(--ease, ease);
  }
  .tag-chip:hover {
    border-color: var(--text-muted);
  }
  .tag-chip__label {
    display: inline-flex;
    align-items: baseline;
    gap: 0.15em;
    white-space: nowrap;
  }
  .tag-chip__hash {
    font-weight: 700;
    color: var(--text-muted);
    opacity: 0.8;
  }
  .tag-chip.is-selected .tag-chip__hash {
    color: var(--bg);
    opacity: 0.7;
  }
  .tag-chip[data-count='0']:not(.is-selected) {
    gap: 0;
    padding-right: 0.75rem;
  }
  .tag-chip[data-count='0']:not(.is-selected) .tag-chip__slot {
    width: 0;
    overflow: hidden;
  }

  .tag-chip__slot {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }
  .tag-chip__count,
  .tag-chip__remove {
    position: absolute;
    inset: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 0;
    min-height: 0;
    width: 100%;
    height: 100%;
    border-radius: 9999px;
    transition: opacity 150ms var(--ease, ease);
  }
  .tag-chip__count {
    /* Match the label's font-size so both sit on the same optical
       line. 11px was the prior value and rendered visibly lower than
       the tag text because the smaller glyph metrics offset the
       flex-center baseline. Using the same text-sm size as the label
       makes the count's baseline and the label's baseline identical. */
    font-size: var(--text-sm);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    line-height: 1;
    color: var(--text-muted);
    opacity: 1;
  }
  .tag-chip__remove {
    background: #dc2626;
    color: #fff;
    opacity: 0;
    pointer-events: none;
