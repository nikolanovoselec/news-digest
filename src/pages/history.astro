---
// Implements REQ-HIST-001
//
// /history — day-grouped list of the authenticated user's last 7 days
// of articles, plus per-day aggregates from the global `scrape_runs`
// table. Each day row expands via a native <details> element to reveal
// its tick list (every hourly run's timestamp, articles ingested,
// tokens, cost) followed by the article cards for that day.
//
// Data is loaded in-process from /api/history so the page never pays
// for a same-origin subrequest hop. The title ("History") stays as-is
// for this phase — a future phase may rename it to "Search & History"
// and add a live search box.

import type { APIContext } from 'astro';
import Base from '~/layouts/Base.astro';
import DigestCard from '~/components/DigestCard.astro';
import TagStrip from '~/components/TagStrip.astro';
import { loadSession } from '~/middleware/auth';
import { slugify } from '~/lib/slug';
import { GET as getHistory } from '~/pages/api/history';

interface WireArticle {
  id: string;
  title: string;
  primary_source_name: string | null;
  primary_source_url: string | null;
  published_at: number;
  details: string[];
  tags: string[];
}

interface DayGroup {
  local_date: string;
  article_count: number;
  articles: WireArticle[];
  // `ticks` (per-scrape-run detail) is still returned by /api/history
  // but no longer rendered — cumulative day-level tokens/cost below
  // replace it.
  day_tokens_in: number;
  day_tokens_out: number;
  day_cost_usd: number;
  day_articles_ingested: number;
}

interface HistoryResponse {
  days: DayGroup[];
}

const env = Astro.locals.runtime.env;
if (typeof env.OAUTH_JWT_SECRET !== 'string' || env.OAUTH_JWT_SECRET === '') {
  return new Response('Application not configured', { status: 500 });
}

const session = await loadSession(
  Astro.request,
  env.DB,
  env.OAUTH_JWT_SECRET,
);
if (session === null) {
  return Astro.redirect('/api/auth/github/login', 303);
}
Astro.locals.user = session.user;

// Fetch the day-grouped payload in-process. Same pattern as digest.astro:
// a direct handler call side-steps the subrequest hop that silently
// returns zero rows on the deployed Worker.
let data: HistoryResponse = { days: [] };
try {
  const res = await getHistory({
    request: Astro.request,
    locals: Astro.locals,
    url: new URL('/api/history', Astro.request.url),
  } as unknown as APIContext);
  if (res.ok) {
    data = (await res.json()) as HistoryResponse;
  }
} catch {
  data = { days: [] };
}

const days = data.days;

// Implements REQ-HIST-001 — deep-link support: /history?date=YYYY-MM-DD
// opens the matching day pre-expanded and filters the list to just
// that day so users arriving from the dashboard "see today" tile land
// on a focused single-day view. The back button strips the param and
// returns to the full 7-day list.
const rawDateParam = Astro.url.searchParams.get('date');
const dateParam =
  typeof rawDateParam === 'string' && /^\d{4}-\d{2}-\d{2}$/.test(rawDateParam)
    ? rawDateParam
    : null;
const deepLinkedDay =
  dateParam !== null ? days.find((d) => d.local_date === dateParam) ?? null : null;
const visibleDays = deepLinkedDay !== null ? [deepLinkedDay] : days;
const isFocused = deepLinkedDay !== null;

// Implements REQ-HIST-001 AC 4/7 — tag railing on Search & History.
// Reads ?tags=a,b,c to pre-select chips server-side; the client-side
// script wires click + URL sync + combined filter (tag AND search).
const rawTagsParam = Astro.url.searchParams.get('tags');
const initialSelectedTagSet = new Set<string>(
  typeof rawTagsParam === 'string' && rawTagsParam !== ''
    ? rawTagsParam.split(',').map((t) => t.trim()).filter((t) => t !== '')
    : [],
);

// User's active hashtags (from the session row) — drives the chip
// set. Parsing mirrors digest.astro.
const sessionUser = session.user;
let userTags: string[] = [];
if (sessionUser.hashtags_json !== null && sessionUser.hashtags_json !== '') {
  try {
    const parsed = JSON.parse(sessionUser.hashtags_json) as unknown;
    if (Array.isArray(parsed)) {
      userTags = parsed.filter((v): v is string => typeof v === 'string');
    }
  } catch {
    userTags = [];
  }
}

// Count tag occurrences across every article in the 7-day window so
// each chip can render its count (distinct from dashboard's today-
// scoped count — here we want the full search pool).
const tagCounts = new Map<string, number>();
for (const t of userTags) tagCounts.set(t, 0);
for (const day of days) {
  for (const a of day.articles) {
    for (const t of a.tags) {
      if (!tagCounts.has(t)) continue;
      tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
    }
  }
}
const sortedUserTags = [...userTags].sort((a, b) => {
  const diff = (tagCounts.get(b) ?? 0) - (tagCounts.get(a) ?? 0);
  if (diff !== 0) return diff;
  return a.localeCompare(b);
});

/** Comma-grouped integer, em-dash when null/undefined. */
function formatInt(n: number | null | undefined): string {
  if (n === null || n === undefined || !Number.isFinite(n)) return '\u2014';
  return Math.max(0, Math.round(n)).toLocaleString('en-US');
}

/** USD cost with sig-fig-aware decimal places, em-dash when null. */
function formatCostUsd(value: number | null | undefined): string {
  if (value === null || value === undefined || !Number.isFinite(value)) return '\u2014';
  if (value === 0) return '$0.00';
  const precise = Math.abs(value).toPrecision(value < 0.01 ? 2 : 3);
  const asNum = Number(precise);
  const fixed = asNum < 0.01 ? asNum.toFixed(4) : asNum.toFixed(2);
  return `$${fixed}`;
}

---

<!-- Implements REQ-HIST-001 -->
<Base title="Search & History">
  <section class="history">
    <header class="history__hero">
      {isFocused && (
        <a class="history__back" href="/history">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            {/* MDI arrow-left — https://pictogrammers.com/library/mdi/icon/arrow-left/ */}
            <path d="M20 11H7.83L13.42 5.41L12 4L4 12L12 20L13.41 18.59L7.83 13H20V11Z" />
          </svg>
          <span>Back to all days</span>
        </a>
      )}
      <h1 class="history__title">Search &amp; History</h1>
      {isFocused && (
        <p class="history__subtitle">Articles from {dateParam}.</p>
      )}
      {!isFocused && (
        <label class="history__search" aria-label="Search history">
          <input
            type="search"
            class="history__search-input"
            placeholder="Search titles and summaries…"
            data-history-search
            autocomplete="off"
            minlength="3"
          />
        </label>
      )}
    </header>

    {!isFocused && (
      <div class="history__tag-strip-host">
        <TagStrip
          tags={sortedUserTags}
          counts={tagCounts}
          initialSelected={initialSelectedTagSet}
          countNoun="articles in the last 7 days"
        />
      </div>
    )}

    {/* Flat grid of matching cards — same breakpoint math as
        .digest-page__grid on the dashboard so search results feel
        like a dashboard view filtered by query. Only visible when
        the search query has ≥3 characters; the day-grouped list
        below hides while this is showing. */}
    <div class="history__search-grid" data-search-grid hidden></div>
    <p class="history__search-empty" data-search-empty hidden aria-live="polite"></p>

    {
      visibleDays.length === 0 ? (
        <p class="history__empty" data-history-empty>
          {isFocused
            ? `No articles on ${dateParam}.`
            : 'No articles in the last 7 days.'}
        </p>
      ) : (
        <ol class="history__list" data-history-list>
          {visibleDays.map((day) => (
            <li class="history__day" data-history-day data-date={day.local_date}>
              <details class="history__details" open={isFocused}>
                <summary class="history__summary">
                  <span class="history__date">{day.local_date}</span>
                  <span class="history__sep" aria-hidden="true">·</span>
                  <span class="history__count">
                    {day.article_count} {day.article_count === 1 ? 'story' : 'stories'}
                  </span>
                  <span class="history__sep" aria-hidden="true">·</span>
                  <span class="history__tokens">
                    {formatInt(day.day_tokens_in + day.day_tokens_out)} tokens
                  </span>
                  <span class="history__sep" aria-hidden="true">·</span>
                  <span class="history__cost">{formatCostUsd(day.day_cost_usd)}</span>
                </summary>

                {/* Day body is just the article grid — per-tick scrape_run
                    details are now summarised cumulatively in the
                    summary row above (tokens + cost for the whole day).
                    Opening a day shows the articles directly. */}
                <div class="history__body">
                  {day.articles.length > 0 && (
                    <div class="history__grid" data-history-grid>
                      {day.articles.map((a, i) => (
                        <DigestCard
                          digestId={a.id}
                          slug={slugify(a.title)}
                          title={a.title}
                          oneLiner={a.details[0] ?? ''}
                          sourceName={a.primary_source_name}
                          sourceUrl={a.primary_source_url}
                          tags={a.tags}
                          index={i}
                        />
                      ))}
                    </div>
                  )}
                </div>
              </details>
            </li>
          ))}
        </ol>
      )
    }
  </section>
</Base>

<script>
  // Client-side search for the history page.
  //
  // When the query is ≥ 3 characters, matching articles render as a
  // flat grid at the top (same breakpoint math as .digest-page__grid
  // on the dashboard) and the day-grouped list below hides. Typing
  // below 3 characters (or clearing the query) restores the
  // day-grouped view instantly.
  //
  // Matching cards are CLONED into the flat grid (cheaper than
  // splicing the live DOM around; the scroll position stays put).
  // Clones have their `data-bound` flags stripped so the shared
  // `initCardInteractions` helper re-binds the star + tag-disclosure
  // click handlers on each clone. Without that rebind, the buttons
  // would be visually present but dead to taps.
  //
  // Lifecycle: rewire on every astro:page-load (View Transitions
  // rebuild the DOM), and tear down on every astro:before-swap so
  // the previous listener doesn't leak across navigations.
  import { initCardInteractions } from '~/scripts/card-interactions';

  const MIN_QUERY_LEN = 3;

  function initHistorySearch(): () => void {
    const input = document.querySelector<HTMLInputElement>(
      '[data-history-search]',
    );
    const searchGrid = document.querySelector<HTMLElement>('[data-search-grid]');
    const searchEmpty = document.querySelector<HTMLElement>('[data-search-empty]');
    const list = document.querySelector<HTMLElement>('[data-history-list]');
    const strip = document.querySelector<HTMLElement>('[data-tag-strip]');
    if (searchGrid === null || searchEmpty === null) {
      return () => {};
    }

    type CardEntry = { el: HTMLElement; haystack: string; tags: Set<string> };
    const cards: CardEntry[] = [];
    const source = document.querySelectorAll<HTMLElement>(
      '[data-history-list] [data-digest-card]',
    );
    for (const card of Array.from(source)) {
      const title =
        card.querySelector('.digest-card__title')?.textContent ?? '';
      const excerpt =
        card.querySelector('.digest-card__one-liner')?.textContent ?? '';
      const rawTags = card.dataset['tags'] ?? '';
      const tagSet = new Set(rawTags === '' ? [] : rawTags.split(','));
      cards.push({ el: card, haystack: (title + ' ' + excerpt).toLowerCase(), tags: tagSet });
    }

    /** Read the currently-selected tag chips from the DOM. */
    const readSelectedTags = (): string[] => {
      if (strip === null) return [];
      const out: string[] = [];
      strip.querySelectorAll<HTMLElement>('[data-tag-chip].is-selected').forEach((chip) => {
        const t = chip.dataset['tag'];
        if (t !== undefined && t !== '') out.push(t);
      });
      return out;
    };

    /** Sync q + tags into the URL via replaceState. Keeps the back
     *  stack clean — a user typing or clicking doesn't append per
     *  keystroke. The /api/auth/... paths and `date` param are
     *  preserved untouched. */
    const syncUrl = (qRaw: string, tags: string[]): void => {
      const url = new URL(window.location.href);
      if (qRaw.length >= MIN_QUERY_LEN) {
        url.searchParams.set('q', qRaw);
      } else {
        url.searchParams.delete('q');
      }
      if (tags.length > 0) {
        url.searchParams.set('tags', tags.join(','));
      } else {
        url.searchParams.delete('tags');
      }
      const next = url.pathname + (url.search === '' ? '' : url.search);
      if (next !== window.location.pathname + window.location.search) {
        window.history.replaceState({}, '', next);
      }
    };

    const apply = (): void => {
      const qRaw = input !== null ? input.value.trim() : '';
      const q = qRaw.toLowerCase();
      const searching = q.length >= MIN_QUERY_LEN;
      const selectedTags = readSelectedTags();
      const tagFiltering = selectedTags.length > 0;
      const selectedSet = new Set(selectedTags);
      syncUrl(qRaw, selectedTags);

      // No search AND no tag → restore day-grouped view.
      if (!searching && !tagFiltering) {
        searchGrid.innerHTML = '';
        searchGrid.hidden = true;
        searchEmpty.hidden = true;
        if (list !== null) list.hidden = false;
        return;
      }

      // Either filter active → flat grid of matches, day list hidden.
      // AND logic: a card must match the query (if searching) AND
      // share at least one tag with the selected set (if tag-filtering).
      if (list !== null) list.hidden = true;
      searchGrid.innerHTML = '';
      let matches = 0;
      for (const { el, haystack, tags } of cards) {
        if (searching && !haystack.includes(q)) continue;
        if (tagFiltering) {
          let any = false;
          for (const t of tags) {
            if (selectedSet.has(t)) { any = true; break; }
          }
          if (!any) continue;
        }
        const clone = el.cloneNode(true) as HTMLElement;
        clone
          .querySelectorAll<HTMLElement>('[data-bound="1"]')
          .forEach((b) => {
            b.removeAttribute('data-bound');
          });
        clone
          .querySelectorAll<HTMLElement>('[data-astro-transition-scope]')
          .forEach((scoped) => {
            scoped.removeAttribute('data-astro-transition-scope');
          });
        searchGrid.appendChild(clone);
        matches++;
      }
      searchGrid.hidden = false;
      if (matches === 0) {
        const parts: string[] = [];
        if (searching) parts.push(`"${qRaw}"`);
        if (tagFiltering) parts.push(selectedTags.map((t) => `#${t}`).join(' '));
        searchEmpty.textContent = `No articles match ${parts.join(' + ')}.`;
        searchEmpty.hidden = false;
      } else {
        searchEmpty.hidden = true;
      }
      initCardInteractions(searchGrid);
    };

    if (input !== null) {
      input.addEventListener('input', apply);
    }

    // Tag chip click handler — toggle is-selected and re-run the
    // combined filter. Bound DIRECTLY to the strip element (not via
    // document-level delegation). Earlier attempts to delegate from
    // `document` survived in theory but kept breaking in practice on
    // SPA return — most likely because the handler's closure over
    // `apply` / `input` got stale even with teardown in place. Binding
    // to the strip itself ties the handler's lifetime to the DOM node
    // it acts on: when the node is swapped out by ClientRouter, its
    // listeners go with it, no explicit teardown needed.
    const stripWrap = document.querySelector<HTMLElement>('[data-tag-strip-wrap]');
    const stripClickHandler = (e: Event): void => {
      const target = e.target;
      if (!(target instanceof Element)) return;
      // Remove (×) takes precedence — it sits inside the chip.
      const removeHit = target.closest<HTMLElement>('[data-tag-remove]');
      if (removeHit !== null) {
        e.preventDefault();
        e.stopPropagation();
        const chip = removeHit.closest<HTMLElement>('[data-tag-chip]');
        const tag = chip?.dataset['tag'];
        if (tag !== undefined && tag !== '') {
          void removeTag(tag);
        }
        return;
      }
      const chip = target.closest<HTMLElement>('[data-tag-chip]');
      if (chip === null) return;
      const wasSelected = chip.classList.contains('is-selected');
      chip.classList.toggle('is-selected', !wasSelected);
      chip.setAttribute('aria-pressed', wasSelected ? 'false' : 'true');
      if (!wasSelected) {
        const thisStrip = chip.closest<HTMLElement>('[data-tag-strip]');
        if (thisStrip !== null) {
          thisStrip.insertBefore(chip, thisStrip.firstChild);
        }
      }
      apply();
    };
    if (stripWrap !== null) {
      stripWrap.addEventListener('click', stripClickHandler);
    }

    // Hydrate from URL on load: restore q + tag selections so that
    // navigating back to /history?q=foo&tags=a,b brings the user to
    // the exact result set they left.
    const url = new URL(window.location.href);
    const urlQ = url.searchParams.get('q');
    const urlTags = url.searchParams.get('tags');
    let needsApply = false;
    if (input !== null && urlQ !== null && urlQ.length >= MIN_QUERY_LEN) {
      input.value = urlQ;
      needsApply = true;
    }
    if (urlTags !== null && urlTags !== '') {
      const set = new Set(urlTags.split(',').map((t) => t.trim()).filter(Boolean));
      if (strip !== null) {
        strip.querySelectorAll<HTMLElement>('[data-tag-chip]').forEach((chip) => {
          const tag = chip.dataset['tag'];
          if (tag !== undefined && set.has(tag)) {
            chip.classList.add('is-selected');
            chip.setAttribute('aria-pressed', 'true');
          }
        });
        // Pin the now-selected chips to the front so the user lands
        // on the filter chip(s) at scroll-position 0 without having
        // to scroll the mobile strip back to find them.
        const selected = Array.from(
          strip.querySelectorAll<HTMLElement>('[data-tag-chip].is-selected'),
        );
        for (let i = selected.length - 1; i >= 0; i -= 1) {
          strip.insertBefore(selected[i]!, strip.firstChild);
        }
      }
      needsApply = true;
    }
    if (needsApply) apply();

    return () => {
      if (input !== null) {
        input.removeEventListener('input', apply);
      }
      if (stripWrap !== null) {
        stripWrap.removeEventListener('click', stripClickHandler);
      }
    };
  }

  /** Read every tag currently rendered in the strip — the source of
   *  truth for the user's active hashtag list on this page. Used by
   *  addTag/removeTag to POST the NEW FULL list to /api/tags (which
   *  expects a replacement array, not a per-tag add/remove). Earlier
   *  versions here posted `{tag}` (singular) and DELETE'd a
   *  non-existent /api/tags/:tag route, so removals looked
   *  successful client-side but never persisted. */
  function currentStripTags(): string[] {
    const strip = document.querySelector<HTMLElement>('[data-tag-strip]');
    if (strip === null) return [];
    return Array.from(strip.querySelectorAll<HTMLElement>('[data-tag-chip]'))
      .map((chip) => chip.dataset['tag'] ?? '')
      .filter((t) => t !== '');
  }

  async function saveTagsList(tags: string[]): Promise<boolean> {
    try {
      const res = await fetch('/api/tags', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ tags }),
      });
      return res.ok;
    } catch {
      return false;
    }
  }

  /** Append `tag` to the user's list via POST /api/tags, then reload
   *  so the strip and per-tag counts reflect the new state. */
  async function addTag(tag: string): Promise<void> {
    const next = currentStripTags();
    if (!next.includes(tag)) next.push(tag);
    if (await saveTagsList(next)) window.location.reload();
  }

  /** Remove `tag` from the user's list. Posts the filtered array so
   *  the server UPDATE writes the authoritative new state. */
  async function removeTag(tag: string): Promise<void> {
    const next = currentStripTags().filter((t) => t !== tag);
    if (await saveTagsList(next)) window.location.reload();
  }

  /** Wire the "+ add" pill: reveal input, submit on Enter / blur,
   *  cancel on Escape. Mirrors the dashboard's add-tag UX. */
  function initTagAdd(): void {
    const addButton = document.querySelector<HTMLButtonElement>('[data-tag-add]');
    const addInput = document.querySelector<HTMLInputElement>('[data-tag-add-input]');
    if (addButton === null || addInput === null) return;
    if (addButton.dataset['addBound'] === '1') return;
    addButton.dataset['addBound'] = '1';
    const reveal = (): void => {
      addButton.hidden = true;
      addInput.hidden = false;
      addInput.focus();
    };
    const cancel = (): void => {
      addInput.value = '';
      addInput.hidden = true;
      addButton.hidden = false;
    };
    const submit = (): void => {
      const raw = addInput.value.trim().toLowerCase().replace(/^#/, '');
      if (raw === '') { cancel(); return; }
      void addTag(raw);
    };
    addButton.addEventListener('click', reveal);
    addInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') { e.preventDefault(); submit(); return; }
      if (e.key === 'Escape') { e.preventDefault(); cancel(); return; }
    });
    addInput.addEventListener('blur', () => {
      if (addInput.value.trim() === '') cancel();
      else submit();
    });
  }

  // Gate EVERY side effect on the same documentElement flag so
  // returning to /history via View Transitions cannot leak a fresh
  // input listener (the prior revision still re-ran the top-level
  // initHistorySearch() on module re-execution, which stacked one
  // dangling `apply` handler per return visit onto the detached
  // input).
  //
  // `teardown` is stashed on the documentElement so the document
  // listeners registered on the FIRST visit always see the CURRENT
  // teardown function, not a frozen module-1 closure.
  //
  // Pattern source: `src/scripts/card-interactions.ts` uses the same
  // cardOutsideClickBound flag for its document-level click handler.
  interface HistoryWin extends Window {
    __historySearchTeardown?: () => void;
  }
  const hwin = window as unknown as HistoryWin;

  function reinit(): void {
    if (typeof hwin.__historySearchTeardown === 'function') {
      hwin.__historySearchTeardown();
    }
    hwin.__historySearchTeardown = initHistorySearch();
    initTagAdd();
  }

  if (document.documentElement.dataset['historySearchBound'] !== '1') {
    document.documentElement.dataset['historySearchBound'] = '1';
    document.addEventListener('astro:before-swap', () => {
      if (typeof hwin.__historySearchTeardown === 'function') {
        hwin.__historySearchTeardown();
        delete hwin.__historySearchTeardown;
      }
    });
    document.addEventListener('astro:page-load', reinit);
    // First-load init — only runs once per full page load; subsequent
    // re-executions of this module on View-Transition returns are
    // handled by the astro:page-load listener above.
    reinit();
  }
</script>

<style>
  .history {
    max-width: 960px;
    margin: 0 auto;
    padding: 1.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .history__hero {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  /* Back button shown only in single-day deep-link mode. Strips
     ?date= and returns the user to the full 7-day history list. */
  .history__back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    align-self: flex-start;
    padding: 6px 12px 6px 8px;
    margin-bottom: 0.25rem;
    color: var(--text);
    text-decoration: none;
    font-size: var(--text-sm);
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
  }
  .history__back:hover {
    background: var(--bg);
    border-color: var(--accent);
    color: var(--accent);
  }
  .history__back:focus-visible {
    background: var(--bg);
    border-color: var(--accent);
    color: var(--accent);
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .history__title {
    margin: 0;
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--text);
  }

  .history__subtitle {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-base);
  }

  .history__search {
    display: flex;
  }

  /* Tag railing host on /history — the TagStrip component itself
     ships no margins, so the surrounding page owns the spacing. */
  .history__tag-strip-host {
    margin: 0.75rem 0 0.25rem;
  }

