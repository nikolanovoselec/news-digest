---
// Implements REQ-HIST-001
//
// /history - day-grouped list of the authenticated user's last 14 days
// of articles, plus per-day aggregates from the global `scrape_runs`
// table. Each day row expands via a native <details> element to reveal
// its tick list (every scrape run's timestamp, articles ingested,
// tokens, cost) followed by the article cards for that day.
//
// Data is loaded in-process from /api/history so the page never pays
// for a same-origin subrequest hop. The title ("History") stays as-is
// for this phase - a future phase may rename it to "Search & History"
// and add a live search box.

import Base from '~/layouts/Base.astro';
import DigestCard from '~/components/DigestCard.astro';
import TagStrip from '~/components/TagStrip.astro';
import { loadSessionForPage } from '~/middleware/auth';
import { slugify } from '~/lib/slug';
import { GET as getHistory, type WireArticle } from '~/pages/api/history';
import { parseHashtags } from '~/lib/hashtags';

interface DayGroup {
  local_date: string;
  article_count: number;
  articles: WireArticle[];
  // `ticks` (per-scrape-run detail) is returned by /api/history but
  // not rendered here - cumulative day-level tokens/cost below carry
  // the user-facing numbers.
  day_tokens_in: number;
  day_tokens_out: number;
  day_cost_usd: number;
  day_articles_ingested: number;
}

interface HistoryResponse {
  days: DayGroup[];
}

const env = Astro.locals.runtime.env;
if (typeof env.OAUTH_JWT_SECRET !== 'string' || env.OAUTH_JWT_SECRET === '') {
  return new Response('Application not configured', { status: 500 });
}

// CF-010 - silent-refresh: loadSessionForPage attaches near-expiry
// re-issued cookies and clear-cookie directives directly onto
// Astro.response.headers (REQ-AUTH-002 AC 4 / REQ-AUTH-008 AC 4).
const session = await loadSessionForPage(
  Astro.request,
  env,
  Astro.response.headers,
);
if (session.user === null) return Astro.redirect('/', 303);
Astro.locals.user = session.user;

// Fetch the day-grouped payload in-process. Same pattern as digest.astro:
// a direct handler call side-steps the subrequest hop that silently
// returns zero rows on the deployed Worker.
let data: HistoryResponse = { days: [] };
try {
  // CF-031: getHistory accepts Pick<APIContext, 'request' | 'locals'> so
  // the SSR caller hands in only what it actually has - no cast needed.
  const res = await getHistory({
    request: Astro.request,
    locals: Astro.locals,
  });
  if (res.ok) {
    data = (await res.json()) as HistoryResponse;
  }
} catch {
  data = { days: [] };
}

const days = data.days;

// Implements REQ-HIST-001 - deep-link support: /history?date=YYYY-MM-DD
// opens the matching day pre-expanded and filters the list to just
// that day so users arriving from the dashboard "see today" tile land
// on a focused single-day view. The back button strips the param and
// returns to the full 14-day list.
const rawDateParam = Astro.url.searchParams.get('date');
const dateParam =
  typeof rawDateParam === 'string' && /^\d{4}-\d{2}-\d{2}$/.test(rawDateParam)
    ? rawDateParam
    : null;
const deepLinkedDay =
  dateParam !== null ? days.find((d) => d.local_date === dateParam) ?? null : null;
const visibleDays = deepLinkedDay !== null ? [deepLinkedDay] : days;
const isFocused = deepLinkedDay !== null;

// Implements REQ-HIST-001 AC 4/7 - tag railing on Search & History.
// Reads ?tags=a,b,c to pre-select chips server-side; the client-side
// script wires click + URL sync + combined filter (tag AND search).
const rawTagsParam = Astro.url.searchParams.get('tags');
const initialSelectedTagSet = new Set<string>(
  typeof rawTagsParam === 'string' && rawTagsParam !== ''
    ? rawTagsParam
        .split(',')
        .map((t) => t.trim().toLowerCase())
        .filter((t) => t !== '')
    : [],
);

// SSR the filtered search-grid when tags are active. Without this,
// server-rendered HTML shows the day-grouped list and the client-
// script later hides it and populates the search-grid - which means
// the View-Transition snapshot and Astro's scrollTo(historyState)
// both operate on a layout the user never actually sees. On back-
// nav this broke scroll restoration and the transition animation.
// Iterate days + day.articles in the order /api/history returns them
// (ingested_at DESC per day, days newest-first) - same order the
// client-side clone path would produce when it walks the day-list
// DOM. Matching orders makes the client's `apply()` rebuild visually
// idempotent (the DOM gets wiped and rebuilt but looks identical).
const isFilteringByTag = initialSelectedTagSet.size > 0 && !isFocused;
const filteredArticles: WireArticle[] = [];
if (isFilteringByTag) {
  for (const day of days) {
    for (const a of day.articles) {
      const anyMatch = a.tags.some((t) =>
        initialSelectedTagSet.has(t.toLowerCase()),
      );
      if (anyMatch) filteredArticles.push(a);
    }
  }
}

// User's active hashtags (from the session row) - drives the chip set.
const sessionUser = session.user;
const userTags = parseHashtags(sessionUser.hashtags_json);

// Set of user-active tags for filtering displayed article tags so
// stale taxonomy (e.g. recently-dropped defaults still cached in the
// LLM allowlist) never surfaces on cards.
const userTagSet = new Set<string>(userTags);

// Count tag occurrences across every article in the 14-day window so
// each chip can render its count (distinct from dashboard's today-
// scoped count - here we want the full search pool).
const tagCounts = new Map<string, number>();
for (const t of userTags) tagCounts.set(t, 0);
for (const day of days) {
  for (const a of day.articles) {
    for (const t of a.tags) {
      if (!tagCounts.has(t)) continue;
      tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
    }
  }
}
const sortedUserTags = [...userTags].sort((a, b) => {
  const diff = (tagCounts.get(b) ?? 0) - (tagCounts.get(a) ?? 0);
  if (diff !== 0) return diff;
  return a.localeCompare(b);
});

/** Comma-grouped integer, em-dash when null/undefined. */
function formatInt(n: number | null | undefined): string {
  if (n === null || n === undefined || !Number.isFinite(n)) return '—';
  return Math.max(0, Math.round(n)).toLocaleString('en-US');
}

/** USD cost with sig-fig-aware decimal places, em-dash when null. */
function formatCostUsd(value: number | null | undefined): string {
  if (value === null || value === undefined || !Number.isFinite(value)) return '—';
  if (value === 0) return '$0.00';
  const precise = Math.abs(value).toPrecision(value < 0.01 ? 2 : 3);
  const asNum = Number(precise);
  const fixed = asNum < 0.01 ? asNum.toFixed(4) : asNum.toFixed(2);
  return `$${fixed}`;
}

---

<!-- Implements REQ-HIST-001 -->
<Base title="Search & History">
  <section class="history">
    <header class="history__hero">
      {isFocused && (
        <a class="history__back" href="/history">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            {/* MDI arrow-left - https://pictogrammers.com/library/mdi/icon/arrow-left/ */}
            <path d="M20 11H7.83L13.42 5.41L12 4L4 12L12 20L13.41 18.59L7.83 13H20V11Z" />
          </svg>
          <span>Back to all days</span>
        </a>
      )}
      <h1 class="history__title">Search &amp; History</h1>
      {isFocused && (
        <p class="history__subtitle">Articles from {dateParam}.</p>
      )}
      {!isFocused && (
        <label class="history__search" aria-label="Search history">
          <input
            type="search"
            class="history__search-input"
            placeholder="Search titles and summaries…"
            data-history-search
            autocomplete="off"
            minlength="3"
          />
        </label>
      )}
    </header>

    {!isFocused && (
      <div class="history__tag-strip-host">
        <TagStrip
          tags={sortedUserTags}
          counts={tagCounts}
          initialSelected={initialSelectedTagSet}
          countNoun="articles in the last 14 days"
        />
      </div>
    )}

    {/* Flat grid of matching cards - same breakpoint math as
        .digest-page__grid on the dashboard so search results feel
        like a dashboard view filtered by query. Pre-populated
        server-side when `?tags=` is active so View-Transition
        snapshots and scroll restore see the final rendered layout
        on back-nav. Client script keeps re-rendering this on live
        chip-toggle and search-input typing. */}
    <div
      class="history__search-grid"
      data-search-grid
      hidden={!isFilteringByTag}
    >
      {isFilteringByTag && filteredArticles.map((a) => (
        <DigestCard
          digestId={a.id}
          articleId={a.id}
          slug={slugify(a.title)}
          title={a.title}
          sourceName={a.primary_source_name}
          sourceUrl={a.primary_source_url}
          altCount={a.alt_source_count}
          oneLiner={a.details[0] ?? ''}
          tags={a.tags.filter((t) => userTagSet.has(t))}
          starred={a.starred}
        />
      ))}
    </div>
    <p
      class="history__search-empty"
      data-search-empty
      hidden={!(isFilteringByTag && filteredArticles.length === 0)}
      aria-live="polite"
    >
      {isFilteringByTag && filteredArticles.length === 0
        ? `No articles match ${[...initialSelectedTagSet].map((t) => `#${t}`).join(' ')}.`
        : ''}
    </p>

    {
      visibleDays.length === 0 ? (
        <p class="history__empty" data-history-empty>
          {isFocused
            ? `No articles on ${dateParam}.`
            : 'No articles in the last 14 days.'}
        </p>
      ) : (
        <ol class="history__list" data-history-list hidden={isFilteringByTag}>
          {visibleDays.map((day) => (
            <li class="history__day" data-history-day data-date={day.local_date}>
              <details class="history__details" open={isFocused}>
                <summary class="history__summary">
                  <span class="history__date">{day.local_date}</span>
                  <span class="history__sep" aria-hidden="true">·</span>
                  <span class="history__count">
                    {day.article_count} {day.article_count === 1 ? 'story' : 'stories'}
                  </span>
                  <span class="history__sep" aria-hidden="true">·</span>
                  <span class="history__tokens">
                    {formatInt(day.day_tokens_in + day.day_tokens_out)} tokens
                  </span>
                  <span class="history__sep" aria-hidden="true">·</span>
                  <span class="history__cost">{formatCostUsd(day.day_cost_usd)}</span>
                </summary>

                {/* Day body is just the article grid - per-tick scrape_run
                    details are now summarised cumulatively in the
                    summary row above (tokens + cost for the whole day).
                    Opening a day shows the articles directly. */}
                <div class="history__body">
                  {day.articles.length > 0 && (
                    <div class="history__grid" data-history-grid>
                      {day.articles.map((a, i) => (
                        <DigestCard
                          digestId={a.id}
                          slug={slugify(a.title)}
                          title={a.title}
                          oneLiner={a.details[0] ?? ''}
                          sourceName={a.primary_source_name}
                          sourceUrl={a.primary_source_url}
                          altCount={a.alt_source_count}
                          tags={a.tags.filter((t) => userTagSet.has(t))}
                          starred={a.starred}
                          index={i}
                          suppressTransition={isFilteringByTag}
                        />
                      ))}
                    </div>
                  )}
                </div>
              </details>
            </li>
          ))}
        </ol>
      )
    }
  </section>
</Base>

<script>
  // Page script body lives in src/scripts/bundled/history-page.ts so
  // oxlint can analyse it. Side-effect import — the module wires its
  // own listeners on load and on astro:page-load.
  import '~/scripts/bundled/history-page';
</script>

<style>
  .history {
    max-width: 960px;
    margin: 0 auto;
    padding: 1.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .history__hero {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  /* Back button shown only in single-day deep-link mode. Strips
     ?date= and returns the user to the full 14-day history list. */
  .history__back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    align-self: flex-start;
    padding: 6px 12px 6px 8px;
    margin-bottom: 0.25rem;
    color: var(--text);
    text-decoration: none;
    font-size: var(--text-sm);
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
  }
  .history__back:hover {
    background: var(--bg);
    border-color: var(--accent);
    color: var(--accent);
  }
  .history__back:focus-visible {
    background: var(--bg);
    border-color: var(--accent);
    color: var(--accent);
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .history__title {
    margin: 0;
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--text);
  }

  .history__subtitle {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-base);
  }

  .history__search {
    display: flex;
  }

  /* Tag railing host on /history - the TagStrip component itself
     ships no margins, so the surrounding page owns the spacing. */
  .history__tag-strip-host {
    margin: 0.75rem 0 0.25rem;
  }

  .history__search-input {
    width: 100%;
    min-height: 40px;
    padding: 0.4rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 0.375rem;
    background-color: var(--surface);
    color: var(--text);
    font-size: var(--text-base);
  }

  .history__search-input:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .history__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .history__day {
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    background-color: var(--surface);
    overflow: hidden;
  }

  .history__details > summary {
    list-style: none;
    cursor: pointer;
  }

  .history__details > summary::-webkit-details-marker {
    display: none;
  }

  .history__summary {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1rem;
    min-height: 44px;
    color: var(--text);
    font-variant-numeric: tabular-nums;
  }

  .history__summary:hover {
    background-color: var(--bg);
  }

  .history__date {
    font-weight: 600;
  }

  .history__sep {
    color: var(--text-muted);
  }

  .history__count,
  .history__tokens,
  .history__cost {
    color: var(--text-muted);
    font-size: var(--text-sm);
  }

  .history__body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 0.75rem 1rem 1.25rem;
    border-top: 1px solid var(--border);
  }

  .history__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.75rem;
    /* Bound the reflow that fires when `<details>` is force-opened
       inside the incoming document during a view-transition pre-swap.
       `contain: layout style` confines layout invalidation to the
       grid's box rather than escaping into the page root, which keeps
       snapshot capture cheap on history back-nav. */
    contain: layout style;
  }

  /* Search results grid - matches .digest-page__grid breakpoints so
     typing into Search looks like a dashboard view filtered by the
     query. 1 col on mobile, 2 from 768px, 3 from 1024px. */
  .history__search-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  .history__search-grid[hidden] {
    display: none;
  }
  @media (min-width: 768px) {
    .history__search-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.25rem;
    }
  }
  @media (min-width: 1024px) {
    .history__search-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .history__empty,
  .history__search-empty {
    margin: 0;
    padding: 2rem;
    color: var(--text-muted);
    text-align: center;
    border: 1px dashed var(--border);
    border-radius: 0.5rem;
  }
</style>
