---
// Implements REQ-HIST-001
//
// /history — day-grouped list of the authenticated user's last 7 days
// of articles, plus per-day aggregates from the global `scrape_runs`
// table. Each day row expands via a native <details> element to reveal
// its tick list (every hourly run's timestamp, articles ingested,
// tokens, cost) followed by the article cards for that day.
//
// Data is loaded in-process from /api/history so the page never pays
// for a same-origin subrequest hop. The title ("History") stays as-is
// for this phase — a future phase may rename it to "Search & History"
// and add a live search box.

import type { APIContext } from 'astro';
import Base from '~/layouts/Base.astro';
import DigestCard from '~/components/DigestCard.astro';
import { loadSession } from '~/middleware/auth';
import { slugify } from '~/lib/slug';
import { GET as getHistory } from '~/pages/api/history';

interface WireArticle {
  id: string;
  title: string;
  primary_source_name: string | null;
  primary_source_url: string | null;
  published_at: number;
  tags: string[];
}

interface WireTick {
  id: string;
  started_at: number;
  finished_at: number | null;
  articles_ingested: number;
  tokens_in: number;
  tokens_out: number;
  estimated_cost_usd: number;
  status: string;
}

interface DayGroup {
  local_date: string;
  article_count: number;
  articles: WireArticle[];
  ticks: WireTick[];
  day_tokens_in: number;
  day_tokens_out: number;
  day_cost_usd: number;
  day_articles_ingested: number;
}

interface HistoryResponse {
  days: DayGroup[];
}

const env = Astro.locals.runtime.env;
if (typeof env.OAUTH_JWT_SECRET !== 'string' || env.OAUTH_JWT_SECRET === '') {
  return new Response('Application not configured', { status: 500 });
}

const session = await loadSession(
  Astro.request,
  env.DB,
  env.OAUTH_JWT_SECRET,
);
if (session === null) {
  return Astro.redirect('/api/auth/github/login', 303);
}
Astro.locals.user = session.user;

// Fetch the day-grouped payload in-process. Same pattern as digest.astro:
// a direct handler call side-steps the subrequest hop that silently
// returns zero rows on the deployed Worker.
let data: HistoryResponse = { days: [] };
try {
  const res = await getHistory({
    request: Astro.request,
    locals: Astro.locals,
    url: new URL('/api/history', Astro.request.url),
  } as unknown as APIContext);
  if (res.ok) {
    data = (await res.json()) as HistoryResponse;
  }
} catch {
  data = { days: [] };
}

const days = data.days;

/** Comma-grouped integer, em-dash when null/undefined. */
function formatInt(n: number | null | undefined): string {
  if (n === null || n === undefined || !Number.isFinite(n)) return '\u2014';
  return Math.max(0, Math.round(n)).toLocaleString('en-US');
}

/** USD cost with sig-fig-aware decimal places, em-dash when null. */
function formatCostUsd(value: number | null | undefined): string {
  if (value === null || value === undefined || !Number.isFinite(value)) return '\u2014';
  if (value === 0) return '$0.00';
  const precise = Math.abs(value).toPrecision(value < 0.01 ? 2 : 3);
  const asNum = Number(precise);
  const fixed = asNum < 0.01 ? asNum.toFixed(4) : asNum.toFixed(2);
  return `$${fixed}`;
}

/** HH:MM formatting for a Unix timestamp (UTC). The user's tz is only
 *  meaningful at the day-grouping level — inside a day, per-tick times
 *  are already scoped to that day so HH:MM UTC is unambiguous enough for
 *  this view. */
function formatHourMinute(unixSeconds: number): string {
  const d = new Date(unixSeconds * 1000);
  const hh = String(d.getUTCHours()).padStart(2, '0');
  const mm = String(d.getUTCMinutes()).padStart(2, '0');
  return `${hh}:${mm}`;
}
---

<!-- Implements REQ-HIST-001 -->
<Base title="Search & History">
  <section class="history">
    <header class="history__hero">
      <h1 class="history__title">Search &amp; History</h1>
      <p class="history__subtitle">The last 7 days of articles matching your tags.</p>
      <label class="history__search" aria-label="Search history">
        <input
          type="search"
          class="history__search-input"
          placeholder="Search titles and summaries…"
          data-history-search
          autocomplete="off"
        />
      </label>
    </header>

    {
      days.length === 0 ? (
        <p class="history__empty" data-history-empty>
          No articles in the last 7 days.
        </p>
      ) : (
        <ol class="history__list" data-history-list>
          {days.map((day) => (
            <li class="history__day" data-history-day data-date={day.local_date}>
              <details class="history__details">
                <summary class="history__summary">
                  <span class="history__date">{day.local_date}</span>
                  <span class="history__sep" aria-hidden="true">·</span>
                  <span class="history__count">
                    {day.article_count} {day.article_count === 1 ? 'story' : 'stories'}
                  </span>
                  <span class="history__sep" aria-hidden="true">·</span>
                  <span class="history__tokens">
                    {formatInt(day.day_tokens_in + day.day_tokens_out)} tokens
                  </span>
                  <span class="history__sep" aria-hidden="true">·</span>
                  <span class="history__cost">{formatCostUsd(day.day_cost_usd)}</span>
                </summary>

                <div class="history__body">
                  {day.ticks.length > 0 && (
                    <ul class="history__ticks" aria-label="Scrape runs for this day">
                      {day.ticks.map((tick) => (
                        <li class="history__tick" data-history-tick data-status={tick.status}>
                          <span class="history__tick-time">{formatHourMinute(tick.started_at)}</span>
                          <span class="history__tick-ingested">
                            {formatInt(tick.articles_ingested)} ingested
                          </span>
                          <span class="history__tick-tokens">
                            {formatInt(tick.tokens_in + tick.tokens_out)} tokens
                          </span>
                          <span class="history__tick-cost">
                            {formatCostUsd(tick.estimated_cost_usd)}
                          </span>
                          <span class="history__tick-status">{tick.status}</span>
                        </li>
                      ))}
                    </ul>
                  )}

                  {day.articles.length > 0 && (
                    <div class="history__grid" data-history-grid>
                      {day.articles.map((a, i) => (
                        <DigestCard
                          digestId={a.id}
                          slug={slugify(a.title)}
                          title={a.title}
                          oneLiner={a.details[0] ?? ''}
                          sourceName={a.primary_source_name}
                          sourceUrl={a.primary_source_url}
                          tags={a.tags}
                          index={i}
                        />
                      ))}
                    </div>
                  )}
                </div>
              </details>
            </li>
          ))}
        </ol>
      )
    }
  </section>
</Base>

<script>
  // Client-side search for the history page.
  //
  // The day-grouped list already renders every article's title +
  // excerpt into the DOM (the server sends all 7 days at once), so a
  // real search is a simple visibility filter — no network, no
  // indexing service, no debounce needed for the size of the dataset
  // (typical: 7 days × ~30 articles/day = ~210 rows).
  //
  // Behaviour:
  //   - Empty query → show every row, auto-open every <details>
  //     collapses stay where the user left them.
  //   - Non-empty query → case-insensitive substring match against
  //     each article's title + visible excerpt. Articles that match
  //     stay visible; others get hidden via a data-attribute so CSS
  //     can pick up the toggle.
  //   - Day wrappers that end up with zero visible articles hide too,
  //     so the user doesn't see empty day headers.
  //   - While searching, we auto-expand every <details> so matches
  //     anywhere in the 7-day window surface without the user having
  //     to click each day open.
  //
  // Tear down on astro:before-swap so the listener doesn't leak
  // across View Transition navigations.
  function initHistorySearch(): () => void {
    const input = document.querySelector<HTMLInputElement>(
      '[data-history-search]',
    );
    if (input === null) return () => {};
    const days = Array.from(
      document.querySelectorAll<HTMLElement>('[data-history-day]'),
    );
    type CardEntry = { el: HTMLElement; haystack: string };
    const cards: CardEntry[] = [];
    for (const day of days) {
      const dayCards = day.querySelectorAll<HTMLElement>('[data-digest-card]');
      for (const card of Array.from(dayCards)) {
        const title =
          card.querySelector('.digest-card__title')?.textContent ?? '';
        const excerpt =
          card.querySelector('.digest-card__one-liner')?.textContent ?? '';
        cards.push({ el: card, haystack: (title + ' ' + excerpt).toLowerCase() });
      }
    }
    const originalOpenState = days.map((day) => {
      const details = day.querySelector('details');
      return details?.hasAttribute('open') ?? false;
    });

    const apply = (): void => {
      const q = input.value.trim().toLowerCase();
      const searching = q !== '';
      for (const { el, haystack } of cards) {
        const match = searching ? haystack.includes(q) : true;
        el.hidden = !match;
      }
      days.forEach((day, idx) => {
        const visible = day.querySelectorAll<HTMLElement>(
          '[data-digest-card]:not([hidden])',
        ).length;
        day.hidden = searching && visible === 0;
        const details = day.querySelector<HTMLDetailsElement>('details');
        if (details !== null) {
          if (searching) {
            details.open = visible > 0;
          } else {
            details.open = originalOpenState[idx] ?? false;
          }
        }
      });
      const anyVisibleDay = days.some((d) => !d.hidden);
      const empty = document.querySelector<HTMLElement>('[data-history-empty]');
      if (empty !== null) {
        // The server-rendered empty state (no rows at all) should
        // stay as-is; this branch only creates a transient search-
        // empty message when the user's query returns nothing.
        let noMatchEl = document.querySelector<HTMLElement>(
          '[data-search-nomatch]',
        );
        if (searching && !anyVisibleDay && cards.length > 0) {
          if (noMatchEl === null) {
            noMatchEl = document.createElement('p');
            noMatchEl.className = 'history__empty';
            noMatchEl.setAttribute('data-search-nomatch', '');
            const list = document.querySelector('[data-history-list]');
            list?.parentElement?.appendChild(noMatchEl);
          }
          noMatchEl.textContent = `No articles match "${input.value.trim()}".`;
          noMatchEl.hidden = false;
        } else if (noMatchEl !== null) {
          noMatchEl.hidden = true;
        }
      }
    };

    input.addEventListener('input', apply);
    return () => {
      input.removeEventListener('input', apply);
    };
  }

  let teardown = initHistorySearch();
  document.addEventListener('astro:before-swap', () => {
    teardown();
  }, { once: true });
  document.addEventListener('astro:page-load', () => {
    teardown = initHistorySearch();
  });
</script>

<style>
  .history {
    max-width: 960px;
    margin: 0 auto;
    padding: 1.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .history__hero {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .history__title {
    margin: 0;
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--text);
  }

  .history__subtitle {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-base);
  }

  .history__search {
    display: flex;
  }

  .history__search-input {
    width: 100%;
    min-height: 40px;
    padding: 0.4rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 0.375rem;
    background-color: var(--surface);
    color: var(--text);
    font-size: var(--text-base);
  }

  .history__search-input:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .history__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .history__day {
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    background-color: var(--surface);
    overflow: hidden;
  }

  .history__details > summary {
    list-style: none;
    cursor: pointer;
  }

  .history__details > summary::-webkit-details-marker {
    display: none;
  }

  .history__summary {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1rem;
    min-height: 44px;
    color: var(--text);
    font-variant-numeric: tabular-nums;
  }

  .history__summary:hover {
    background-color: var(--bg);
  }

  .history__date {
    font-weight: 600;
  }

  .history__sep {
    color: var(--text-muted);
  }

  .history__count,
  .history__tokens,
  .history__cost {
    color: var(--text-muted);
    font-size: var(--text-sm);
  }

  .history__body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 0.75rem 1rem 1.25rem;
    border-top: 1px solid var(--border);
  }

  .history__ticks {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .history__tick {
    display: grid;
    grid-template-columns: auto 1fr 1fr 1fr auto;
    gap: 0.75rem;
    align-items: center;
    padding: 0.4rem 0.5rem;
    font-size: var(--text-sm);
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
    border-radius: 0.25rem;
  }

  .history__tick:nth-child(odd) {
    background-color: var(--bg);
  }

  .history__tick-time {
    font-weight: 600;
    color: var(--text);
  }

  .history__tick-status {
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .history__tick[data-status='failed'] .history__tick-status {
    color: #b91c1c;
  }

  .history__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.75rem;
  }

  .history__empty {
    margin: 0;
    padding: 2rem;
    color: var(--text-muted);
    text-align: center;
    border: 1px dashed var(--border);
    border-radius: 0.5rem;
  }

  @media (max-width: 640px) {
    .history__tick {
      grid-template-columns: auto 1fr;
      row-gap: 0.2rem;
    }
    .history__tick-status {
      grid-column: 2;
      text-align: right;
    }
  }
</style>
