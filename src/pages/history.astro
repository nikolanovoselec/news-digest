---
// Implements REQ-HIST-001
//
// /history — day-grouped list of the authenticated user's last 7 days
// of articles, plus per-day aggregates from the global `scrape_runs`
// table. Each day row expands via a native <details> element to reveal
// its tick list (every hourly run's timestamp, articles ingested,
// tokens, cost) followed by the article cards for that day.
//
// Data is loaded in-process from /api/history so the page never pays
// for a same-origin subrequest hop. The title ("History") stays as-is
// for this phase — a future phase may rename it to "Search & History"
// and add a live search box.

import type { APIContext } from 'astro';
import Base from '~/layouts/Base.astro';
import DigestCard from '~/components/DigestCard.astro';
import { loadSession } from '~/middleware/auth';
import { slugify } from '~/lib/slug';
import { GET as getHistory } from '~/pages/api/history';

interface WireArticle {
  id: string;
  title: string;
  primary_source_name: string | null;
  primary_source_url: string | null;
  published_at: number;
  details: string[];
  tags: string[];
}

interface DayGroup {
  local_date: string;
  article_count: number;
  articles: WireArticle[];
  // `ticks` (per-scrape-run detail) is still returned by /api/history
  // but no longer rendered — cumulative day-level tokens/cost below
  // replace it.
  day_tokens_in: number;
  day_tokens_out: number;
  day_cost_usd: number;
  day_articles_ingested: number;
}

interface HistoryResponse {
  days: DayGroup[];
}

const env = Astro.locals.runtime.env;
if (typeof env.OAUTH_JWT_SECRET !== 'string' || env.OAUTH_JWT_SECRET === '') {
  return new Response('Application not configured', { status: 500 });
}

const session = await loadSession(
  Astro.request,
  env.DB,
  env.OAUTH_JWT_SECRET,
);
if (session === null) {
  return Astro.redirect('/api/auth/github/login', 303);
}
Astro.locals.user = session.user;

// Fetch the day-grouped payload in-process. Same pattern as digest.astro:
// a direct handler call side-steps the subrequest hop that silently
// returns zero rows on the deployed Worker.
let data: HistoryResponse = { days: [] };
try {
  const res = await getHistory({
    request: Astro.request,
    locals: Astro.locals,
    url: new URL('/api/history', Astro.request.url),
  } as unknown as APIContext);
  if (res.ok) {
    data = (await res.json()) as HistoryResponse;
  }
} catch {
  data = { days: [] };
}

const days = data.days;

/** Comma-grouped integer, em-dash when null/undefined. */
function formatInt(n: number | null | undefined): string {
  if (n === null || n === undefined || !Number.isFinite(n)) return '\u2014';
  return Math.max(0, Math.round(n)).toLocaleString('en-US');
}

/** USD cost with sig-fig-aware decimal places, em-dash when null. */
function formatCostUsd(value: number | null | undefined): string {
  if (value === null || value === undefined || !Number.isFinite(value)) return '\u2014';
  if (value === 0) return '$0.00';
  const precise = Math.abs(value).toPrecision(value < 0.01 ? 2 : 3);
  const asNum = Number(precise);
  const fixed = asNum < 0.01 ? asNum.toFixed(4) : asNum.toFixed(2);
  return `$${fixed}`;
}

---

<!-- Implements REQ-HIST-001 -->
<Base title="Search & History">
  <section class="history">
    <header class="history__hero">
      <h1 class="history__title">Search &amp; History</h1>
      <p class="history__subtitle">The last 7 days of articles matching your tags.</p>
      <label class="history__search" aria-label="Search history">
        <input
          type="search"
          class="history__search-input"
          placeholder="Search titles and summaries (3+ chars)…"
          data-history-search
          autocomplete="off"
          minlength="3"
        />
      </label>
    </header>

    {/* Flat grid of matching cards — same breakpoint math as
        .digest-page__grid on the dashboard so search results feel
        like a dashboard view filtered by query. Only visible when
        the search query has ≥3 characters; the day-grouped list
        below hides while this is showing. */}
    <div class="history__search-grid" data-search-grid hidden></div>
    <p class="history__search-empty" data-search-empty hidden aria-live="polite"></p>

    {
      days.length === 0 ? (
        <p class="history__empty" data-history-empty>
          No articles in the last 7 days.
        </p>
      ) : (
        <ol class="history__list" data-history-list>
          {days.map((day) => (
            <li class="history__day" data-history-day data-date={day.local_date}>
              <details class="history__details">
                <summary class="history__summary">
                  <span class="history__date">{day.local_date}</span>
                  <span class="history__sep" aria-hidden="true">·</span>
                  <span class="history__count">
                    {day.article_count} {day.article_count === 1 ? 'story' : 'stories'}
                  </span>
                  <span class="history__sep" aria-hidden="true">·</span>
                  <span class="history__tokens">
                    {formatInt(day.day_tokens_in + day.day_tokens_out)} tokens
                  </span>
                  <span class="history__sep" aria-hidden="true">·</span>
                  <span class="history__cost">{formatCostUsd(day.day_cost_usd)}</span>
                </summary>

                {/* Day body is just the article grid — per-tick scrape_run
                    details are now summarised cumulatively in the
                    summary row above (tokens + cost for the whole day).
                    Opening a day shows the articles directly. */}
                <div class="history__body">
                  {day.articles.length > 0 && (
                    <div class="history__grid" data-history-grid>
                      {day.articles.map((a, i) => (
                        <DigestCard
                          digestId={a.id}
                          slug={slugify(a.title)}
                          title={a.title}
                          oneLiner={a.details[0] ?? ''}
                          sourceName={a.primary_source_name}
                          sourceUrl={a.primary_source_url}
                          tags={a.tags}
                          index={i}
                        />
                      ))}
                    </div>
                  )}
                </div>
              </details>
            </li>
          ))}
        </ol>
      )
    }
  </section>
</Base>

<script>
  // Client-side search for the history page.
  //
  // When the query is ≥ 3 characters, matching articles render as a
  // flat grid at the top (same breakpoint math as .digest-page__grid
  // on the dashboard) and the day-grouped list below hides. Typing
  // below 3 characters (or clearing the query) restores the
  // day-grouped view instantly.
  //
  // Matching cards are CLONED into the flat grid (cheaper than
  // splicing the live DOM around; the scroll position stays put).
  // Clones have their `data-bound` flags stripped so the shared
  // `initCardInteractions` helper re-binds the star + tag-disclosure
  // click handlers on each clone. Without that rebind, the buttons
  // would be visually present but dead to taps.
  //
  // Lifecycle: rewire on every astro:page-load (View Transitions
  // rebuild the DOM), and tear down on every astro:before-swap so
  // the previous listener doesn't leak across navigations.
  import { initCardInteractions } from '~/scripts/card-interactions';

  const MIN_QUERY_LEN = 3;

  function initHistorySearch(): () => void {
    const input = document.querySelector<HTMLInputElement>(
      '[data-history-search]',
    );
    const searchGrid = document.querySelector<HTMLElement>('[data-search-grid]');
    const searchEmpty = document.querySelector<HTMLElement>('[data-search-empty]');
    const list = document.querySelector<HTMLElement>('[data-history-list]');
    if (input === null || searchGrid === null || searchEmpty === null) {
      return () => {};
    }

    type CardEntry = { el: HTMLElement; haystack: string };
    const cards: CardEntry[] = [];
    const source = document.querySelectorAll<HTMLElement>(
      '[data-history-list] [data-digest-card]',
    );
    for (const card of Array.from(source)) {
      const title =
        card.querySelector('.digest-card__title')?.textContent ?? '';
      const excerpt =
        card.querySelector('.digest-card__one-liner')?.textContent ?? '';
      cards.push({ el: card, haystack: (title + ' ' + excerpt).toLowerCase() });
    }

    const apply = (): void => {
      const q = input.value.trim().toLowerCase();
      const searching = q.length >= MIN_QUERY_LEN;

      // Short / empty query → restore day-grouped view.
      if (!searching) {
        searchGrid.innerHTML = '';
        searchGrid.hidden = true;
        searchEmpty.hidden = true;
        if (list !== null) list.hidden = false;
        return;
      }

      // ≥3 chars → flat grid of matches, day list hidden.
      if (list !== null) list.hidden = true;
      searchGrid.innerHTML = '';
      let matches = 0;
      for (const { el, haystack } of cards) {
        if (!haystack.includes(q)) continue;
        const clone = el.cloneNode(true) as HTMLElement;
        // Clear the per-button bound flags so initCardInteractions
        // re-binds click handlers on this fresh DOM subtree.
        clone
          .querySelectorAll<HTMLElement>('[data-bound="1"]')
          .forEach((b) => {
            b.removeAttribute('data-bound');
          });
        // Strip Astro's view-transition scope from the clone so it
        // cannot conflict with the ORIGINAL card's `transition:name`
        // that still sits in the hidden day list. The spec only
        // allows a single element per `view-transition-name` value
        // during a transition; duplicates silently abort the
        // animation. The animation here is polish, not contract, so
        // it's safe to drop it on the search clone rather than
        // rewrite the scope to a unique value.
        clone
          .querySelectorAll<HTMLElement>('[data-astro-transition-scope]')
          .forEach((scoped) => {
            scoped.removeAttribute('data-astro-transition-scope');
          });
        searchGrid.appendChild(clone);
        matches++;
      }
      searchGrid.hidden = false;
      if (matches === 0) {
        searchEmpty.textContent = `No articles match "${input.value.trim()}".`;
        searchEmpty.hidden = false;
      } else {
        searchEmpty.hidden = true;
      }
      // Rebind star + tag-disclosure handlers on the cloned buttons.
      initCardInteractions(searchGrid);
    };

    input.addEventListener('input', apply);
    return () => {
      input.removeEventListener('input', apply);
    };
  }

  // Gate the document-level listeners behind a flag on <html> so
  // returning to /history via View Transitions does NOT stack a fresh
  // astro:before-swap + astro:page-load pair on every visit. The
  // module-level script re-executes on each return, but the guard
  // keeps the document listeners singletons — same pattern
  // card-interactions.ts uses for `cardOutsideClickBound`. The
  // `teardown` reference itself is updated on each page-load so the
  // swap handler always tears down the CURRENT input wiring.
  let teardown = initHistorySearch();
  if (document.documentElement.dataset['historySearchBound'] !== '1') {
    document.documentElement.dataset['historySearchBound'] = '1';
    document.addEventListener('astro:before-swap', () => {
      teardown();
    });
    document.addEventListener('astro:page-load', () => {
      teardown = initHistorySearch();
    });
  }
</script>

<style>
  .history {
    max-width: 960px;
    margin: 0 auto;
    padding: 1.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .history__hero {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .history__title {
    margin: 0;
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--text);
  }

  .history__subtitle {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-base);
  }

  .history__search {
    display: flex;
  }

  .history__search-input {
    width: 100%;
    min-height: 40px;
    padding: 0.4rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 0.375rem;
    background-color: var(--surface);
    color: var(--text);
    font-size: var(--text-base);
  }

  .history__search-input:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .history__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .history__day {
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    background-color: var(--surface);
    overflow: hidden;
  }

  .history__details > summary {
    list-style: none;
    cursor: pointer;
  }

  .history__details > summary::-webkit-details-marker {
    display: none;
  }

  .history__summary {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1rem;
    min-height: 44px;
    color: var(--text);
    font-variant-numeric: tabular-nums;
  }

  .history__summary:hover {
    background-color: var(--bg);
  }

  .history__date {
    font-weight: 600;
  }

  .history__sep {
    color: var(--text-muted);
  }

  .history__count,
  .history__tokens,
  .history__cost {
    color: var(--text-muted);
    font-size: var(--text-sm);
  }

  .history__body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 0.75rem 1rem 1.25rem;
    border-top: 1px solid var(--border);
  }

  .history__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.75rem;
  }

  /* Search results grid — matches .digest-page__grid breakpoints so
     typing into Search looks like a dashboard view filtered by the
     query. 1 col on mobile, 2 from 768px, 3 from 1024px. */
  .history__search-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  .history__search-grid[hidden] {
    display: none;
  }
  @media (min-width: 768px) {
    .history__search-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.25rem;
    }
  }
  @media (min-width: 1024px) {
    .history__search-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .history__empty,
  .history__search-empty {
    margin: 0;
    padding: 2rem;
    color: var(--text-muted);
    text-align: center;
    border: 1px dashed var(--border);
    border-radius: 0.5rem;
  }
</style>
