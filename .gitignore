node_modules/
dist/
.astro/

# Generated by `npm run icons` (or the build/deploy scripts) — reproducible
# from public/icons/app-icon.svg, never committed.
public/icons/app-icon-*.png

# CF-001 — generated by `node scripts/build-client-scripts.mjs` during
# `npm run build` from the TypeScript sources at src/scripts/*.ts.
# Hand-edits would drift from source; CI rebuilds on every push.
public/scripts/*.js

.wrangler/
.dev.vars
.env
.env.local
*.log
.DS_Store
coverage/
.vscode/
.idea/

# Playwright (live-site e2e suite — see playwright.config.ts)
playwright-report/
test-results/
.playwright/

# graphify caches (regenerable, large)
graphify-out/cache/
graphify-out/.cache/
graphify-out/.chunks/
graphify-out/manifest.json
graphify-out/obsidian/

# graphify working-tree intermediates (created mid-run, cleaned at the end
# of a successful build; defensive in case a run is interrupted before cleanup)
.graphify_ast.json
.graphify_semantic.json
.graphify_extract.json
.graphify_detect.json
.graphify_analysis.json
.graphify_cached.json
.graphify_uncached.txt
.graphify_chunk_*.txt
.graphify_old.json
