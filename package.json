{
  "name": "news-digest",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/merge-worker-handlers.mjs",
    "preview": "wrangler dev",
    "deploy": "astro build && wrangler deploy",
    "fixtures": "node scripts/generate-test-fixtures.mjs",
    "typecheck": "npm run fixtures && astro check && tsc --noEmit",
    "test": "npm run fixtures && vitest run",
    "test:watch": "npm run fixtures && vitest",
    "lint": "oxlint src/ tests/ --deny-warnings --ignore-pattern '**/*.astro'",
    "lint:fix": "oxlint src/ tests/ --fix --ignore-pattern '**/*.astro'",
    "knip": "knip"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.13",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^5.18.1",
    "fast-xml-parser": "^5.0.9",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@cloudflare/vitest-pool-workers": "^0.14.9",
    "@cloudflare/workers-types": "^4.20260422.1",
    "@types/node": "^25.6.0",
    "@vite-pwa/astro": "^1.2.0",
    "esbuild": "^0.28.0",
    "knip": "^6.6.1",
    "oxlint": "^1.61.0",
    "typescript": "^5.7.1",
    "vitest": "^4.1.5",
    "wrangler": "^4.84.1"
  }
}
