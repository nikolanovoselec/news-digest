{
  "name": "news-digest",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler dev",
    "deploy": "astro build && wrangler deploy",
    "typecheck": "astro check && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src/ tests/ --deny-warnings",
    "lint:fix": "oxlint src/ tests/ --fix",
    "knip": "knip"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.0.0",
    "@astrojs/tailwind": "^6.0.0",
    "astro": "^5.0.0",
    "fast-xml-parser": "^4.5.0",
    "tailwindcss": "^3.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.7.0",
    "@cloudflare/workers-types": "^4.20260405.0",
    "@types/node": "^22.0.0",
    "@vite-pwa/astro": "^0.5.0",
    "knip": "^5.40.0",
    "oxlint": "^0.15.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "wrangler": "^3.100.0"
  }
}
